{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "strictNullChecks": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "composite": false,
    "module": "ES2022",
    "moduleResolution": "bundler",
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"],
}
