  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./radu-machine-learning": "./src/App.tsx",
    "./styles": "./src/styles/styles.css"
  },
  "scripts": {
    "postinstall": "cp -r public/radu-img ../../apps/playground/public/radu-img",
    "dev": "vite --host",
