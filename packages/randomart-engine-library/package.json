{
  "name": "@repo/randomart-engine-library",
  "version": "1.0.0",
  "description": "Generate visual and symbolic random-art representations of a text seed (Perrig & Song hash visualization).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "randomart": "./src/cli.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "randomart": "npx tsx src/cli.ts",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "keywords": [
    "randomart",
    "hash-visualization",
    "drunken-bishop",
    "identicon",
    "png",
    "glsl"
  ],
  "license": "MIT",
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsx": "^4.23.0",
    "typescript": "catalog:"
  }
}
