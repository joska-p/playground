{
  "$schema": "https://v2-10-1.turborepo.dev/schema.json",
  "ui": "stream-with-experimental-timestamps",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".astro/**",
        "dist/**",
        "storybook-static/**",
        ".next/**",
        "!.next/cache/**",
        ".svelte-kit/**",
        ".output/**"
      ]
    },
    "test": {
      "outputs": ["coverage/**", "playwright-report/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [".eslintcache"]
    },
    "lint-fix": {
      "dependsOn": ["^lint-fix"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
