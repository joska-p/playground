# =============================================================================
# Zero-Pollution Agent Sandbox
# Base: Debian Slim (small, stable, broad package support)
# =============================================================================
FROM docker.io/debian:bookworm-slim

# --- Core system tools -------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl wget git vim nano less jq unzip zip \
    build-essential ca-certificates gnupg \
    procps iputils-ping dnsutils \
    python3 python3-pip python3-venv pipx \
    && curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - \
    && apt-get install -y nodejs \
    && curl -fsSL https://go.dev/dl/go1.22.4.linux-amd64.tar.gz \
       | tar -C /usr/local -xz \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# --- Paths -------------------------------------------------------------------
ENV PATH="/usr/local/go/bin:${PATH}"
ENV SANDBOX_HOME="/opt/sandbox"
ENV PIPX_HOME="${SANDBOX_HOME}/pipx"
ENV PIPX_BIN_DIR="${SANDBOX_HOME}/bin"
ENV PNPM_HOME="${SANDBOX_HOME}/pnpm"
ENV PATH="${SANDBOX_HOME}/bin:${PNPM_HOME}:${PATH}"

RUN mkdir -p "${SANDBOX_HOME}/bin" "${SANDBOX_HOME}/pnpm"

# --- pnpm via corepack -------------------------------------------------------
RUN corepack enable pnpm \
 && corepack prepare pnpm@latest --activate \
 && pnpm config set store-dir "${SANDBOX_HOME}/pnpm-store" --global

# --- Python tools via pipx ---------------------------------------------------
RUN pipx install aider-chat \
 && pipx install llm \
 && pipx install open-interpreter \
 && chmod -R 755 "${SANDBOX_HOME}/pipx" "${SANDBOX_HOME}/bin"

# --- Node tools via pnpm -----------------------------------------------------
RUN pnpm add -g \
    @anthropic-ai/sdk \
    typescript \
    ts-node

# --- Profile: make /opt/sandbox available to all login shells ----------------
RUN printf '%s\n' \
    'export PATH="/opt/sandbox/bin:/opt/sandbox/pnpm:${PATH}"' \
    'export PIPX_HOME="/opt/sandbox/pipx"' \
    'export PNPM_HOME="/opt/sandbox/pnpm"' \
    > /etc/profile.d/sandbox.sh \
 && chmod 644 /etc/profile.d/sandbox.sh

# --- Prepare /etc/skel so new users inherit the shell config -----------------
RUN printf '%s\n' \
    'source /etc/profile.d/sandbox.sh' \
    'export PS1="[sandbox] \w \$ "' \
    'alias ll="ls -lah --color=auto"' \
    >> /etc/skel/.bashrc

# --- Create dev user (copies skel, so /home/dev/.bashrc is ready) ------------
RUN useradd -m -s /bin/bash -u 1000 dev

# --- Port Exposure -----------------------------------------------------------
# Astro: 4321, Storybook: 6006, etc.
EXPOSE 4321 6006 3000 5000 8080 8888

# --- Entrypoint --------------------------------------------------------------
CMD ["/bin/bash", "--login"]
