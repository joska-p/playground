# =============================================================================
# Dev Sandbox — Debian Bookworm Slim
# Stack: Node.js via nvm · pnpm · Python via uv · Zsh + Oh My Zsh
# Tools: opencode · graphify · turbo · eslint · prettier · language servers
# =============================================================================
FROM docker.io/debian:bookworm-slim


# -----------------------------------------------------------------------------
# 1. System packages
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    zsh curl wget git vim nano less jq unzip zip openssh-client \
    build-essential ca-certificates gnupg \
    procps iputils-ping dnsutils \
    graphviz \
 && apt-get clean && rm -rf /var/lib/apt/lists/*


# -----------------------------------------------------------------------------
# 2. Create the dev user and skeleton directory
#
# Tools are installed into /opt/sandbox/skel instead of /home/dev because the
# devcontainer bind-mounts .container_home/ over /home/dev at runtime, which
# would hide anything written there at build time. postCreateCommand copies
# skel into /home/dev on first start, once the mount is already applied.
#
# UID 1000 matches the default host UID, required by --userns=keep-id.
# -----------------------------------------------------------------------------
RUN useradd -m -s /bin/zsh -u 1000 dev \
 && mkdir -p /opt/sandbox/skel \
 && chown -R dev:dev /opt/sandbox

USER dev
WORKDIR /opt/sandbox/skel


# -----------------------------------------------------------------------------
# 3. nvm + Node.js 24 + pnpm via corepack
#
# NVM_DIR is exported inline (not via ENV) so the directory exists before the
# installer checks for it. mkdir -p is required for the same reason.
# -----------------------------------------------------------------------------
RUN export NVM_DIR="/opt/sandbox/skel/.nvm" \
 && mkdir -p "$NVM_DIR" \
 && curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash \
 && . "$NVM_DIR/nvm.sh" \
 && nvm install 24 \
 && nvm alias default 24 \
 && nvm use default \
 && export PATH="$(nvm which default | xargs dirname):$PATH" \
 && corepack enable pnpm \
 && corepack prepare pnpm@latest --activate


# -----------------------------------------------------------------------------
# 4. pnpm global tools
#
# Each RUN is a fresh shell with no profile, so nvm.sh must be sourced and
# PATH exported manually on every step that needs node/pnpm.
# -----------------------------------------------------------------------------
ENV PNPM_HOME="/opt/sandbox/skel/.local/share/pnpm"

RUN export NVM_DIR="/opt/sandbox/skel/.nvm" \
 && . "$NVM_DIR/nvm.sh" \
 && nvm use default \
 && export PATH="$(nvm which default | xargs dirname):$PNPM_HOME:$PATH" \
 && pnpm config set store-dir /opt/sandbox/skel/.local/share/pnpm-store --global \
 && pnpm add -g \
    opencode-ai \
    typescript \
    turbo \
    eslint \
    prettier \
    typescript-language-server \
    @astrojs/language-server \
    @tailwindcss/language-server


# -----------------------------------------------------------------------------
# 5. uv + graphify
#
# graphify requires a post-install step to download its rendering backend.
# graphifyy with 2 y is the name of the package. It's not a typo.
# -----------------------------------------------------------------------------
ENV UV_TOOL_DIR="/opt/sandbox/skel/.local/uv-tools"
ENV UV_TOOL_BIN_DIR="/opt/sandbox/skel/.local/bin"

RUN curl -LsSf https://astral.sh/uv/install.sh | UV_INSTALL_DIR=/opt/sandbox/skel/.local/bin sh \
 && export PATH="/opt/sandbox/skel/.local/bin:$PATH" \
 && uv tool install graphifyy \
 && graphify install --platform opencode


# -----------------------------------------------------------------------------
# 6. Oh My Zsh + powerlevel10k + zsh-autosuggestions
# -----------------------------------------------------------------------------
ENV ZSH="/opt/sandbox/skel/.oh-my-zsh"
ENV ZSH_CUSTOM="/opt/sandbox/skel/.oh-my-zsh/custom"

RUN sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" \
    "" --unattended \
 && git clone --depth=1 https://github.com/romkatv/powerlevel10k.git \
    "$ZSH_CUSTOM/themes/powerlevel10k" \
 && git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions \
    "$ZSH_CUSTOM/plugins/zsh-autosuggestions"


# -----------------------------------------------------------------------------
# 7. .zshrc
# -----------------------------------------------------------------------------
RUN printf 'export ZSH="$HOME/.oh-my-zsh"\n\
ZSH_THEME="powerlevel10k/powerlevel10k"\n\
plugins=(git z zsh-autosuggestions)\n\
source $ZSH/oh-my-zsh.sh\n\
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh\n\
export NVM_DIR="$HOME/.nvm"\n\
[ -s "$NVM_DIR/nvm.sh" ] && \\. "$NVM_DIR/nvm.sh"\n\
export PNPM_HOME="$HOME/.local/share/pnpm"\n\
export PATH="$PNPM_HOME:$PATH"\n\
export UV_TOOL_DIR="$HOME/.local/uv-tools"\n\
export UV_TOOL_BIN_DIR="$HOME/.local/bin"\n\
export PATH="$HOME/.local/bin:$PATH"\n\
alias ll="ls -lah --color=auto"\n\
alias gs="git status"\n' > /opt/sandbox/skel/.zshrc

# -----------------------------------------------------------------------------
# 8. init-home.sh
# -----------------------------------------------------------------------------
RUN printf '#!/bin/bash\n\
set -e\n\
echo "[sandbox] Initialising home directory..."\n\
for item in /opt/sandbox/skel/.*; do\n\
  name="$(basename "$item")"\n\
  [ "$name" = "." ] || [ "$name" = ".." ] && continue\n\
  dest="$HOME/$name"\n\
  if [ ! -e "$dest" ]; then\n\
    cp -a "$item" "$dest"\n\
  elif [ -d "$item" ] && [ -d "$dest" ]; then\n\
    cp -rn "$item/." "$dest/"\n\
  fi\n\
done\n\
if ! command -v graphify &>/dev/null; then\n\
  /opt/sandbox/skel/.local/bin/uv tool install graphifyy\n\
fi\n' > /opt/sandbox/init-home.sh

RUN chmod +x /opt/sandbox/init-home.sh


# Astro: 4321 4322 · Storybook: 6006 · Generic: 3000 / 5000 / 8080 / 8888
EXPOSE 4321 4322 6006 3000 5000 8080 8888

CMD ["/bin/zsh", "--login"]
