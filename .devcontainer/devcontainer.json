{
  // -------------------------------------------------------------------------
  // Dev Container — "boffin" experiment sandbox
  // Spec: https://containers.dev/implementors/json_reference/
  // -------------------------------------------------------------------------
  "name": "playground-dev",
  "containerName": "playground-dev",
  "appPorts": [2222, 3000, 4321, 4322, 5000, 5173, 5174, 5175, 6006, 8080, 8888],
  // Build from the local ContainerFile (Podman-compatible)
  "build": {
    "dockerfile": "ContainerFile",
    "context": ".."
  },

  // Run as the boffin user (UID 1000 = your host user)
  "remoteUser": "boffin",
  "containerUser": "boffin",

  // -------------------------------------------------------------------------
  // Mounts
  //   - Bind the container home to your local playground directory so that
  //     everything boffin installs or creates persists across container runs.
  //   - The source path must already exist on the host (or be created before
  //     starting the container).
  // -------------------------------------------------------------------------
  "mounts": [
    {
      "type": "bind",
      "source": "${localWorkspaceFolder}/.container_home",
      "target": "/home/boffin",
      "consistency": "cached"
    }
  ],

  // -------------------------------------------------------------------------
  // Port forwarding — all ports are forwarded to the same host port
  // -------------------------------------------------------------------------
  "forwardPorts": [2222, 3000, 4321, 4322, 5000, 5173, 5174, 5175, 6006, 8080, 8888],

  // -------------------------------------------------------------------------
  // Container run arguments (Podman / Docker)
  //   --userns=keep-id  → Podman maps your host UID into the container so
  //                        bind-mount ownership stays consistent.
  //                        Remove this line if you use Docker instead.
  // -------------------------------------------------------------------------
  "runArgs": ["--userns=keep-id", "--name", "playground-dev"],

  // -------------------------------------------------------------------------
  // Lifecycle hooks
  //   Ensure the local mount target exists before the container starts.
  // -------------------------------------------------------------------------
  "initializeCommand": "mkdir -p ${localWorkspaceFolder}/.container_home",

  // -------------------------------------------------------------------------
  // Start SSH server automatically when the container starts
  // -------------------------------------------------------------------------
  "postStartCommand": "bash -lc 'pgrep -x sshd >/dev/null || sudo /usr/sbin/sshd'",

  // -------------------------------------------------------------------------
  // Run setup script after the container is created
  // -------------------------------------------------------------------------
  "postCreateCommand": "GITLAB_USER=jpotin bash .devcontainer/scripts/setup.sh all"
}
