{
  "name": "sandbox-dev",

  "build": {
    "dockerfile": "./Containerfile",
    "context": ".."
  },

  // --userns=keep-id maps your host UID to UID 1000 inside the container,
  // so files created inside are owned by you on the host without sudo.
  "runArgs": ["--userns=keep-id"],

  "remoteUser": "dev",

  // Bind-mount .container_home/ as /home/dev so your shell config, history,
  // and tool state persist across container rebuilds on your host machine.
  // Create it once with: mkdir .container_home
  "mounts": [
    "source=${localWorkspaceFolder}/.container_home,target=/home/dev,type=bind,consistency=cached"
  ],

  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",

  // Astro: 4321 · Storybook: 6006 · Generic: 3000 / 5000 / 8080 / 8888
  "forwardPorts": [4321, 6006, 3000, 5000, 8080, 8888],

  // Needed so non-interactive processes (editor extensions, scripts) can find
  // node, pnpm, uv, etc. without sourcing .zshrc first.
  "containerEnv": {
    "NVM_DIR": "/home/dev/.nvm",
    "PNPM_HOME": "/home/dev/.local/share/pnpm",
    "UV_TOOL_DIR": "/home/dev/.local/uv-tools",
    "UV_TOOL_BIN_DIR": "/home/dev/.local/bin"
  },

  // Copies items from /opt/sandbox/skel into /home/dev for anything that
  // doesn't already exist there, so your customisations are never overwritten.
  "postCreateCommand": "bash /opt/sandbox/init-home.sh"
}
