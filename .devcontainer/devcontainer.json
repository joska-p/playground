{
  "name": "creative-playground",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers-extra/features/ffmpeg-apt-get:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {},
    "ghcr.io/devcontainers-extra/features/uv:1": {}
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/playground,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/playground",
  "remoteUser": "vscode",
  "mounts": [
    {
      "source": "playground-home-volume",
      "target": "/home/vscode",
      "type": "volume"
    }
  ],
  "forwardPorts": [
    2222, 3000, 4321, 4322, 5000, 5173, 5174, 5175, 6006, 8080, 8888
  ],
  "runArgs": ["--userns=keep-id", "--name", "playground"],
  "postCreateCommand": "uv python install 3.14 && echo 'alias python=\"uv run python\"' >> /home/vscode/.zshrc && echo 'alias python3=\"uv run python3\"' >> /home/vscode/.zshrc && echo 'alias pip=\"uv run pip\"' >> /home/vscode/.zshrc && echo 'alias pip3=\"uv run pip3\"' >> /home/vscode/.zshrc && sudo chsh -s $(which zsh) vscode"
}
