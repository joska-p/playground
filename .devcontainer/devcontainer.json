{
  "name": "creative-playground",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers-extra/features/ffmpeg-apt-get:1": {},
    "ghcr.io/devcontainers/features/nvidia-cuda:3": {
      "installToolkit": true
    }
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/playground,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/playground",
  "remoteUser": "vscode",
  "mounts": [
    {
      "source": "playground-home-volume",
      "target": "/home/vscode",
      "type": "volume"
    }
  ],
  "hostRequirements": {
    "gpu": "optional"
  },
  "forwardPorts": [2222, 3000, 4321, 4322, 5000, 5173, 5174, 5175, 6006, 8080, 8888],
  "runArgs": ["--name", "playground", "--gpus=all"],
  "settings": {
    "terminal.integrated.env.linux": {
      "NVIDIA_VISIBLE_DEVICES": "all",
      "NVIDIA_DRIVER_CAPABILITIES": "compute,utility"
    }
  },
  "postStartCommand": "bash .devcontainer/scripts/setup.sh && usermod --shell /bin/zsh vscode"
}
