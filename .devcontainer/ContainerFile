# =============================================================================
# ContainerFile — boffin-lab
#
# Base: mcr.microsoft.com/devcontainers/base:debian (bookworm)
#
# Already provided by the base image (no need to install):
#   bash, bash-completion, curl, wget, gnupg, ca-certificates, git,
#   less, lsb-release, locales (en_US.UTF-8), procps, sudo, unzip, zip,
#   non-root user scaffold (UID 1000), passwordless sudo
#
# Layer strategy:
#   - Everything here is STABLE and benefits from layer caching.
#   - Fast-changing things (dotfiles, tool versions, SSH keys) live in setup.sh.
#   - Rebuild this image rarely; run setup.sh often.
# =============================================================================
FROM mcr.microsoft.com/devcontainers/base:debian

# -----------------------------------------------------------------------------
# Rename the default "vscode" user (UID 1000) to "boffin" and set zsh as shell
# -----------------------------------------------------------------------------
RUN usermod -l boffin -d /home/boffin -m vscode \
    && groupmod -n boffin vscode \
    && chsh -s /bin/zsh boffin \
    && echo "boffin ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/boffin \
    && chmod 0440 /etc/sudoers.d/boffin

# -----------------------------------------------------------------------------
# Additional packages — only what the base does NOT already provide
#
#   • Shell & terminal extras
#   • Build toolchain (required by pyenv to compile Python)
#   • Media tools (ffmpeg + imagemagick for creative-coding exports)
#   • Fonts (needed by imagemagick + some canvas renderers)
#   • SSH server
#   • Misc extras
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    \
    # --- Shell & terminal extras ---
    bat \
    dnsutils \
    iputils-ping \
    lsof \
    man-db \
    net-tools \
    tree \
    vim \
    zsh \
    zsh-common \
    \
    # --- Build toolchain (required by pyenv) ---
    build-essential \
    libffi-dev \
    liblzma-dev \
    libncursesw5-dev \
    libreadline-dev \
    libsqlite3-dev \
    libssl-dev \
    libxml2-dev \
    libxmlsec1-dev \
    llvm \
    make \
    tk-dev \
    xz-utils \
    zlib1g-dev \
    \
    # --- Media tools (creative coding: export canvas to video/image) ---
    ffmpeg \
    imagemagick \
    \
    # --- Fonts (needed by imagemagick + some canvas renderers) ---
    fontconfig \
    fonts-dejavu-core \
    \
    # --- SSH server ---
    openssh-server \
    \
    # --- Misc extras ---
    htop \
    \
    && rm -rf /var/lib/apt/lists/* \
    # sshd needs this directory to exist at startup
    && mkdir -p /run/sshd

# -----------------------------------------------------------------------------
# SSH server configuration
#   - Port 2222 avoids conflicts with the host's own SSH daemon on port 22.
#   - Password auth disabled — key-only, set up by setup.sh at first run.
#   - Only the boffin user is allowed in.
# -----------------------------------------------------------------------------
RUN sed -i 's/#Port 22/Port 2222/'                                      /etc/ssh/sshd_config \
    && sed -i 's/#PasswordAuthentication yes/PasswordAuthentication no/' /etc/ssh/sshd_config \
    && sed -i 's/#PubkeyAuthentication yes/PubkeyAuthentication yes/'    /etc/ssh/sshd_config \
    && echo "PermitRootLogin no"  >> /etc/ssh/sshd_config \
    && echo "AllowUsers boffin"   >> /etc/ssh/sshd_config

# -----------------------------------------------------------------------------
# Switch to boffin — all subsequent steps land in /home/boffin (UID 1000).
# Note: the bind-mount in devcontainer.json overlays /home/boffin at runtime,
# so files written here are fallback defaults only (used when .container_home
# is empty on first start).
# -----------------------------------------------------------------------------
USER boffin
WORKDIR /home/boffin

# -----------------------------------------------------------------------------
# Exposed ports (documentation only — actual forwarding is in devcontainer.json)
#
#   2222  SSH
#   3000  Node / general dev server
#   4321  Astro dev server
#   4322  Spare / secondary
#   5000  Flask / MLflow
#   5173  Vite dev server
#   5174  Spare / secondary
#   6006  Storybook
#   8080  Generic HTTP / static preview (serve)
#   8888  Jupyter
# -----------------------------------------------------------------------------
EXPOSE 2222 3000 4321 4322 5000 5173 5174 6006 8080 8888

RUN service ssh start
CMD ["/bin/zsh"]
