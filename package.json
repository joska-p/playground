{
  "name": "playground",
  "private": true,
  "scripts": {
    "deploy": "pnpm build && mkdir -p ./apps/playground/dist/storybook && cp -r ./apps/storybook/storybook-static/. ./apps/playground/dist/storybook/",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint-fix": "turbo run lint-fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "check-types": "turbo run check-types",
    "gen": "turbo gen",
    "graphify": "graphify update",
    "clean": "node ./scripts/clean.mjs",
    "reset": "node ./scripts/clean.mjs --yes && pnpm install && pnpm format && pnpm lint-fix && pnpm check-types && pnpm build"
  },
  "devDependencies": {
    "@turbo/gen": "^2.9.14",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24"
  }
}
