{
  "name": "@repo/playground",
  "private": true,
  "scripts": {
    "deploy:vercel": "pnpm build && mkdir -p ./apps/playground/dist/storybook && cp -r ./apps/storybook/storybook-static/. ./apps/playground/dist/storybook/",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "preview": "turbo run preview",
    "lint": "turbo run lint",
    "lint-fix": "turbo run lint-fix",
    "format": "turbo run format",
    "check-types": "turbo run check-types",
    "graphify": "graphify update . && cp graphify-out/graph.html apps/playground/public/graphify/graph.html",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
