{
  "name": "playground",
  "private": true,
  "scripts": {
    "sync-package-docs": "node ./scripts/sync-package-readmes.mjs",
    "deploy": "pnpm build && mkdir -p ./apps/playground/dist/storybook && cp -r ./apps/storybook/storybook-static/. ./apps/playground/dist/storybook/",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint-fix": "turbo run lint-fix",
    "format": "prettier --write .",
    "check-types": "turbo run check-types",
    "gen": "turbo gen",
    "graphify": "graphify update",
    "clean": "turbo clean && turbo run clean && rm -rf node_modules /**/node_modules",
    "reset": "pnpm clean && pnpm i && pnpm format && pnpm lint-fix && pnpm check-types && pnpm build",
    "fallow": "fallow"
  },
  "devDependencies": {
    "@turbo/codemod": "^2.10.1",
    "fallow": "^2.91.0",
    "prettier": "catalog:",
    "prettier-plugin-astro": "catalog:",
    "prettier-plugin-organize-imports": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "^2.10.1",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.9.0"
}
