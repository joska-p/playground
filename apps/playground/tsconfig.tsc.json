{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "incremental": true,
    "tsBuildInfoFile": "./.turbo/tsconfig.tsc.tsbuildinfo"
  },
  "references": [
    { "path": "../ui" },
    { "path": "../art-canvas" },
    { "path": "../automa" },
    { "path": "../graph-viz" },
    { "path": "../image-to-particles" },
    { "path": "../l-system" },
    { "path": "../mosaic-maker" },
    { "path": "../palette-generator" },
    { "path": "../pixel" },
    { "path": "../pixel-manipulator" },
    { "path": "../randomart" },
    { "path": "../radu-machine-learning" },
    { "path": "../real-life" },
    { "path": "../sequence-renderer" },
    { "path": "../three-stage" }
  ]
}
