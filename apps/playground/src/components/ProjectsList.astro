---
import { getCollection } from 'astro:content';
import { AtlasCard } from '@repo/ui/cards';

const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}discoveries/`;
const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => a.data.title.localeCompare(b.data.title));

function stringToSeed(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    const char = str.charCodeAt(i);
    hash = (hash << 5) - hash + char;
    hash = hash & hash;
  }
  return Math.abs(hash);
}
---

<div class="grid grid-cols-[repeat(auto-fill,minmax(340px,1fr))] gap-4">
  {
    sortedProjects.map((project) => {
      const mainTag = project.data.tags[0].id;
      return (
        <a
          href={`${projectsBaseUrl}${project.id}/#main`}
          title={project.data.title}
        >
          <AtlasCard
            seed={stringToSeed(project.data.title)}
            cardId={project.data.tags[0].id}
            cardTitle={project.data.title}
            classification={project.data.description}
            density={String(stringToSeed(project.data.description))}
            resolution={String(stringToSeed(project.data.title))}
            color={`var(--tags-${mainTag})`}
          />
        </a>
      );
    })
  }
</div>
