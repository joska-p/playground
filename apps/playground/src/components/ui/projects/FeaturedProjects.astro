---
import { getCollection } from 'astro:content';
import SectionHeader from '../features/SectionHeader.astro';
import ExperimentCard from '../cards/ExperimentCard.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}projects/`;
const allProjects = await getCollection('projects');
const featuredProjects = allProjects.filter(
  (p) => p.data.featured
);
---

<SectionHeader
  iconName="sparkles"
  title="Engines & Labs"
  description="Volatile experiments in high-interactivity canvas rendering."
  href="https://jpotin.gitlab.io/playground/"
  className="mb-12"
>
  <span slot="link-text">View on GitLab</span>
</SectionHeader>

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {
    featuredProjects.map((project) => (
      <ExperimentCard
        href={`${projectsBaseUrl}${project.data.category.id}/${project.id}/`}
        title={project.data.name}
        description={project.data.description}
        iconName={project.data.icon}
        category={project.data.category.id}
        tags={project.data.tags.map((t) => t.id)}
      />
    ))
  }
</div>
