---
import SectionHeader from '../features/SectionHeader.astro';
import ExperimentCard from '../cards/ExperimentCard.astro';
import { getFeaturedProjects } from '../../../data/projects';

const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}projects/`;
const featuredProjects = getFeaturedProjects();
---

<SectionHeader
  iconName="sparkles"
  title="Engines & Labs"
  description="Volatile experiments in high-interactivity canvas rendering."
  href="https://jpotin.gitlab.io/playground/"
  className="mb-12"
>
  <span slot="link-text">View on GitLab</span>
</SectionHeader>

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {
    featuredProjects.map((project) => (
      <ExperimentCard
        href={`${projectsBaseUrl}${project.category}/${project.slug}/`}
        title={project.name}
        description={project.description}
        iconName={project.icon}
        category={project.category}
        tags={project.tags}
      />
    ))
  }
</div>
