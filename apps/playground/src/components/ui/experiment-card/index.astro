---
import { Card, CardHeader, CardTitle, CardContent, Badge } from "@repo/ui";
import type { ComponentType } from "react";
import type { Category } from "../../../data/projects";

interface Props {
  href: string;
  title: string;
  description: string;
  icon: ComponentType<{ className?: string }>;
  category?: Category;
  tags?: string[];
}

const {
  href,
  title,
  description,
  icon: Icon,
  category = "generative",
  tags = []
} = Astro.props;
---

<a href={href} class="group outline-none" style={`--category-variant: var(--category-${category})`}>
  <Card variant="primary" className="h-full border-2 border-transparent bg-card/50 transition-all duration-300 hover:-translate-y-2 hover:border-(--category-variant) hover:shadow-2xl hover:shadow-primary/10 group-focus:ring-2 group-focus:ring-(--category-variant)">
    <CardHeader>
      <div class={`mb-4 flex h-14 w-14 items-center justify-center rounded-2xl transition-transform group-hover:scale-110 group-hover:rotate-3 bg-(--category-variant)/20`}>
        <Icon className="h-8 w-8 text-(--category-variant)" />
      </div>
      <CardTitle className="text-2xl">{title}</CardTitle>
    </CardHeader>
    <CardContent>
      <p class="text-sm leading-relaxed text-muted-foreground">
        {description}
      </p>
      {tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <Badge variant="secondary">
              {tag}
            </Badge>
          ))}
        </div>
      )}
    </CardContent>
  </Card>
</a>