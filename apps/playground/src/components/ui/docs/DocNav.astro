---
import { getCollection } from 'astro:content';
import NavCategory from './NavCategory.astro';
import type { IconName } from '@repo/ui/icons';

const currentPath = Astro.url.pathname;

const allTags = await getCollection('tags');
const allDocs = await getCollection('docs', ({ data }) => !data.draft);

interface NavGroup {
  id: string;
  label: string;
  description: string;
  iconName: IconName;
  articles: typeof allDocs;
}

const groups: NavGroup[] = allTags
  .filter((tag) =>
    ['tutorial', 'how-to', 'explanation', 'reference', 'conventions'].includes(tag.id)
  )
  .map((tag) => {
    const articles = allDocs
      .filter((doc) => doc.data.tags[0] === tag.id)
      .sort((a, b) => a.data.order - b.data.order);
    return {
      id: tag.id,
      label: tag.data.title,
      description: tag.data.description,
      iconName: tag.data.icon ?? 'bluesky',
      articles
    };
  })
  .filter((g) => g.articles.length > 0);
---

<aside class="sticky top-24 hidden h-full w-60 shrink-0 flex-col overflow-y-auto md:flex">
  <div class="flex h-12 items-center gap-2.5 px-5">
    <span class="bg-primary h-1.5 w-1.5 rounded-full"></span>
    <span class="text-muted-foreground text-[10px] font-semibold uppercase"> ~/docs </span>
  </div>

  <nav
    class="min-h-full flex-1 overflow-y-auto p-3"
    aria-label="Documentation navigation"
  >
    <div class="space-y-5 py-1">
      {
        groups.map((tag) => (
          <NavCategory
            category={tag}
            currentPath={currentPath}
          />
        ))
      }
    </div>
  </nav>
</aside>
