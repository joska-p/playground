---
type TypographyToken = {
  name: string;
  stack: string;
  example: string;
};

type Props = {
  tokens: TypographyToken[];
};

const { tokens } = Astro.props;
---

<div class="not-prose bg-card my-6 overflow-hidden rounded-xl border shadow-sm">
  <div class="overflow-x-auto">
    <table class="w-full border-collapse text-left text-sm">
      <thead>
        <tr class="border-border bg-muted/30 border-b">
          <th class="text-foreground px-4 py-3 font-semibold">Token</th>
          <th class="text-foreground px-4 py-3 font-semibold">Preview</th>
          <th class="text-foreground px-4 py-3 font-semibold">Font Stack</th>
        </tr>
      </thead>
      <tbody class="divide-border divide-y">
        {
          tokens.map((token) => (
            <tr class="hover:bg-muted/10 transition-colors">
              <td class="px-4 py-4 align-top">
                <code class="bg-muted text-primary rounded px-2 py-0.5 font-mono text-xs font-medium">
                  {token.name}
                </code>
              </td>
              <td class="px-4 py-4 align-top">
                <div
                  class="text-foreground text-lg leading-tight"
                  style={{ fontFamily: `var(${token.name})` }}
                >
                  {token.example}
                </div>
              </td>
              <td class="text-muted-foreground max-w-xs px-4 py-4 align-top font-mono text-xs break-all">
                {token.stack}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>
