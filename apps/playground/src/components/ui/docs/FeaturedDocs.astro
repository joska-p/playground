---
import DocCard from "../cards/DocCard.astro";
import SectionHeader from "../features/SectionHeader.astro";
import { IconArrowRight } from "@repo/ui/icons/ArrowRight";
import { getFeaturedDocs, docsBaseUrl } from "../../../data/docs";

const featuredDocs = await getFeaturedDocs();
---

<SectionHeader
  icon="book"
  title="Documentation"
  description="Manifesto, guides, and references for collaborators."
  align="center"
  className="mb-12"
/>

<div class="grid gap-4 sm:grid-cols-2">
  {
    featuredDocs.map((doc) => {
      const docUrl = `${docsBaseUrl}${doc.id}/`;
      const categoryId = doc.data.category || "explanation";
      return (
        <DocCard
          href={docUrl}
          type={categoryId}
          title={doc.data.title}
          description={doc.data.description}
        />
      );
    })
  }
</div>

<div class="mt-10 text-center">
  <a
    href={docsBaseUrl}
    class="group text-primary/60 hover:text-primary inline-flex items-center gap-2 text-xs font-bold tracking-widest uppercase transition-colors"
  >
    Browse all docs
    <IconArrowRight className="transition-transform group-hover:translate-x-0.5" size={11} />
  </a>
</div>
