---
import { getCollection, getEntry } from 'astro:content';
import DocCard from '../cards/DocCard.astro';
import SectionHeader from '../features/SectionHeader.astro';
import { Icon } from '@repo/ui/Icon';

const baseUrl = import.meta.env.BASE_URL || '/';
const docsBaseUrl = `${baseUrl}docs/`;

const featuredDocs = await getCollection('docs', ({ data }) => data.featured && !data.draft);
const featuredDocsWithMeta = await Promise.all(
  featuredDocs.map(async (doc) => {
    const categoryEntry = await getEntry(doc.data.category);
    return {
      ...doc,
      categoryId: doc.data.category.id,
      iconName: categoryEntry.data.icon
    };
  })
);
---

<SectionHeader
  iconName="book"
  title="Documentation"
  description="Manifesto, guides, and references for collaborators."
  align="center"
  className="mb-12"
/>

<div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-4">
  {
    featuredDocsWithMeta.map((doc) => {
      const docUrl = `${docsBaseUrl}${doc.id}/`;
      return (
        <DocCard
          href={docUrl}
          type={doc.categoryId}
          iconName={doc.iconName}
          title={doc.data.title}
          description={doc.data.description}
        />
      );
    })
  }
</div>

<div class="mt-10 text-center">
  <a
    href={docsBaseUrl}
    class="group text-primary/60 hover:text-primary inline-flex items-center gap-2 text-xs font-bold uppercase transition-colors"
  >
    Browse all docs
    <Icon
      name="arrow-right"
      className="h-4 w-4 transition-transform group-hover:translate-x-0.5"
    />
  </a>
</div>
