---
type Token = {
  name: string;
  usage: string;
}

type Props = {
  tokens: Token[];
}

const { tokens } = Astro.props;
---

<div class="not-prose my-6 overflow-hidden rounded-xl border bg-card shadow-sm">
  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm border-collapse">
      <thead>
        <tr class="border-b border-border bg-muted/30">
          <th class="px-4 py-3 font-semibold text-foreground w-24">Preview</th>
          <th class="px-4 py-3 font-semibold text-foreground">Token</th>
          <th class="px-4 py-3 font-semibold text-foreground">Usage</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        {tokens.map((token) => (
          <tr class="hover:bg-muted/10 transition-colors">
            <td class="px-4 py-4">
              <div
                class="h-10 w-20 rounded-md border border-border/50 shadow-sm"
                style={{ backgroundColor: `var(${token.name})` }}
                title={`Preview of var(${token.name})`}
              />
            </td>
            <td class="px-4 py-4 align-middle">
              <div class="flex flex-col gap-1">
                <code class="w-fit rounded bg-muted px-2 py-0.5 font-mono text-xs font-medium text-primary">
                  {token.name}
                </code>
              </div>
            </td>
            <td class="px-4 py-4 align-middle text-muted-foreground leading-relaxed">
              {token.usage}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
