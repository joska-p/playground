---
type Token = {
  name: string;
  usage: string;
};

type Props = {
  tokens: Token[];
};

const { tokens } = Astro.props;
---

<div class="not-prose bg-card my-6 overflow-hidden rounded-xl border shadow-sm">
  <div class="overflow-x-auto">
    <table class="w-full border-collapse text-left text-sm">
      <thead>
        <tr class="border-border bg-muted/30 border-b">
          <th class="text-foreground w-24 px-4 py-3 font-semibold">Preview</th>
          <th class="text-foreground px-4 py-3 font-semibold">Token</th>
          <th class="text-foreground px-4 py-3 font-semibold">Usage</th>
        </tr>
      </thead>
      <tbody class="divide-border divide-y">
        {
          tokens.map((token) => (
            <tr class="hover:bg-muted/10 transition-colors">
              <td class="px-4 py-4">
                <div
                  class="border-border/50 h-10 w-20 rounded-md border shadow-sm"
                  style={{ backgroundColor: `var(${token.name})` }}
                  title={`Preview of var(${token.name})`}
                />
              </td>
              <td class="px-4 py-4 align-middle">
                <div class="flex flex-col gap-1">
                  <code class="bg-muted text-primary w-fit rounded px-2 py-0.5 text-xs font-medium">
                    {token.name}
                  </code>
                </div>
              </td>
              <td class="text-muted-foreground px-4 py-4 align-middle">{token.usage}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>
