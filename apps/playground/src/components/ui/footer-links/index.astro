---
import { Badge } from "@repo/ui";

type Route = {
  label: string;
  href: string;
  isUtility?: boolean;
  icon?: string;
}

const baseUrl = import.meta.env.BASE_URL || "/";

// Utility links (like GitHub) and Docs
const routes: Route[] = [
  { label: "GitHub", href: "https://github.com/joska-p/playground", isUtility: true, icon: "github" },
  { label: "GitLab", href: "https://gitlab.com/jpotin/playground", isUtility: true, icon: "gitlab" },
  { label: "Storybook", href: `${baseUrl}storybook/`, isUtility: true, icon: "storybook" },
  { label: "Docs", href: `${baseUrl}docs/`, icon: "docs" },
];

// Utility links (like GitHub) and Docs from routes
const utilityLinks = routes.filter((r) => r.isUtility || r.label === "Docs");

type Props = {
  class?: string;
}

const { class: className } = Astro.props;

// Tools and technologies used - cycling through variants for visual interest
const credits = [
  { name: "Astro",  variant: "primary" },
  { name: "React",  variant: "secondary" },
  { name: "Tailwind", variant: "accent" },
  { name: "Turborepo", variant: "primary" },
  { name: "Storybook", variant: "secondary" },
  { name: "TypeScript", variant: "accent" },
  { name: "Nix", variant: "secondary" },
  { name: "pnpm", variant: "primary" },
];
---

<footer class:list={["border-t border-border/40 pt-16 text-center", className]}>
  <div class="mb-8 flex justify-center gap-8">
    {utilityLinks.map((link) => (
      <a
        href={link.href}
        class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors"
        target={link.href.startsWith("http") ? "_blank" : undefined}
        rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
      >
        <span class="sr-only">{link.label}</span>
        {link.icon === "github" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
        )}
        {link.icon === "gitlab" && (
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 380 380" fill="currentColor" stroke="none"  class="h-4 w-4"><path d="M282.83,170.73l-.27-.69-26.14-68.22a6.81,6.81,0,0,0-2.69-3.24,7,7,0,0,0-8,.43,7,7,0,0,0-2.32,3.52l-17.65,54H154.29l-17.65-54A6.86,6.86,0,0,0,134.32,99a7,7,0,0,0-8-.43,6.87,6.87,0,0,0-2.69,3.24L97.44,170l-.26.69a48.54,48.54,0,0,0,16.1,56.1l.09.07.24.17,39.82,29.82,19.7,14.91,12,9.06a8.07,8.07,0,0,0,9.76,0l12-9.06,19.7-14.91,40.06-30,.1-.08A48.56,48.56,0,0,0,282.83,170.73Z"/></svg>

        )}
        {link.icon === "storybook" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        )}
        {link.label === "Docs" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
        )}
        {!link.icon && link.label !== "Docs" && link.label !== "GitHub" && link.label !== "Storybook" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        )}
        <span>{link.label}</span>
      </a>
    ))}
  </div>
  <div class="mb-4 flex flex-wrap justify-center gap-2">
    <span class="text-muted-foreground text-sm py-1">Powered by</span>
    {credits.map((credit) => (
      <Badge variant={credit.variant as "primary" | "secondary" | "accent" | "outline"} className="gap-1">
        {credit.name}
      </Badge>
    ))}
  </div>
  <p class="text-sm text-muted-foreground italic">
    <slot>Made with creativity.</slot>
  </p>
</footer>
