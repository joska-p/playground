---
type Route = { label: string; href: string; icon?: string };

const baseUrl = import.meta.env.BASE_URL || "/";
const routes: Route[] = [
  { label: "GitLab", href: "https://gitlab.com/jpotin/playground", icon: "gitlab" },
  { label: "Storybook", href: `${baseUrl}storybook/`, icon: "storybook" },
  { label: "Docs", href: `${baseUrl}docs/`, icon: "docs" },
];

const credits = [
  "Astro",
  "React",
  "Tailwind",
  "Turborepo",
  "Storybook",
  "TypeScript",
  "Nix",
  "pnpm",
];
type Props = { class?: string };
const { class: className } = Astro.props;
---

<footer
  class:list={[
    "bg-background/50 not-prose relative w-full pt-12 pb-8 backdrop-blur-sm transition-colors",
    className,
  ]}
>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="flex flex-col items-center gap-8 md:flex-row md:items-start md:justify-between">
      <div class="flex flex-col items-center gap-4 md:items-start">
        <a
          href={baseUrl}
          class="group text-muted-foreground hover:text-primary flex items-center gap-2 font-mono text-xs font-bold tracking-[0.25em] transition-all duration-300"
        >
          <span class="relative flex h-2.5 w-2.5" aria-hidden="true">
            <span
              class="bg-primary group-hover:bg-accent absolute inset-0 animate-[pg-ping_2s_cubic-bezier(0,0,0.2,1)_infinite] rounded-full opacity-60 group-hover:animate-ping"
            ></span>
            <span
              class="bg-primary group-hover:bg-accent relative h-2.5 w-2.5 rounded-full transition-colors group-hover:scale-110"
            ></span>
          </span>
          PG_LAB
        </a>
        <p class="text-muted-foreground/50 font-mono text-[10px] tracking-wide">
          <slot>Made with creativity.</slot>
        </p>
      </div>

      <nav
        class="flex flex-wrap justify-center gap-x-6 gap-y-4 md:justify-end"
        aria-label="Footer navigation"
      >
        {
          routes.map((link) => (
            <a
              href={link.href}
              class="group text-muted-foreground/70 hover:text-primary flex items-center gap-2 font-mono text-[10px] font-medium tracking-widest uppercase transition-all duration-300 hover:-translate-y-0.5"
              target={link.href.startsWith("http") ? "_blank" : undefined}
              rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
            >
              {link.icon === "github" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="transition-transform group-hover:scale-110 group-hover:-rotate-12"
                  aria-hidden="true"
                >
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
              )}
              {link.icon === "gitlab" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:scale-110 group-hover:rotate-12"
                  aria-hidden="true"
                >
                  <path d="m22 13.29-3.33-10a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18l-2.26 6.67H8.32L6.06 3.27a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18L2 13.29a.74.74 0 0 0 .27.83L12 21l9.73-6.88a.74.74 0 0 0 .27-.83Z" />
                </svg>
              )}
              {link.icon === "storybook" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:scale-110 group-hover:rotate-12"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="10" />
                  <path d="M12 16v-4" />
                  <path d="M12 8h.01" />
                </svg>
              )}
              {link.icon === "docs" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:scale-110 group-hover:-rotate-12"
                  aria-hidden="true"
                >
                  <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
                </svg>
              )}
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="via-border/50 my-8 h-px w-full bg-linear-to-r from-transparent to-transparent">
    </div>

    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex flex-wrap items-center justify-center gap-2 md:justify-start">
        <span class="text-muted-foreground/40 mr-2 font-mono text-[10px] tracking-widest uppercase"
          >Built with</span
        >
        {
          credits.map((name) => (
            <span class="border-border/40 bg-muted/20 text-muted-foreground/60 hover:border-primary/40 hover:bg-primary/10 hover:text-primary cursor-default rounded-full border px-3 py-1 font-mono text-[9px] font-semibold tracking-widest uppercase transition-all duration-300 hover:-translate-y-0.5 hover:shadow-sm">
              {name}
            </span>
          ))
        }
      </div>

      <div class="text-muted-foreground/40 font-mono text-[10px] tracking-widest">
        © {new Date().getFullYear()} PG_LAB
      </div>
    </div>
  </div>
</footer>
