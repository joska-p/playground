---
import { Icon, type IconName } from '@repo/ui/icons';
import type { Category } from '../../../data/projects';
import BaseCard from './BaseCard.astro';

type Props = {
  href: string;
  title: string;
  description?: string;
  iconName: IconName;
  category?: Category;
  tags?: string[];
  className?: string;
};

const {
  href,
  title,
  description,
  iconName,
  category = 'generative',
  tags = [],
  className,
} = Astro.props;

const accentColor = `var(--category-${category}, var(--color-primary))`;
---

<BaseCard
  href={href}
  accentColor={accentColor}
  variant="experiment"
  className={className}
>
  <!-- Hover gradient line -->
  <div
    class="h-1 w-full opacity-0 transition-opacity duration-300 [background:linear-gradient(90deg,transparent,var(--card-accent)_30%,var(--card-accent)_70%,transparent)] group-hover:opacity-100"
    aria-hidden="true"
  >
  </div>

  <!-- Full-width icon illustration strip -->
  <div
    class="flex items-center justify-center px-4 pt-4 pb-2 text-(--card-accent)"
    aria-hidden="true"
  >
    <div class="w-full max-w-16">
      <Icon name={iconName} />
    </div>
  </div>

  <!-- Accent divider -->
  <div
    class="bg-muted mx-4 h-px transition-colors duration-300 group-hover:bg-(--card-accent)"
  >
  </div>

  <div class="flex flex-col gap-3 p-4 pt-3">
    <h3 class="text-card-foreground font-semibold">
      {title}
    </h3>

    <p class="text-muted-foreground line-clamp-2 text-sm">
      {description}
    </p>

    <slot />
  </div>

  <div class="flex flex-wrap gap-1.5 px-4 py-2.5">
    {
      tags.map((tag) => (
        <span class="text-muted-foreground/60 rounded px-1.5 py-0.5 text-xs">
          {tag}
        </span>
      ))
    }
  </div>
</BaseCard>
