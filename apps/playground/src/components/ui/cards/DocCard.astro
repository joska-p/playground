---
import { Icon, type IconName } from '@repo/ui/icons';
import BaseCard from './BaseCard.astro';

type Props = {
  href: string;
  title: string;
  description?: string;
  type?: string;
  iconName?: IconName;
  className?: string;
};

const { href, title, description, type = 'reference', iconName, className } = Astro.props;

const accentColor = `var(--category-${type}, var(--color-primary))`;
---

<BaseCard
  href={href}
  accentColor={accentColor}
  variant="doc"
  className={className ?? ''}
>
  <span
    class="pointer-events-none absolute top-0 right-0 h-0 w-0 [border-width:0_28px_28px_0] border-solid border-[transparent_var(--card-accent)_transparent_transparent] opacity-50 transition-opacity duration-200 group-hover:opacity-100"
    aria-hidden="true"
  ></span>

  <div class="flex flex-1 flex-col gap-4 p-4">
    <div
      class="flex w-fit items-center gap-2 rounded-md bg-[color-mix(in_srgb,var(--card-accent)_12%,transparent)] px-2 py-1 text-xs font-semibold text-(--card-accent) uppercase [border:1px_solid_color-mix(in_srgb,var(--card-accent)_25%,transparent)]"
    >
      {
        iconName && (
          <Icon
            name={iconName}
            className="h-4 w-4"
          />
        )
      }
      <span>{type}</span>
    </div>

    <h3 class="text-card-foreground font-semibold">
      {title}
    </h3>
    {description && <p class="text-muted-foreground line-clamp-2 flex-1 text-sm">{description}</p>}
    <slot />
  </div>
</BaseCard>
