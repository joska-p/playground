---
import { getCollection } from 'astro:content';
import CategoryCard from '../cards/CategoryCard.astro';

const allCategories = await getCollection('categories');
const allProjects = await getCollection('projects');

const groups = allCategories
  .map((cat) => ({
    id: cat.id,
    label: cat.data.name,
    description: cat.data.description,
    icon: cat.data.icon,
    count: allProjects.filter((p) => p.data.category.id === cat.id).length
  }))
  .filter((g) => g.count > 0);
---

<section
  class="border-border border-b px-5 py-10 sm:px-6 lg:py-14"
  aria-label="Experiment categories"
>
  <div class="mx-auto max-w-6xl space-y-6">
    <header class="flex items-center gap-3">
      <span class="text-muted-foreground text-sm tracking-widest uppercase">
        experiments
      </span>
      <div
        class="bg-border h-px flex-1"
        aria-hidden="true"
      >
      </div>
      <span class="text-muted-foreground/60 text-sm">
        {groups.length}&nbsp;categories
      </span>
    </header>

    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
      {
        groups.map((group) => (
          <CategoryCard
            id={group.id}
            label={group.label}
            description={group.description}
            iconName={group.icon}
            count={group.count}
          />
        ))
      }
    </div>
  </div>
</section>
