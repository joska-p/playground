---
import { getCollection } from 'astro:content';
import { CategoryCard } from '@repo/ui/cards';
import type { CSSProperties } from 'react';
import type { IconName } from '@repo/ui/icons';

const baseUrl = import.meta.env.BASE_URL || '/';

const allTags = await getCollection('tags');
const allProjects = await getCollection('projects');

type Group = {
  id: string;
  label: string;
  description: string;
  icon: IconName;
  count: number;
};

const groups: Group[] = allTags
  .filter((tag) => tag.data.icon !== undefined)
  .map((tag) => ({
    id: tag.data.slug,
    label: tag.data.name,
    description: tag.data.description,
    icon: tag.data.icon!,
    count: allProjects.filter((p) => p.data.tags[0] === tag.data.slug).length
  }))
  .filter((g) => g.count > 0);
---

<section
  class="px-5 py-10 sm:px-6 lg:py-14"
  aria-label="Experiment categories"
>
  <div class="mx-auto max-w-6xl space-y-6">
    <header class="flex items-center gap-3">
      <span class="text-muted-foreground text-sm tracking-widest uppercase">experiments</span>
      <span class="text-muted-foreground/60 ml-auto text-sm">
        {groups.length}&nbsp;categories
      </span>
    </header>

    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
      {
        groups.map((group) => {
          const { id, label, description, icon, count } = group;
          const link = `${baseUrl}projects/${id}/`;
          const cardStyle = {
            '--_color': `var(--color-projects-${id})`
          } as CSSProperties;
          return (
            <CategoryCard
              href={link}
              id={id}
              label={label}
              description={description}
              iconName={icon}
              count={count}
              style={cardStyle}
            />
          );
        })
      }
    </div>
  </div>
</section>
