<div class="border-border bg-card/40 border-b">
  <dl class="mx-auto grid max-w-6xl grid-cols-[repeat(auto-fill,minmax(140px,1fr))] gap-px bg-border">
    {
      [
        { value: "24+", label: "Experiments" },
        { value: "4", label: "Categories" },
        { value: "60fps", label: "Target Perf" },
        { value: "0", label: "Runtime Deps" },
      ].map(({ value, label }) => (
        <div class="bg-card flex flex-col px-6 py-5">
          <dt class="text-muted-foreground text-xs font-bold tracking-widest uppercase">
            {label}
          </dt>
          <dd class="mt-1.5 text-2xl font-black">{value}</dd>
        </div>
      ))
    }
  </dl>
</div>
