---
import type { LucideIcon } from "lucide-react";

type Props = {
  icon?: LucideIcon;
  title: string;
  description?: string;
  href?: string;
  align?: "left" | "center";
};

const { icon: Icon, title, description, href, align = "left" } = Astro.props;
const isCenter = align === "center";
---

<div class:list={["flex flex-col gap-2", isCenter ? "items-center text-center" : "items-start"]}>
  <!-- Title row -->
  <div class:list={["flex items-center gap-3", isCenter && "justify-center"]}>
    {
      Icon && (
        <span class="border-primary/30 bg-primary/10 text-primary flex h-7 w-7 shrink-0 items-center justify-center rounded-md border">
          <Icon className="h-3.5 w-3.5" />
        </span>
      )
    }
    <h2 class="text-primary m-0 text-xs font-bold tracking-[0.2em] uppercase">
      {title}
    </h2>
    <span class="bg-border h-px flex-1"></span>
  </div>

  {
    description && (
      <p
        class:list={[
          "text-muted-foreground max-w-xl text-sm leading-relaxed",
          isCenter && "text-center",
          Icon ? "ml-10" : "",
        ]}
      >
        {description}
      </p>
    )
  }

  {
    href && (
      <a
        href={href}
        class:list={[
          "group text-primary/60 hover:text-primary mt-1 inline-flex items-center gap-1.5 text-[10px] font-bold tracking-widest uppercase transition-colors",
          Icon ? "ml-10" : "",
        ]}
      >
        <slot name="link-text">View all</slot>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="11"
          height="11"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform group-hover:translate-x-0.5"
          aria-hidden="true"
        >
          <>
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </>
        </svg>
      </a>
    )
  }
</div>
