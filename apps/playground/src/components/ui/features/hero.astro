---
// src/components/ui/Hero.astro
interface Props {
  badgeText?: string;
  title?: string;
  highlight?: string;
  description?: string;
}

const {
  badgeText = "Stateless first · Astro + React 19",
  title = "Creative",
  highlight = "Playground",
  description = "A high-performance lab for interactive visualizations, math sequences, and color tools. Built to experiment without limits.",
} = Astro.props;
---

<section
  class="hero border-border relative flex flex-col justify-end overflow-hidden border-b px-6 py-24 lg:py-32"
>
  <div class="dot-grid absolute inset-0 z-0" aria-hidden="true"></div>
  <div
    class="bg-primary absolute bottom-0 -left-32 z-0 h-112 w-md rounded-full opacity-[0.07] blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto w-full max-w-6xl">
    <div
      class="border-primary/20 bg-primary/6 text-primary mb-8 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-[10px] font-semibold tracking-[0.2em] uppercase"
    >
      <span class="live-dot relative flex h-1.5 w-1.5">
        <span class="ping bg-primary absolute inline-flex h-full w-full rounded-full opacity-60"
        ></span>
        <span class="bg-primary relative inline-flex h-1.5 w-1.5 rounded-full"></span>
      </span>
      {badgeText}
    </div>

    <h1
      class="text-foreground text-[clamp(3rem,8vw,6rem)] leading-[0.93] font-black tracking-tight"
    >
      {title}<br />
      <span class="text-primary">{highlight}<span class="cursor">_</span></span>
    </h1>

    <p class="text-muted-foreground mt-7 max-w-lg text-base leading-relaxed">
      {description}
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-4">
      <slot name="cta" />
    </div>
  </div>
</section>

<style>
  .dot-grid {
    background-image: radial-gradient(circle, var(--border) 1px, transparent 1px);
    background-size: 28px 28px;
    opacity: 0.5;
  }

  .cursor {
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
