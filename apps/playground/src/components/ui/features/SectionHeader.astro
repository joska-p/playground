---
import { iconMap } from "@repo/ui/iconMap";
import { IconArrowRight } from "@repo/ui/icons/ArrowRight";
import type { IconName } from "@repo/ui/iconMap";

type Props = {
  icon?: IconName;
  title: string;
  description?: string;
  href?: string;
  align?: "left" | "center";
  className?: string;
};

const { icon, title, description, href, align = "left", className = "mb-8" } = Astro.props;
const Icon = icon ? iconMap[icon] : undefined;
const isCenter = align === "center";
---

<div
  class:list={["flex flex-col gap-2", isCenter ? "items-center text-center" : "items-start", className]}
>
  <div class:list={["flex items-center gap-3", isCenter && "justify-center"]}>
    {
      Icon && (
        <span class="border-primary/30 bg-primary/10 text-primary flex h-7 w-7 shrink-0 items-center justify-center rounded-md border">
          <Icon className="h-3.5 w-3.5" />
        </span>
      )
    }
    <h2 class="text-primary m-0 text-xs font-bold tracking-widest uppercase">
      {title}
    </h2>
    <span class="bg-border h-px flex-1"></span>
  </div>

  {
    description && (
      <p
        class:list={[
          "text-muted-foreground max-w-xl text-sm leading-relaxed",
          isCenter && "text-center",
          Icon ? "ml-10" : "",
        ]}
      >
        {description}
      </p>
    )
  }

  {
    href && (
      <a
        href={href}
        class:list={[
          "group text-primary/60 hover:text-primary mt-1 inline-flex items-center gap-1.5 text-xs font-bold tracking-widest uppercase transition-colors",
          Icon ? "ml-10" : "",
        ]}
      >
        <slot name="link-text">View all</slot>
        <IconArrowRight
          className="transition-transform group-hover:translate-x-0.5"
          size={11}
        />
      </a>
    )
  }
</div>
