---
import { Icon, type IconName } from '@repo/ui/icons';

type Props = {
  iconName?: IconName;
  title: string;
  description?: string;
  href?: string;
  align?: 'left' | 'center';
  className?: string;
  category?: string;
};

const {
  iconName,
  title,
  description,
  href,
  align = 'left',
  className = 'mb-8',
  category
} = Astro.props;
const isCenter = align === 'center';
const accentColor = `var(--category-${category}, var(--color-primary))`;
---

<div
  class:list={[
    'flex flex-col gap-2',
    isCenter ? 'items-center text-center' : 'items-start',
    className
  ]}
  style={{ '--accent': accentColor }}
>
  <div class:list={['flex items-center gap-3', isCenter && 'justify-center']}>
    {
      iconName && (
        <span class="text-accent flex shrink-0 items-center justify-center">
          <Icon
            name={iconName}
            className=" w-7 h-7"
          />
        </span>
      )
    }
    <h2 class="text-accent m-0 text-xs font-bold uppercase">
      {title}
    </h2>
    <span class="bg-border h-px flex-1"></span>
  </div>

  {
    description && (
      <p
        class:list={[
          'text-muted-foreground max-w-xl text-sm',
          isCenter && 'text-center',
          iconName ? 'ml-10' : ''
        ]}
      >
        {description}
      </p>
    )
  }

  {
    href && (
      <a
        href={href}
        class:list={[
          'group text-accent/60 hover:text-accent mt-1 inline-flex items-center gap-1.5 text-xs font-bold uppercase transition-colors',
          iconName ? 'ml-10' : ''
        ]}
      >
        <slot name="link-text">View all</slot>
        <Icon
          name="arrow-right"
          className="transition-transform w-4 h-4 group-hover:translate-x-0.5"
        />
      </a>
    )
  }
</div>
