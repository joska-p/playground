---
import { renderPixelMapAsBase64 } from '@repo/randomart/renderPixelMapAsBase64';

type Props = {
  badgeText?: string;
  title?: string;
  highlight?: string;
  description?: string;
  className?: string; // Added to allow safe layout overrides per-page
};

const {
  badgeText = 'Stateless first · Astro + React 19',
  title = 'Creative',
  highlight = 'Playground',
  description = 'A high-performance lab for interactive visualizations, math sequences, and color tools. Built to experiment without limits.',
  className = ''
} = Astro.props;

const dataUri = renderPixelMapAsBase64(description, 300, 8);
---

<section
  class:list={[
    'border-border relative flex min-h-[65vh] flex-col justify-center overflow-hidden border-b px-6 py-[clamp(5rem,8vw,8rem)]',
    className
  ]}
>
  <!-- Grid bg -->
  <div
    class="absolute inset-0 z-0 bg-[linear-gradient(var(--border)_1px,transparent_1px),linear-gradient(to_right,var(--border)_1px,transparent_1px)] bg-size-[4rem_4rem] opacity-10"
    aria-hidden="true"
  >
  </div>

  <!-- Radial fade mask -->
  <div
    class="absolute inset-0 z-0 bg-[radial-gradient(ellipse_70%_60%_at_50%_50%,transparent_50%,var(--background)_100%)]"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto w-full max-w-6xl">
    {
      badgeText && (
        <div class="border-primary/20 bg-primary/5 text-primary mb-8 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-semibold uppercase backdrop-blur-sm">
          {badgeText}
        </div>
      )
    }
    <div class="flex gap-4">
      <h1
        class="from-primary via-accent to-secondary bg-linear-to-br bg-clip-text text-[clamp(2.75rem,7.5vw,5.5rem)] leading-tight font-black text-transparent"
      >
        {highlight}<br />
        {title}<span class="cursor ml-1 font-light">_</span>
      </h1>
      <figure class="ml-auto hidden md:flex md:flex-col">
        <img
          src={dataUri}
          width="200"
          height="200"
          alt="randomart generated from the description"
          class="filtering-pixelated max-h-min"
        />
        <figcaption class="text-muted-foreground mt-4 text-center text-xs">
          randomart
        </figcaption>
      </figure>
    </div>

    {
      description && (
        <p class="text-muted-foreground mt-6 max-w-xl text-[clamp(1rem,2.5vw,1.125rem)]">
          {description}
        </p>
      )
    }

    {
      Astro.slots.has('cta') && (
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <slot name="cta" />
        </div>
      )
    }
  </div>
</section>
