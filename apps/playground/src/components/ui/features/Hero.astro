---
// src/components/ui/Hero.astro
type Props = {
  badgeText?: string;
  title?: string;
  highlight?: string;
  description?: string;
  className?: string; // Added to allow safe layout overrides per-page
}

const {
  badgeText = "Stateless first · Astro + React 19",
  title = "Creative",
  highlight = "Playground",
  description = "A high-performance lab for interactive visualizations, math sequences, and color tools. Built to experiment without limits.",
  className = "",
} = Astro.props;
---

<section
  class:list={[
    "border-border relative flex min-h-[65vh] flex-col justify-center overflow-hidden border-b px-6 py-[clamp(5rem,8vw,8rem)]",
    className,
  ]}
>
  <div class="dot-grid absolute inset-0 z-0 opacity-50" aria-hidden="true"></div>

  <div
    class="bg-primary absolute -bottom-24 -left-32 z-0 h-96 w-96 rounded-full opacity-10 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div
    class="bg-primary absolute -top-24 -right-32 z-0 h-96 w-96 rounded-full opacity-5 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto w-full max-w-6xl">
    {
      badgeText && (
        <div class="border-primary/20 bg-primary/5 text-primary mb-8 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-semibold tracking-widest uppercase backdrop-blur-sm">
          {badgeText}
        </div>
      )
    }

    <h1
      class="text-[clamp(2.75rem,7.5vw,5.5rem)] font-black tracking-tight leading-none"
    >
      {highlight}<br />
      <span class="from-primary to-primary/70 bg-linear-to-r bg-clip-text text-transparent">
        {title}<span class="text-primary cursor ml-1 font-light">_</span>
      </span>
    </h1>

    {
      description && (
        <p class="text-muted-foreground mt-6 max-w-xl text-[clamp(1rem,2.5vw,1.125rem)] leading-relaxed">
          {description}
        </p>
      )
    }

    {
      Astro.slots.has("cta") && (
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <slot name="cta" />
        </div>
      )
    }
  </div>
</section>

<style>
  /* Fallback template if your global CSS doesn't have a dot-grid background class defined */
  .dot-grid {
    background-image: radial-gradient(
      rgba(var(--primary-rgb, 120, 119, 198), 0.15) 1px,
      transparent 1px
    );
    background-size: 24px 24px;
  }
</style>
