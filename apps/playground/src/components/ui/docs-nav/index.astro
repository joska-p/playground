---
import { getDocs } from "../../utils/docs";
import { baseUrl } from "../../constants/routes";

const docs = await getDocs();

const docsByType = {
  tutorial: [] as typeof docs,
  "how-to": [] as typeof docs,
  explanation: [] as typeof docs,
  reference: [] as typeof docs,
};

for (const doc of docs) {
  docsByType[doc.data.type].push(doc);
}

for (const type of Object.keys(docsByType) as (keyof typeof docsByType)[]) {
  docsByType[type].sort((a, b) => a.data.order - b.data.order);
}

const TYPE_LABELS = {
  tutorial: "Tutorials",
  "how-to": "How-To Guides",
  explanation: "Explanation",
  reference: "Reference",
};

const currentPath = Astro.url.pathname;
const docsBaseUrl = `${baseUrl}/docs`.replace(/\/+/g, "/");
---

<aside class="hidden md:block w-64 shrink-0 overflow-y-auto border-r border-border/40 bg-card/30 p-6">
  <a 
    href={docsBaseUrl} 
    class="mb-6 flex items-center gap-2 text-sm font-semibold text-muted-foreground transition-colors hover:text-foreground"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="m15 18-6-6 6-6"/></svg>
    Documentation Hub
  </a>
  
  <nav class="space-y-8">
    {Object.entries(docsByType).map(([type, items]) => (
      <div>
        <h3 class="mb-3 text-xs font-bold uppercase tracking-widest text-muted-foreground/70">
          {TYPE_LABELS[type]}
        </h3>
        <ul class="space-y-1">
          {items.map((doc) => {
            const href = `${docsBaseUrl}/${doc.id}`;
            const isActive = currentPath === href || currentPath === `${href}/`;
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    "block rounded-md px-3 py-2 text-sm transition-all",
                    isActive 
                      ? "bg-primary/10 font-medium text-primary shadow-sm" 
                      : "text-muted-foreground hover:bg-muted hover:text-foreground"
                  ]}
                >
                  {doc.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>