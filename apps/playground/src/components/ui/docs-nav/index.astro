---
import { getDocsByCategory, docsBaseUrl } from "../../../data/docs";

const currentPath = Astro.url.pathname;
const categories = await getDocsByCategory();
---

<aside class="hidden md:block w-64 shrink-0 overflow-y-auto border-r border-border/40 bg-card/30 p-6">
  <nav class="space-y-8">
    {categories.map((category) => (
      <div>
        <div class="mb-3 flex items-center gap-2">
          <category.Icon className={`h-4 w-4 ${category.color}`} />
          <h3 class="text-xs font-bold uppercase tracking-widest text-muted-foreground/70">
            {category.label}
          </h3>
        </div>
        <ul class="space-y-1">
          {category.articles.map((doc) => {
            const docUrl = `${docsBaseUrl}${doc.id}/`;
            const isActive = currentPath === docUrl;
            return (
              <li>
                <a
                  href={docUrl}
                  class:list={[
                    "block rounded-md px-3 py-2 text-sm transition-all",
                    isActive
                      ? "bg-primary/10 font-medium text-primary shadow-sm"
                      : "text-muted-foreground hover:bg-muted hover:text-foreground"
                  ]}
                >
                  {doc.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>
