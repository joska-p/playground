---
import { docsByTag } from "../../../data/docs";
const currentPath = Astro.url.pathname;
---

<aside class="hidden md:block w-64 shrink-0 overflow-y-auto border-r border-border/40 bg-card/30 p-6">
  <nav class="space-y-8">
    {docsByTag.map((section) => (
      <div>
        <div class="mb-3 flex items-center gap-2">
          <section.Icon className={`h-4 w-4 ${section.color}`} />
          <h3 class="text-xs font-bold uppercase tracking-widest text-muted-foreground/70">
            {section.label}
          </h3>
        </div>
        <ul class="space-y-1">
          {section.docs.map((doc) => {
            const isActive = currentPath === doc.url || currentPath === `${doc.url}/`;
            return (
              <li>
                <a
                  href={doc.url}
                  class:list={[
                    "block rounded-md px-3 py-2 text-sm transition-all",
                    isActive
                      ? "bg-primary/10 font-medium text-primary shadow-sm"
                      : "text-muted-foreground hover:bg-muted hover:text-foreground"
                  ]}
                >
                  {doc.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>
