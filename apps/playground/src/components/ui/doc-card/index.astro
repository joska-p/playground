---
import { ArrowRight } from "lucide-react";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@repo/ui";
import { getTagMetadata } from "../../../data/docs";
import type { TagId } from "../../../data/docs";


interface Props {
  href: string;
  title: string;
  description?: string | undefined;
  type?: TagId;
  className?: string | undefined;
}

const { href, title, description, type = "reference", className } = Astro.props;
const metadata = getTagMetadata(type);
const { Icon, color } = metadata;
---

<a
  href={href}
  class:list={["group inline-block outline-none", className]}
  style={`--category-variant: var(--category-${type})`}
>
  <Card
    variant="primary"
    className="h-full border-2 border-border/40 bg-card transition-all duration-200 hover:-translate-y-1 hover:border-(--category-variant) hover:shadow-lg group-focus-within:ring-2 group-focus-within:ring-primary"
  >
    <CardHeader className="pb-4">
      <div class="flex items-start gap-4">
        <div class:list={[
          "mt-1 mb-0 flex h-9 w-9 items-center justify-center rounded-lg p-2 bg-(--category-variant)/20 transition-transform group-hover:scale-110 group-hover:rotate-3",
          color
        ]}>
          <Icon className="h-5 w-5" />
        </div>
        <div class="flex-1">
          <CardTitle className="flex items-center gap-2 text-lg">
            {title}
            <ArrowRight className="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </CardTitle>
          {description && (
            <CardDescription className="mt-1 not-italic line-clamp-2">
              {description}
            </CardDescription>
          )}
        </div>
      </div>
    </CardHeader>
    <CardContent className="pt-0">
      <slot />
    </CardContent>
  </Card>
</a>
