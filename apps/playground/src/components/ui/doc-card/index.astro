---
import { getTagMetadata } from "../../../data/docs";
import type { TagId } from "../../../data/docs";

type Props = {
  href: string;
  title: string;
  description?: string | undefined;
  type?: TagId;
  className?: string | undefined;
};

const { href, title, description, type = "reference", className } = Astro.props;
const { Icon, color } = getTagMetadata(type);
---

<a
  href={href}
  class:list={[
    "doc-card group relative flex flex-col gap-3 overflow-hidden rounded-lg border border-border bg-card p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary",
    className,
  ]}
  style={{ "--cat": `var(--category-${type}, var(--primary))` }}
>
  <!-- Left accent stripe -->
  <span class="absolute inset-y-0 left-0 w-[3px] rounded-l-lg bg-(--cat) opacity-30 transition-all duration-200 group-hover:opacity-100" />

  <div class="pl-4">
    <!-- Type badge -->
    <div class="flex items-center gap-2 mb-3">
      <span
        class:list={["flex h-5.5 w-5.5 items-center justify-center rounded-sm", color]}
        style="background-color: color-mix(in srgb, var(--cat) 14%, transparent)"
      >
        <Icon className="h-3 w-3" style={{ color: "var(--cat)" }} />
      </span>
      <span class="text-[9px] font-semibold tracking-widest uppercase" style="color: var(--cat)">
        {type.replace("-", "·")}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-sm font-semibold text-card-foreground transition-colors group-hover:text-primary leading-snug">
      {title}
    </h3>

    <!-- Description -->
    {description && (
      <p class="mt-1.5 text-sm text-muted-foreground line-clamp-2 leading-relaxed">
        {description}
      </p>
    )}

    <slot />
  </div>

  <!-- Arrow indicator -->
  <svg
    xmlns="http://www.w3.org/2000/svg" width="11" height="11"
    viewBox="0 0 24 24" fill="none" stroke="currentColor"
    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
    class="absolute right-4 bottom-4 text-primary opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0.5"
    aria-hidden="true"
  >
    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
  </svg>
</a>
