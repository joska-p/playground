---
import type { LucideIcon } from "lucide-react";
import { ArrowRight } from "lucide-react";

interface Props {
  href: string;
  icon?: LucideIcon;
  title: string;
  description?: string;
  type?: "tutorial" | "how-to" | "explanation" | "reference";
  class?: string;
}

const { href, icon: Icon, title, description, type = "reference", class: className } = Astro.props;

---

<a href={href} style={`--category-variant: var(--category-${type})`} class:list={[
  "group inline-block rounded-xl border border-(--category-variant)/50 bg-card p-6 transition-all duration-200 hover:border-(--category-variant)/50 hover:shadow-lg hover:shadow-(--category-variant)/5",
  className
]}>
  <span class="flex items-start gap-4">
    {Icon && (
      <span class="mt-1 rounded-lg bg-(--category-variant)/10 p-2 text-(--category-variant) transition-colors group-hover:bg-(--category-variant) group-hover:text-primary-foreground">
        <Icon className="h-5 w-5" />
      </span>
    )}
    <span class="flex-1">
      <span class="flex items-center gap-2 font-mono text-lg font-semibold">
        {title}
        <ArrowRight className="h-4 w-4 transition-transform group-hover:translate-x-1" />
      </span>
      {description && <p class="mt-1 text-sm text-muted-foreground">{description}</p>}
      <slot />
    </span>
  </span>
</a>
