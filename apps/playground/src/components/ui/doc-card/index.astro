---
import type { LucideIcon } from "lucide-react";
import { ArrowRight } from "lucide-react";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@repo/ui";

interface Props {
  href: string;
  icon?: LucideIcon;
  title: string;
  description?: string;
  type?: "tutorial" | "how-to" | "explanation" | "reference";
  class?: string;
}

const { href, icon: Icon, title, description, type = "reference", class: className } = Astro.props;

---

<a href={href} style={`--category-variant: var(--category-${type})`} class:list={["group inline-block outline-none", className]}>
  <Card variant="primary" className="h-full border-2 border-(--category-variant)/40 bg-card transition-all duration-200 hover:-translate-y-1 hover:border-(--category-variant)/60 hover:shadow-lg hover:shadow-(--category-variant)/5 group-focus-within:ring-2 group-focus-within:ring-(--category-variant)">
    <CardHeader className="pb-4">
      <div class="flex items-start gap-4">
    {Icon && (
          <div class="mt-1 mb-0 flex h-9 w-9 items-center justify-center rounded-lg bg-(--category-variant)/10 p-2 text-(--category-variant) transition-colors group-hover:bg-(--category-variant) group-hover:text-primary-foreground">
        <Icon className="h-5 w-5" />
          </div>
    )}
        <div class="flex-1">
          <CardTitle className="flex items-center gap-2 text-lg">
            {title}
            <ArrowRight className="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </CardTitle>
          {description && <CardDescription className="mt-1 not-italic">{description}</CardDescription>}
        </div>
      </div>
    </CardHeader>
    <CardContent className="pt-0">
      <slot />
    </CardContent>
  </Card>
</a>
