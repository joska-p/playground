---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/ui/features/Hero.astro";
import DocCard from "../../components/ui/cards/DocCard.astro";
import { getNotesByCategory, notebookBaseUrl } from "../../data/notebook";
import Footer from "../../layouts/Footer.astro";

const notesByCategory = await getNotesByCategory();
---

<BaseLayout title="Notebook" katex={true}>

  <Hero
    badgeText="Notebook"
    highlight="WIP"
    title="Not a Blog"
    description="A repository of ideas and notes that don't fit anywhere else."
  />

  <div class="mx-auto w-full max-w-5xl px-6 py-16 lg:py-20">
    <div class="space-y-16">
      {notesByCategory.map((category) => (
        <section id={category.id} class="scroll-mt-20">

          <!-- Category header -->
          <header class="mb-8 flex items-start gap-4">
            <span
              class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-border bg-card"
              style={{ color: `var(--category-${category.id}, var(--primary))` }}
            >
            </span>
            <div>
              <div class="flex items-center gap-3 mb-1">
                <h2
                  class="text-xs font-bold tracking-[0.18em] uppercase m-0"
                  style={{ color: `var(--category-${category.id}, var(--primary))` }}
                >
                  {category.label}
                </h2>
                <span class="h-px flex-1 bg-border" />
              </div>
              {category.description && (
                <p class="text-sm text-muted-foreground max-w-2xl leading-relaxed">
                  {category.description}
                </p>
              )}
            </div>
          </header>

          <!-- Cards -->
          <div class="grid gap-4 sm:grid-cols-2">
            {category.articles.map((note) => {
              const noteUrl     = `${notebookBaseUrl}${note.id}/`;
              return (
                <DocCard
                  href={noteUrl}
                  title={note.data.title}
                  description={note.data.description}
                />
              );
            })}
          </div>

        </section>
      ))}
    </div>
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
