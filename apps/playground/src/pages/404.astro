---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from '@repo/ui/Icon';
import Footer from '../layouts/Footer.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
---

<BaseLayout title="404 — Not Found">
  <div
    class="relative flex flex-1 items-center justify-center overflow-hidden px-6 py-24"
  >
    <!-- Grid bg -->
    <div
      class="absolute inset-0 z-0 bg-[linear-gradient(var(--border)_1px,transparent_1px),linear-gradient(to_right,var(--border)_1px,transparent_1px)] bg-[length:4rem_4rem] opacity-10"
      aria-hidden="true"
    >
    </div>

    <!-- Radial fade mask -->
    <div
      class="absolute inset-0 z-0 bg-[radial-gradient(ellipse_70%_60%_at_50%_50%,transparent_50%,var(--background)_100%)]"
      aria-hidden="true"
    >
    </div>

    <!-- Glow -->
    <div
      class="bg-primary absolute top-1/2 left-1/2 z-0 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full opacity-5 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 mx-auto max-w-lg text-center">
      <!-- 404 numeral -->
      <p
        class="from-primary via-accent to-secondary mb-2 bg-linear-to-br bg-clip-text text-9xl font-black text-transparent"
      >
        404
      </p>

      <!-- Heading -->
      <h1 class="mb-4 text-lg font-bold uppercase">Page not found</h1>

      <p class="text-muted-foreground mx-auto mb-10 max-w-sm text-sm">
        You've ventured into the void. This page doesn't exist — perhaps it was
        lost in the multiverse, or maybe it never was.
      </p>

      <!-- Actions -->
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href={`${baseUrl}/`}
          class="bg-primary text-primary-foreground inline-flex h-10 items-center gap-2 rounded-md px-6 text-xs font-bold uppercase transition-all hover:-translate-y-px hover:opacity-90 active:translate-y-0"
        >
          <Icon
            name="home"
            className="h-3.5 w-3.5"
          />
          Go Home
        </a>
        <a
          href={`${baseUrl}projects/`}
          class="border-border bg-card text-muted-foreground hover:border-primary/30 hover:text-foreground inline-flex h-10 items-center gap-2 rounded-md border px-6 text-xs font-bold uppercase transition-all active:scale-95"
        >
          <Icon
            name="sparkles"
            className="h-3.5 w-3.5"
          />
          Explore
        </a>
      </div>
    </div>

    <!-- Decorative corners -->
    <div
      class="border-border/40 pointer-events-none absolute bottom-8 left-8 z-10 h-16 w-16 border-b border-l"
      aria-hidden="true"
    >
    </div>
    <div
      class="border-border/40 pointer-events-none absolute top-8 right-8 z-10 h-16 w-16 border-t border-r"
      aria-hidden="true"
    >
    </div>
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
