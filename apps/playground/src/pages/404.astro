---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from '@repo/ui/icons';
import Footer from '../layouts/Footer.astro';
import { Hero } from '@repo/ui/data-display';
import { buttonVariants } from '@repo/ui/data-entry';

const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}#atlas`;
---

<BaseLayout title="404 — Not Found">
  <Hero
    badgeText="Lost in the woods"
    highlight="404"
    title="PAGE NOT FOUND"
    description="You've ventured into the void. This page doesn't exist — perhaps it was lost in the multiverse, or maybe it never was."
  >
    <a
      href={`${baseUrl}`}
      class={buttonVariants({ variant: 'primary' }) +
        ' shadow-primary/20 hover:shadow-primary/30 rounded-full shadow-lg hover:-translate-y-0.5 hover:shadow-xl uppercase text-xs px-6 h-10'}
    >
      <Icon
        name="home"
        className="h-3.5 w-3.5"
      />
      Go Home
    </a>
    <a
      href={projectsBaseUrl}
      class="border-border/50 text-muted-foreground hover:border-primary/40 hover:bg-muted/30 hover:text-primary inline-flex h-10 items-center gap-2 rounded-full border-2 bg-transparent px-6 text-xs font-bold uppercase transition-all duration-300 hover:-translate-y-0.5 active:scale-95"
    >
      All Projects
    </a>
  </Hero>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
