---
import BaseLayout from "../layouts/base-layout.astro";
import ExperimentCard from "../components/ui/experiment-card/index.astro";
import DocCard from "../components/ui/doc-card/index.astro";
import SectionHeader from "../components/ui/section-header/index.astro";
import FooterLinks from "../components/ui/footer-links/index.astro";
import { getFeaturedProjects } from "../data/projects";
import { Sparkles, Book, Terminal } from "lucide-react";
import { getFeaturedDocs, docsBaseUrl } from "../data/docs";

const baseUrl = import.meta.env.BASE_URL || "/";
const projectsBaseUrl = `${baseUrl}projects/`;
const githubRoute = { href: "https://github.com/joska-p/playground" };
const featuredProjects = getFeaturedProjects();
const featuredDocs = await getFeaturedDocs();
---

<BaseLayout title="Playground">
  <section
    class="hero-section border-border relative flex flex-col items-start justify-end overflow-hidden border-b px-6 py-20 lg:py-28"
  >
    <!-- Dot-grid background -->
    <div class="dot-grid absolute inset-0 z-0"></div>

    <!-- Primary radial glow, bottom-left anchored -->
    <div
      class="bg-primary absolute bottom-0 left-0 z-0 h-120 w-120 -translate-x-1/4 translate-y-1/4 rounded-full opacity-10 blur-3xl"
    >
    </div>

    <div class="relative z-10 mx-auto w-full max-w-6xl">
      <!-- Tag / environment badge -->
      <div
        class="border-primary/30 bg-primary/8 text-primary mb-6 inline-flex items-center gap-2 rounded border px-3 py-1 font-mono text-[10px] tracking-widest"
      >
        <span class="hero-pulse bg-primary h-1.5 w-1.5 rounded-full"></span>
        STATELESS_FIRST &nbsp;·&nbsp; ASTRO + REACT 19
      </div>

      <!-- Headline -->
      <h1
        class="text-foreground font-mono text-5xl leading-[1.06] font-bold tracking-tight sm:text-6xl lg:text-7xl"
      >
        Creative<br />
        <span class="text-primary">Playground<span class="hero-cursor">_</span></span>
      </h1>

      <!-- Description -->
      <p class="text-muted-foreground mt-6 max-w-xl text-base leading-relaxed">
        A high-performance lab for interactive visualizations,
        <span class="text-foreground font-medium">math sequences</span>, and color tools. Built with
        Astro + React 19 to experiment without limits.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a
          href="#experiments"
          class="bg-primary text-primary-foreground inline-flex h-10 items-center gap-2 rounded-md px-6 font-mono font-bold tracking-widest transition-all hover:-translate-y-px hover:opacity-90 active:translate-y-0 active:opacity-100"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"
            ></line></svg
          >
          EXPLORE ENGINES
        </a>
        <a
          href={projectsBaseUrl}
          class="border-border bg-card text-muted-foreground hover:border-foreground/40 hover:text-foreground inline-flex h-10 items-center rounded-md border px-6 font-mono tracking-widest transition-all active:scale-[0.98]"
        >
          BROWSE PROJECTS
        </a>
      </div>
    </div>
  </section>

  <!-- ── STATS ROW ─────────────────────────────────────────────────────── -->
  <div class="border-border bg-card border-b">
    <dl class="divide-border mx-auto grid max-w-6xl grid-cols-2 divide-x sm:grid-cols-4">
      {
        [
          { value: "24+", label: "EXPERIMENTS" },
          { value: "4", label: "CATEGORIES" },
          { value: "60fps", label: "TARGET PERF" },
          { value: "0", label: "RUNTIME DEPS" },
        ].map(({ value, label }) => (
          <div class="flex flex-col px-6 py-5">
            <dt class="text-muted-foreground font-mono text-[10px] tracking-widest">{label}</dt>
            <dd class="text-foreground mt-1 font-mono text-2xl font-bold">{value}</dd>
          </div>
        ))
      }
    </dl>
  </div>

  <!-- ── CONTENT ────────────────────────────────────────────────────────── -->
  <div class="mx-auto w-full max-w-6xl px-6 py-20 lg:py-24">
    <!-- Engines & Labs -->
    <section id="experiments" class="mb-24 scroll-mt-20">
      <SectionHeader
        icon={Sparkles}
        title="Engines & Labs"
        description="Volatile experiments in high-interactivity canvas rendering."
        href={githubRoute.href}
      >
        <span slot="link-text">View all on GitHub</span>
      </SectionHeader>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          featuredProjects.map((project) => (
            <ExperimentCard
              href={`${projectsBaseUrl}${project.category}/${project.slug}/`}
              title={project.name}
              description={project.description}
              icon={project.icon}
              category={project.category}
              tags={project.tags}
            />
          ))
        }
      </div>
    </section>

    <!-- Documentation -->
    <section class="mb-24">
      <!-- Subtle inner container with card bg -->
      <div class="border-border bg-card/50 rounded-xl border p-8 lg:p-12">
        <SectionHeader
          icon={Book}
          title="Documentation"
          description="Manifesto, guides, and references for collaborators."
          align="center"
        />

        <div class="mt-10 grid gap-5 sm:grid-cols-2">
          {
            featuredDocs.map((doc) => {
              const docUrl = `${docsBaseUrl}${doc.id}/`;
              const firstTagId = doc.data.tags[0] || "explanation";
              return (
                <DocCard
                  href={docUrl}
                  type={firstTagId}
                  title={doc.data.title}
                  description={doc.data.description}
                />
              );
            })
          }
        </div>

        <div class="mt-10 text-center">
          <a
            href={docsBaseUrl}
            class="text-primary hover:text-foreground inline-flex items-center gap-2 font-mono font-bold tracking-widest transition-colors"
          >
            BROWSE DOCS
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
            >
          </a>
        </div>
      </div>
    </section>

    <FooterLinks>
      <span slot="default">Crafted with creativity.</span>
    </FooterLinks>
  </div>
</BaseLayout>

<style>
  /* Dot-grid using the border color so it respects both themes */
  .dot-grid {
    background-image: radial-gradient(circle, var(--border) 1px, transparent 1px);
    background-size: 26px 26px;
    opacity: 0.45;
  }

  /* Blinking cursor on headline */
  .hero-cursor {
    animation: cursor-blink 1.1s step-end infinite;
  }
  @keyframes cursor-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  /* Pulsing live dot */
  .hero-pulse {
    animation: hero-pulse 2.4s ease-in-out infinite;
  }
  @keyframes hero-pulse {
    0%,
    75%,
    100% {
      opacity: 1;
    }
    87% {
      opacity: 0.1;
    }
  }
</style>
