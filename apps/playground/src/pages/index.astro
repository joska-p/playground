---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Hero, SectionHeader } from '@repo/ui/data-display';
import Footer from '../layouts/Footer.astro';
import ProjectsList from '../components/ProjectsList.astro';
import NotesList from '../components/NotesList.astro';
import DocumentsList from '../components/DocumentsList.astro';
---

<BaseLayout title="Cahier d'exercices">
  <Hero
    variant="ghost"
    badgeText="Recreational Programming"
    highlight="Reinventing the wheel"
    title="Cahier d'exercices"
    description="A personal archive of uncharted logic, visual phenomena, and mathematical playgrounds. Built not to be finished, but to discover what happens next."
  />
</BaseLayout>

<section
  id="discoveries"
  class="mx-auto mb-24 w-full max-w-6xl px-6 py-20 lg:py-24"
>
  <SectionHeader
    iconName="bluesky"
    title="Discoveries"
    description="Experiments catalogued in the field — live prototypes and visual investigations."
    className="mb-12"
  />
  <ProjectsList />
</section>

<section
  id="notes"
  class="mx-auto mb-24 w-full max-w-6xl px-6 py-20 lg:py-24"
>
  <SectionHeader
    iconName="bluesky"
    title="Field Notes"
    description="Reflective writing, logs, and observations from the research process."
    className="mb-12"
  />
  <NotesList />
</section>

<section
  id="documents"
  class="mx-auto mb-24 w-full max-w-6xl px-6 py-20 lg:py-24"
>
  <SectionHeader
    iconName="bluesky"
    title="Codex"
    description="Technical references, guides, and the collective manual."
    align="center"
    className="mb-12"
  />
  <DocumentsList />
</section>

<Footer>
  <span slot="default">Crafted with creativity.</span>
</Footer>
