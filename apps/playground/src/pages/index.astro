---
import BaseLayout from "../layouts/base-layout.astro";
import ExperimentCard from "../components/ui/experiment-card/index.astro";
import DocCard from "../components/ui/doc-card/index.astro";
import SectionHeader from "../components/ui/section-header/index.astro";
import FooterLinks from "../components/ui/footer-links/index.astro";
import { projects, getProjectSlugs } from "../data/projects";

// Import the new processed data
import { featuredDocs } from "../data/docs";
import { Sparkles, Book, Zap } from "lucide-react";

const baseUrl = import.meta.env.BASE_URL || "/";
const docsBaseUrl = `${baseUrl}docs/`;
const projectsBaseUrl = `${baseUrl}projects/`;

const githubRoute = { href: "https://github.com/joska-p/playground" };

// Get featured projects (first 4)
const featuredSlugs = getProjectSlugs().slice(0, 4);
---

<BaseLayout title="Playground">
  <section class="relative flex flex-col items-center justify-center overflow-hidden border-b border-border/40 bg-card/30 px-6 py-24 text-center lg:py-32">
    <div class="absolute inset-0 z-0 opacity-20">
      <div class="absolute top-0 left-0 h-full w-full bg-[radial-gradient(circle_at_50%_50%,var(--primary),transparent_70%)]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-4xl">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1 text-sm font-medium text-primary">
        <Zap className="h-4 w-4 fill-current text-primary" />
        <span>Stateless First Architecture</span>
      </div>

      <h1 class="font-serif text-6xl font-black tracking-tighter sm:text-7xl lg:text-8xl">
        Creative <span class="bg-linear-to-r from-primary via-accent to-secondary bg-clip-text text-transparent">Playground</span>
      </h1>

      <p class="mx-auto mt-8 max-w-2xl text-xl text-muted-foreground leading-relaxed">
        A high-performance creative coding lab. Interactive visualizations, math sequences, and color tools built with
        <span class="text-foreground font-semibold italic">Astro + React 19</span>.
      </p>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
        <a
          href="#experiments"
          class="inline-flex h-12 items-center justify-center rounded-lg bg-primary px-8 text-sm font-bold text-primary-foreground shadow-lg shadow-primary/20 transition-all hover:scale-105 hover:bg-primary/90 active:scale-95"
        >
          Explore Engines
        </a>
        <a
          href={projectsBaseUrl}
          class="inline-flex h-12 items-center justify-center rounded-lg border border-border bg-background px-8 text-sm font-bold transition-all hover:bg-muted active:scale-95"
        >
          Browse Projects
        </a>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
    <section id="experiments" class="mb-24 scroll-mt-24">
      <SectionHeader
        icon={Sparkles}
        title="Engines & Labs"
        description="Volatile experiments in high-interactivity canvas rendering."
        href={githubRoute.href}
      >
        <span slot="link-text">View all on GitHub</span>
      </SectionHeader>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 mt-12">
        {featuredSlugs.map((slug) => {
          const project = projects[slug];
          if (!project) return null;
          return (
            <ExperimentCard
              href={`${projectsBaseUrl}${project.category}/${slug}/`}
              title={project.name}
              description={project.description}
              icon={project.icon}
              category={project.category}
              tags={project.tags}
            />
          );
        })}
      </div>
    </section>

    <section class="mb-24 rounded-3xl bg-muted/30 p-8 lg:p-12">
      <SectionHeader
        icon={Book}
        title="Documentation"
        description="Manifesto, guides, and references for collaborators."
        align="center"
      />

      <div class="grid gap-6 sm:grid-cols-2 mt-12">
        {featuredDocs.map((doc) => (
          <DocCard
            href={doc.url}
            type={doc.tagMetadata[0]?.id || "reference"}
            title={doc.data.title}
            description={doc.data.description}
          />
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href={docsBaseUrl} class="inline-flex items-center gap-2 font-bold text-primary hover:text-accent transition-colors">
          Browse Documentation
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <FooterLinks>
      <span slot="default">Crafted with creativity.</span>
    </FooterLinks>
  </div>
</BaseLayout>
