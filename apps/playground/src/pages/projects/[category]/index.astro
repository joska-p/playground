---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ExperimentCard from '../../../components/ui/cards/ExperimentCard.astro';
import Hero from '../../../components/ui/features/Hero.astro';
import Footer from '../../../layouts/Footer.astro';

export async function getStaticPaths() {
  const categories = await getCollection('projects-categories');
  return categories.map((cat) => ({
    params: { category: cat.id }
  }));
}

const { category } = Astro.params;

const allCategories = await getCollection('projects-categories');
const categoryMeta = allCategories.find((c) => c.id === category);

if (!categoryMeta) {
  return Astro.redirect('/404');
}

const allProjects = await getCollection('projects');
const categoryProjects = allProjects.filter((p) => p.data.category.id === category);
const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}projects/`;
const { name, description } = categoryMeta.data;
---

<BaseLayout title={`${name} — Projects`}>
  <Hero
    badgeText="project"
    title={name}
    highlight={category}
    description={description}
  />
  <div class="mx-auto w-full max-w-6xl px-6 py-16 lg:py-20">
    <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
      {
        categoryProjects.map((project) => (
          <ExperimentCard
            href={`${projectsBaseUrl}${project.data.category.id}/${project.id}/`}
            title={project.data.name}
            description={project.data.description}
            iconName={project.data.icon}
            category={project.data.category.id}
            tags={project.data.tags.map((t) => t.id)}
          />
        ))
      }
    </div>
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
