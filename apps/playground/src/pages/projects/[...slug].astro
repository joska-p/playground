---
import { getCollection } from 'astro:content';
import { DynamicProjectApp } from '../../components/DynamicProjectApp';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Hero } from '@repo/ui/data-display';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: `${project.data.tags[0]}/${project.id}` }
  }));
}

const slug = Astro.params.slug;
const projectSlug = slug.split('/').pop()!;
const allProjects = await getCollection('projects');
const project = allProjects.find((p) => p.id === projectSlug);

if (!project) {
  return Astro.redirect('/404');
}

const { name, description } = project.data;
const mainTag = project.data.tags[0];
const keywords = project.data.tags.join(', ');
---

<BaseLayout
  title={name}
  description={description}
  keywords={keywords}
>
  <Hero
    badgeText={keywords}
    title={name}
    highlight={mainTag}
    description={description}
  />
  <div class="h-0 min-h-screen">
    <DynamicProjectApp
      slug={projectSlug}
      client:only="react"
    />
  </div>
</BaseLayout>
