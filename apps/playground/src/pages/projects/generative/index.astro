---
import BaseLayout from "../../../layouts/base-layout.astro";
import ExperimentCard from "../../../components/ui/experiment-card/index.astro";
import SectionHeader from "../../../components/ui/section-header/index.astro";
import { getProjectsByCategory } from "../../../data/projects";

const baseUrl = import.meta.env.BASE_URL || "/";
const projectsBaseUrl = `${baseUrl}projects/`;
const categories = getProjectsByCategory();
---

<BaseLayout title="Projects | Playground">
  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section
    class="projects-hero border-border relative flex flex-col items-start justify-end overflow-hidden border-b px-6 py-20 lg:py-24"
  >
    <div class="dot-grid absolute inset-0 z-0"></div>
    <div
      class="bg-primary absolute right-0 bottom-0 z-0 h-96 w-96 translate-x-1/4 translate-y-1/4 rounded-full opacity-10 blur-3xl"
    >
    </div>

    <div class="relative z-10 mx-auto w-full max-w-6xl">
      <div
        class="border-primary/30 bg-primary/8 text-primary mb-5 inline-flex items-center gap-2 rounded border px-3 py-1 text-[10px] tracking-widest"
      >
        <span class="hero-pulse bg-primary h-1.5 w-1.5 rounded-full"></span>
        CREATIVE PROJECTS
      </div>

      <h1
        class="text-5xl leading-[1.06] tracking-tight sm:text-6xl lg:text-7xl"
      >
        Explore<br />
        <span class="text-primary">The Lab<span class="hero-cursor">_</span></span>
      </h1>

      <p class="text-muted-foreground mt-6 max-w-xl text-sm">
        Interactive tools, visualizations, and creative engines built with
        <span class="text-foreground font-medium">Astro + React 19</span>. Browse by category to
        find the right experiment.
      </p>
    </div>
  </section>

  <!-- ── PROJECT CATEGORIES ────────────────────────────────────── -->
  <div class="mx-auto w-full max-w-6xl px-6 py-16 lg:py-20">
    {
      categories.map(({ name, description, projects }) => (
        <section class="mb-16 last:mb-0">
          <SectionHeader title={name} description={description} />

          <div class="mt-8 grid gap-5 sm:grid-cols-2">
            {projects.map((project) => (
              <ExperimentCard
                href={`${projectsBaseUrl}${project.category}/${project.slug}/`}
                title={project.name}
                description={project.description}
                icon={project.icon}
                category={project.category}
                tags={project.tags}
              />
            ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>

<style>
  .dot-grid {
    background-image: radial-gradient(circle, var(--border) 1px, transparent 1px);
    background-size: 26px 26px;
    opacity: 0.45;
  }
  .hero-cursor {
    animation: cursor-blink 1.1s step-end infinite;
  }
  @keyframes cursor-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  .hero-pulse {
    animation: hero-pulse 2.4s ease-in-out infinite;
  }
  @keyframes hero-pulse {
    0%,
    75%,
    100% {
      opacity: 1;
    }
    87% {
      opacity: 0.1;
    }
  }
</style>
