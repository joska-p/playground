---
import { App } from '@repo/mosaic-maker';
import { StrictMode } from 'react';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { projects } from '../../../../data/projects';
import Hero from '../../../../components/ui/features/Hero.astro';

const project = projects['mosaic'];
const keywords = `${project['tags'].join(', ')}`;
---

<BaseLayout
  title={project['name']}
  description={project['description']}
  keywords={keywords}
>
  <Hero
    badgeText={keywords}
    title={project['name']}
    highlight={project['category']}
    description={project['description']}
  />
  <div class="min-h-screen">
    <StrictMode>
      <App client:only="react" />
    </StrictMode>
  </div>
</BaseLayout>
