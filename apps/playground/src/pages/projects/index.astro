---
import BaseLayout from "../../layouts/base-layout.astro";
import Hero from "../../components/ui/features/hero.astro";
import ExperimentCard from "../../components/ui/cards/experiment-card.astro";
import SectionHeader from "../../components/ui/features/section-header.astro";
import { getProjectsByCategory } from "../../data/projects";
import Footer from "../../layouts/footer.astro";

const baseUrl = import.meta.env.BASE_URL || "/";
const projectsBaseUrl = `${baseUrl}projects/`;
const categories = getProjectsByCategory();
---

<BaseLayout title="Projects">
  <Hero
    badgeText="Creative Projects"
    title="The Lab"
    highlight="Explore"
    description="Interactive tools, visualizations, and creative engines built with Astro + React 19</span>. Browse by category to find the right experiment."
  />

  <div class="mx-auto w-full max-w-6xl px-6 py-16 lg:py-20">
    <div class="space-y-16">
      {
        categories.map(({ name, description, projects }) => (
          <section>
            <SectionHeader title={name} description={description} />
            <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {projects.map((project) => (
                <ExperimentCard
                  href={`${projectsBaseUrl}${project.category}/${project.slug}/`}
                  title={project.name}
                  description={project.description}
                  icon={project.icon}
                  category={project.category}
                  tags={project.tags}
                />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
