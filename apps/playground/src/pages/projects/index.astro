---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Hero } from '@repo/ui/data-display';
import { ProjectCard } from '@repo/ui/cards';
import Footer from '../../layouts/Footer.astro';
import type { CSSProperties } from 'react';

const allProjects = await getCollection('projects');
const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}projects/`;
---

<BaseLayout title="Projects">
  <Hero
    badgeText="Creative Projects"
    title="The Lab"
    highlight="Explore"
    description="Interactive tools, visualizations, and creative engines built with Astro + React 19. Browse by category to find the right experiment."
  />

  <div class="mx-auto w-full max-w-6xl space-y-16 px-6 py-16 lg:py-20">
    <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
      {
        allProjects.map((project) => {
          const mainTag = project.data.tags[0].id;
          const cardStyle = {
            '--_color': `var(--color-tags-${mainTag})`
          } as CSSProperties;
          return (
            <ProjectCard
              href={`${projectsBaseUrl}${project.id}`}
              title={project.data.title}
              description={project.data.description}
              iconName={project.data.iconName}
              style={cardStyle}
              tags={project.data.tags.map((tag) => tag.id)}
            />
          );
        })
      }
    </div>
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
