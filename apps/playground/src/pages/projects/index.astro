---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/ui/features/Hero.astro';
import ExperimentCard from '../../components/ui/cards/ExperimentCard.astro';
import SectionHeader from '../../components/ui/features/SectionHeader.astro';
import { getProjectsByCategory } from '../../data/projects';
import Footer from '../../layouts/Footer.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}projects/`;
const categories = getProjectsByCategory();
---

<BaseLayout title="Projects">
  <Hero
    badgeText="Creative Projects"
    title="The Lab"
    highlight="Explore"
    description="Interactive tools, visualizations, and creative engines built with Astro + React 19. Browse by category to find the right experiment."
  />

  <div class="mx-auto w-full max-w-6xl space-y-16 px-6 py-16 lg:py-20">
    {
      categories.map(({ name, description, icon, projects, id }) => (
        <section>
          <SectionHeader
            title={name}
            description={description}
            iconName={icon}
            className="mb-12"
            category={id}
          />
          <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
            {projects.map((project) => (
              <ExperimentCard
                href={`${projectsBaseUrl}${project.category}/${project.slug}/`}
                title={project.name}
                description={project.description}
                iconName={project.icon}
                category={project.category}
                tags={project.tags}
              />
            ))}
          </div>
        </section>
      ))
    }
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
