---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Hero, SectionHeader } from '@repo/ui/data-display';
import { ProjectCard } from '@repo/ui/cards';
import Footer from '../../layouts/Footer.astro';
import type { CSSProperties } from 'react';
import type { IconName } from '@repo/ui/icons';

const allTags = await getCollection('tags');
const allProjects = await getCollection('projects');
const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}projects/`;

interface Group {
  id: string;
  name: string;
  description: string;
  icon: IconName;
  order: number;
  projects: Array<{
    slug: string;
    tags: string[];
    name: string;
    description: string;
    icon: IconName;
  }>;
}

const groups: Group[] = allTags
  .filter((tag) => tag.data.order !== undefined && tag.data.icon !== undefined)
  .sort((a, b) => a.data.order - b.data.order)
  .map((tag) => ({
    id: tag.data.slug,
    name: tag.data.name,
    description: tag.data.description,
    icon: tag.data.icon!,
    order: tag.data.order,
    projects: allProjects
      .filter((p) => p.data.tags[0] === tag.data.slug)
      .map((p) => ({
        slug: p.id,
        tags: p.data.tags,
        name: p.data.name,
        description: p.data.description,
        icon: p.data.icon
      }))
  }))
  .filter((g) => g.projects.length > 0);
---

<BaseLayout title="Projects">
  <Hero
    badgeText="Creative Projects"
    title="The Lab"
    highlight="Explore"
    description="Interactive tools, visualizations, and creative engines built with Astro + React 19. Browse by category to find the right experiment."
  />

  <div class="mx-auto w-full max-w-6xl space-y-16 px-6 py-16 lg:py-20">
    {
      groups.map(({ name, description, id, projects }) => {
        const cardStyle = {
          '--_color': `var(--color-projects-${id})`
        } as CSSProperties;

        return (
          <section>
            <SectionHeader
              title={name}
              description={description}
              className="mb-12"
              style={cardStyle}
              iconName="bluesky"
            />
            <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
              {projects.map((project) => {
                const cardStyle = {
                  '--_color': `var(--color-projects-${id})`
                } as CSSProperties;
                return (
                  <ProjectCard
                    href={`${projectsBaseUrl}${id}/${project.slug}/`}
                    title={project.name}
                    description={project.description}
                    iconName={project.icon}
                    style={cardStyle}
                    tags={project.tags}
                  />
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
