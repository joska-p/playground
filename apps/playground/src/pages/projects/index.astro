---
import BaseLayout from "../../layouts/base-layout.astro";
import ExperimentCard from "../../components/ui/experiment-card/index.astro";
import SectionHeader from "../../components/ui/section-header/index.astro";
import { baseUrl } from "../../constants/routes";
import {
  categories,
  projectsByCategory,
  type Category,
} from "../../data/projects";

const projectsBase = `${baseUrl}/projects`;
const categoryList: Category[] = ["generative", "color", "image"];
---

<BaseLayout title="Projects | Playground">
  <section class="relative flex flex-col items-center justify-center overflow-hidden border-b border-border/40 bg-card/30 px-6 py-24 text-center lg:py-32">
    <div class="absolute inset-0 z-0 opacity-20">
      <div class="absolute top-0 left-0 h-full w-full bg-[radial-gradient(circle_at_50%_50%,var(--primary),transparent_70%)]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-4xl">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1 text-sm font-medium text-primary">
        <span>Creative Projects</span>
      </div>

      <h1 class="font-serif text-5xl font-black tracking-tighter sm:text-6xl lg:text-7xl">
        Explore the <span class="bg-linear-to-r from-primary via-accent to-secondary bg-clip-text text-transparent">Lab</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
        Interactive tools, visualizations, and creative engines built with Astro + React 19.
        Browse projects by category to find the right tool for your creative workflow.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
    {categoryList.map((category) => {
      const categoryMeta = categories[category];
      const CategoryIcon = categoryMeta.icon;
      const categoryProjects = projectsByCategory[category];

      return (
        <section class="mb-16">
          <SectionHeader
            icon={CategoryIcon}
            title={categoryMeta.name}
            description={categoryMeta.description}
          />

          <div class="grid gap-8 sm:grid-cols-2 mt-8">
            {categoryProjects.map((project) => (
              <ExperimentCard
                href={`${projectsBase}/${project.slug}`}
                title={project.name}
                description={project.description}
                icon={project.icon}
                iconBgColor={project.iconBg}
                iconColor={project.iconColor}
                tags={project.tags}
              />
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>