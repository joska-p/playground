---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Hero, SectionHeader } from '@repo/ui/data-display';
import { ProjectCard } from '@repo/ui/cards';
import Footer from '../../layouts/Footer.astro';
import type { CSSProperties } from 'react';

const allCategories = await getCollection('projects-categories');
const allProjects = await getCollection('projects');
const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}projects/`;

const categories = allCategories
  .sort((a, b) => a.data.order - b.data.order)
  .map((cat) => ({
    id: cat.id,
    name: cat.data.name,
    description: cat.data.description,
    icon: cat.data.icon,
    order: cat.data.order,
    projects: allProjects
      .filter((p) => p.data.category.id === cat.id)
      .map((p) => ({ ...p.data, slug: p.id }))
  }));
---

<BaseLayout title="Projects">
  <Hero
    badgeText="Creative Projects"
    title="The Lab"
    highlight="Explore"
    description="Interactive tools, visualizations, and creative engines built with Astro + React 19. Browse by category to find the right experiment."
  />

  <div class="mx-auto w-full max-w-6xl space-y-16 px-6 py-16 lg:py-20">
    {
      categories.map(({ name, description, id, projects }) => {
        const cardStyle = {
          '--_color': `var(--color-projects-${id})`
        } as CSSProperties;

        return (
          <section>
            <SectionHeader
              title={name}
              description={description}
              className="mb-12"
              style={cardStyle}
              iconName="bluesky"
            />
            <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
              {projects.map((project) => {
                const cardStyle = {
                  '--_color': `var(--color-projects-${id})`
                } as CSSProperties;
                return (
                  <ProjectCard
                    href={`${projectsBaseUrl}${project.category.id}/${project.slug}/`}
                    title={project.name}
                    description={project.description}
                    iconName={project.icon}
                    style={cardStyle}
                    tags={project.tags.map((t) => t.id)}
                  />
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
