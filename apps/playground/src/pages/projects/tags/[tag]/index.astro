---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ExperimentCard from '../../../../components/ui/cards/ExperimentCard.astro';
import SectionHeader from '../../../../components/ui/features/SectionHeader.astro';
import Footer from '../../../../layouts/Footer.astro';

export async function getStaticPaths() {
  const tags = await getCollection('tags');
  return tags.map((tag) => ({
    params: { tag: tag.id }
  }));
}

const { tag } = Astro.params;
const tagId = tag!;

const allTags = await getCollection('tags');
const tagMeta = allTags.find((t) => t.id === tagId);

if (!tagMeta) {
  return Astro.redirect('/404');
}

const allProjects = await getCollection('projects');
const tagProjects = allProjects.filter((p) =>
  p.data.tags.some((t) => t.id === tagId)
);
const baseUrl = import.meta.env.BASE_URL || '/';
const projectsBaseUrl = `${baseUrl}projects/`;
const { name } = tagMeta.data;
---

<BaseLayout title={`${name} Projects`}>
  <div class="mx-auto w-full max-w-6xl px-6 py-16 lg:py-20">
    <SectionHeader
      title={name}
      description={`Projects tagged with "${name}"`}
      iconName="data-viz"
    />

    <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
      {
        tagProjects.map((project) => (
          <ExperimentCard
            href={`${projectsBaseUrl}${project.data.category.id}/${project.id}/`}
            title={project.data.name}
            description={project.data.description}
            iconName={project.data.icon}
            category={project.data.category.id}
            tags={project.data.tags.map((t) => t.id)}
          />
        ))
      }
    </div>
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
