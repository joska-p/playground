---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/ui/features/Hero.astro';
import DocCard from '../../components/ui/cards/DocCard.astro';
import Footer from '../../layouts/Footer.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
const notesBaseUrl = `${baseUrl}notes/`;

const notebookCategories = await getCollection('notes-categories');
const allNotes = await getCollection('notes', ({ data }) => !data.draft);

const notesByCategory = notebookCategories.map((cat) => {
  const articles = allNotes
    .filter((note) => note.data.category.id === cat.id)
    .sort((a, b) => a.data.order - b.data.order);
  return {
    id: cat.id,
    label: cat.data.name,
    description: cat.data.description,
    articles
  };
});
---

<BaseLayout
  title="Notes"
  katex={true}
>
  <Hero
    badgeText="Notes"
    highlight="WIP"
    title="Not a Blog"
    description="A repository of ideas and notes that don't fit anywhere else."
  />

  <div class="mx-auto w-full max-w-5xl space-y-16 px-6 py-16 lg:py-20">
    {
      notesByCategory.map((category) => (
        <section
          id={category.id}
          class="scroll-mt-20"
        >
          <header class="mb-8 flex items-start gap-4">
            <span
              class="border-border bg-card mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md border text-(--color-current)"
              style={{
                '--color-current': `var(--category-${category.id}, var(--color-primary))`
              }}
            />
            <div>
              <div class="mb-1 flex items-center gap-3">
                <h2
                  class="m-0 text-xs font-bold text-(--color-current) uppercase"
                  style={{
                    '--color-current': `var(--category-${category.id}, var(--color-primary))`
                  }}
                >
                  {category.label}
                </h2>
                <span class="bg-border h-px flex-1" />
              </div>
              {category.description && (
                <p class="text-muted-foreground max-w-2xl text-sm">
                  {category.description}
                </p>
              )}
            </div>
          </header>

          <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-4">
            {category.articles.map((note) => {
              const noteUrl = `${notesBaseUrl}${note.id}/`;
              return (
                <DocCard
                  href={noteUrl}
                  title={note.data.title}
                  description={note.data.description}
                />
              );
            })}
          </div>
        </section>
      ))
    }
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
