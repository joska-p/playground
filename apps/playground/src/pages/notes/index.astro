---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Hero, SectionHeader } from '@repo/ui/data-display';
import { DocCard } from '@repo/ui/cards';
import Footer from '../../layouts/Footer.astro';
import type { CSSProperties } from 'react';

const baseUrl = import.meta.env.BASE_URL || '/';
const notesBaseUrl = `${baseUrl}notes/`;

const allTags = await getCollection('tags');
const allNotes = await getCollection('notes', ({ data }) => !data.draft);

interface NoteGroup {
  id: string;
  label: string;
  description: string;
  articles: typeof allNotes;
}

const groups: NoteGroup[] = allTags
  .filter((tag) => ['log', 'maths'].includes(tag.data.slug))
  .map((tag) => {
    const articles = allNotes
      .filter((note) => note.data.tags[0] === tag.data.slug)
      .sort((a, b) => a.data.order - b.data.order);
    return {
      id: tag.data.slug,
      label: tag.data.name,
      description: tag.data.description,
      articles
    };
  })
  .filter((g) => g.articles.length > 0);
---

<BaseLayout
  title="Notes"
  katex={true}
>
  <Hero
    badgeText="Notes"
    highlight="WIP"
    title="Not a Blog"
    description="A repository of ideas and notes that don't fit anywhere else."
  />

  <div class="mx-auto w-full max-w-5xl space-y-16 px-6 py-16 lg:py-20">
    {
      groups.map((category) => {
        const cardStyle = {
          '--_color': `var(--color-notes-${category.id})`
        } as CSSProperties;

        return (
          <section>
            <SectionHeader
              title={category.label}
              description={category.description}
              iconName="bluesky"
              className="mb-12"
              style={cardStyle}
            />
            <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
              {category.articles.map((note) => {
                const mainTag = note.data.tags[0];
                const cardStyle = {
                  '--_color': `var(--color-notes-${mainTag})`
                } as CSSProperties;
                const noteUrl = `${notesBaseUrl}${note.id}/`;
                return (
                  <DocCard
                    href={noteUrl}
                    title={note.data.title}
                    description={note.data.description ?? ''}
                    style={cardStyle}
                  />
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
