---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Hero } from '@repo/ui/Hero';
import { DocCard } from '@repo/ui/DocCard';
import Footer from '../../layouts/Footer.astro';
import type { CSSProperties } from 'react';
import { SectionHeader } from '@repo/ui/SectionHeader';

const baseUrl = import.meta.env.BASE_URL || '/';
const notesBaseUrl = `${baseUrl}notes/`;

const notebookCategories = await getCollection('notes-categories');
const allNotes = await getCollection('notes', ({ data }) => !data.draft);

const notesByCategory = notebookCategories.map((cat) => {
  const articles = allNotes
    .filter((note) => note.data.category.id === cat.id)
    .sort((a, b) => a.data.order - b.data.order);
  return {
    id: cat.id,
    label: cat.data.name,
    description: cat.data.description,
    articles
  };
});
---

<BaseLayout
  title="Notes"
  katex={true}
>
  <Hero
    badgeText="Notes"
    highlight="WIP"
    title="Not a Blog"
    description="A repository of ideas and notes that don't fit anywhere else."
  />

  <div class="mx-auto w-full max-w-5xl space-y-16 px-6 py-16 lg:py-20">
    {
      notesByCategory.map((category) => {
        const cardStyle = {
          '--_color': `var(--color-notes-${category.id})`
        } as CSSProperties;

        return (
          <section>
            <SectionHeader
              title={category.label}
              description={category.description}
              iconName="bluesky"
              className="mb-12"
              style={cardStyle}
            />
            <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
              {category.articles.map((note) => {
                const noteUrl = `${notesBaseUrl}${note.id}/`;
                return (
                  <DocCard
                    href={noteUrl}
                    title={note.data.title}
                    description={note.data.description ?? ''}
                  />
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
