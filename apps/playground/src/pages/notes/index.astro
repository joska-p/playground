---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Hero } from '@repo/ui/data-display';
import { DocCard } from '@repo/ui/cards';
import Footer from '../../layouts/Footer.astro';
import type { CSSProperties } from 'react';

const baseUrl = import.meta.env.BASE_URL || '/';
const notesBaseUrl = `${baseUrl}notes/`;
const allNotes = await getCollection('notes', ({ data }) => !data.draft);
---

<BaseLayout
  title="Notes"
  katex={true}
>
  <Hero
    badgeText="Notes"
    highlight="WIP"
    title="Not a Blog"
    description="A repository of ideas and notes that don't fit anywhere else."
  />

  <div class="mx-auto w-full max-w-5xl space-y-16 px-6 py-16 lg:py-20">
    <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
      {
        allNotes.map((note) => {
          const mainTag = note.data.tags[0].id;
          const cardStyle = {
            '--variant-color': `var(--tags-${mainTag})`
          } as CSSProperties;
          const noteUrl = `${notesBaseUrl}${note.id}/`;
          return (
            <DocCard
              href={noteUrl}
              title={note.data.title}
              description={note.data.description}
              style={cardStyle}
            />
          );
        })
      }
    </div>
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
