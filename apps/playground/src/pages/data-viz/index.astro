---
import CategoryPage from "../../layouts/category-page.astro";
import { baseUrl } from "../../constants/routes";

const title = "Data Viz";
const description = "Charts, graphs, and data visualization tools";
const projects = [
  {
    label: "Piechart",
    href: `${baseUrl}/data-viz/piechart/`,
    description: "Interactive d3-based piechart examples",
  },
  {
    label: "Graphify",
    href: `${baseUrl}/data-viz/graphify/graph.html`,
    description: "Knowledge graph",
  },
];
---

<CategoryPage title={title} description={description} projects={projects} />
