---
import Layout from "../../layouts/layout.astro";
import { baseUrl } from "../../constants/routes";

const projects = [
  {
    label: "Mosaic Maker",
    href: `${baseUrl}/mosaic/mosaic-maker/`,
    description: "Create complex mosaic patterns from images",
  },
];
---

<Layout title="Mosaic">
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-foreground">Mosaic</h1>
      <p class="mt-2 text-lg text-foreground/60">
        Pattern generation and tiling algorithms
      </p>
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project) => (
          <a
            href={project.href}
            class="group block rounded-lg border border-border bg-card p-6 transition-all hover:border-primary hover:bg-card/80"
          >
            <h2 class="text-xl font-semibold text-foreground group-hover:text-primary">
              {project.label}
            </h2>
            <p class="mt-2 text-sm text-foreground/60">{project.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</Layout>