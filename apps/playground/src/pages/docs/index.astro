---
import { Icon } from '@repo/ui/icons';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/ui/features/Hero.astro';
import DocCard from '../../components/ui/cards/DocCard.astro';
import Footer from '../../layouts/Footer.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
const docsBaseUrl = `${baseUrl}docs/`;

const docsCategories = await getCollection('docs-categories');
const allDocs = await getCollection('docs', ({ data }) => !data.draft);

const docsByCategory = docsCategories.map((cat) => {
  const articles = allDocs
    .filter((doc) => doc.data.category.id === cat.id)
    .sort((a, b) => a.data.order - b.data.order);
  return {
    id: cat.id,
    label: cat.data.name,
    description: cat.data.description,
    iconName: cat.data.icon,
    articles
  };
});
---

<BaseLayout title="Documentation">
  <Hero
    badgeText="Documentation"
    highlight="Knowledge"
    title="Base"
    description="Manifesto, guides, and references for collaborators and contributors."
  />
  <div class="mx-auto w-full max-w-5xl space-y-16 px-6 py-16 lg:py-20">
    {
      docsByCategory.map((category) => {
        return (
          <section
            id={category.id}
            class="scroll-mt-20"
          >
            <header class="mb-8 flex items-start gap-4">
              <span
                class="border-border bg-card mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md border text-(--color-current)"
                style={{
                  '--color-current': `var(--category-${category.id}, var(--color-primary))`
                }}
              >
                <Icon
                  name={category.iconName}
                  className="h-3.5 w-3.5"
                />
              </span>
              <div>
                <div class="mb-1 flex items-center gap-3">
                  <h2
                    class="m-0 text-xs font-bold text-(--color-current) uppercase"
                    style={{
                      '--color-current': `var(--category-${category.id}, var(--color-primary))`
                    }}
                  >
                    {category.label}
                  </h2>
                  <span class="bg-border h-px flex-1" />
                </div>
                {category.description && (
                  <p class="text-muted-foreground max-w-2xl text-sm">
                    {category.description}
                  </p>
                )}
              </div>
            </header>

            <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-4">
              {category.articles.map((doc) => {
                const docUrl = `${docsBaseUrl}${doc.id}/`;
                return (
                  <DocCard
                    href={docUrl}
                    title={doc.data.title}
                    description={doc.data.description}
                    type={category.id}
                    iconName={category.iconName}
                  />
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
