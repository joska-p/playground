---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Hero, SectionHeader } from '@repo/ui/data-display';
import { DocCard } from '@repo/ui/cards';
import Footer from '../../layouts/Footer.astro';
import type { CSSProperties } from 'react';
import type { IconName } from '@repo/ui/icons';

const baseUrl = import.meta.env.BASE_URL || '/';
const docsBaseUrl = `${baseUrl}docs/`;

const allTags = await getCollection('tags');
const allDocs = await getCollection('docs', ({ data }) => !data.draft);

interface DocGroup {
  id: string;
  label: string;
  description: string;
  iconName: IconName;
  articles: typeof allDocs;
}

const groups: DocGroup[] = allTags
  .filter((tag) =>
    ['tutorial', 'how-to', 'explanation', 'reference', 'conventions'].includes(tag.data.slug)
  )
  .map((tag) => {
    const articles = allDocs
      .filter((doc) => doc.data.tags[0] === tag.data.slug)
      .sort((a, b) => a.data.order - b.data.order);
    return {
      id: tag.data.slug,
      label: tag.data.name,
      description: tag.data.description,
      iconName: tag.data.icon ?? 'bluesky',
      articles
    };
  })
  .filter((g) => g.articles.length > 0);
---

<BaseLayout title="Documentation">
  <Hero
    badgeText="Documentation"
    highlight="Knowledge"
    title="Base"
    description="Manifesto, guides, and references for collaborators and contributors."
  />
  <div class="mx-auto w-full max-w-5xl space-y-16 px-6 py-16 lg:py-20">
    {
      groups.map((category) => {
        const cardStyle = {
          '--_color': `var(--color-docs-${category.id})`
        } as CSSProperties;

        return (
          <section>
            <SectionHeader
              title={category.label}
              description={category.description}
              iconName="bluesky"
              className="mb-12"
              style={cardStyle}
            />
            <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
              {category.articles.map((doc) => {
                const docUrl = `${docsBaseUrl}${doc.id}/`;
                return (
                  <DocCard
                    href={docUrl}
                    title={doc.data.title}
                    description={doc.data.description ?? ''}
                    type={category.id}
                    iconName={category.iconName}
                    style={cardStyle}
                  />
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
