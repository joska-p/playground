---
import BaseLayout from "../../layouts/base-layout.astro";
import DocCard from "../../components/ui/doc-card/index.astro";
import { getDocsByCategory, docsBaseUrl } from "../../data/docs";

const docsByCategory = await getDocsByCategory();
---

<BaseLayout title="Documentation Hub">

  <!-- ── PAGE HEADER ───────────────────────────────────────────── -->
  <section class="docs-hero relative flex flex-col items-start justify-end overflow-hidden border-b border-border px-6 py-16 lg:py-20">

    <div class="dot-grid absolute inset-0 z-0"></div>
    <div class="absolute top-0 left-0 z-0 h-80 w-80 -translate-x-1/3 -translate-y-1/3 rounded-full bg-primary opacity-8 blur-3xl"></div>

    <div class="relative z-10 mx-auto w-full max-w-6xl">
      <div class="mb-5 inline-flex items-center gap-2 rounded border border-primary/30 bg-primary/8 px-3 py-1 font-mono text-[10px] tracking-widest text-primary">
        <span class="hero-pulse h-1.5 w-1.5 rounded-full bg-primary"></span>
        DOCUMENTATION
      </div>

      <h1 class="font-mono text-4xl font-bold leading-[1.06] tracking-tight text-foreground sm:text-5xl lg:text-6xl">
        Knowledge<br />
        <span class="text-primary">Base<span class="hero-cursor">_</span></span>
      </h1>

      <p class="mt-5 max-w-lg text-sm leading-relaxed text-muted-foreground">
        Manifesto, guides, and references for collaborators and contributors.
      </p>
    </div>
  </section>

  <!-- ── CATEGORIES ────────────────────────────────────────────── -->
  <div class="mx-auto w-full max-w-5xl px-6 py-16 lg:py-20">
    <div class="space-y-16">
      {docsByCategory.map((category) => (
        <section id={category.id} class="scroll-mt-20">

          <!-- Category header -->
          <header class="mb-8 flex items-start gap-4">
            <span
              class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-border bg-card"
              style={{color: `var(--category-${category.id}, var(--primary))`}}
            >
              <category.Icon className="h-4 w-4" />
            </span>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="h-px w-5 bg-primary"></span>
                <h2 class="font-mono font-bold tracking-widest uppercase" style={{color: `var(--category-${category.id}, var(--primary))`}}>
                  {category.label}
                </h2>
              </div>
              {category.description && (
                <p class="text-sm leading-relaxed text-muted-foreground max-w-2xl">
                  {category.description}
                </p>
              )}
            </div>
          </header>

          <!-- Doc cards -->
          <div class="grid gap-4 sm:grid-cols-2">
            {category.articles.map((doc) => {
              const docUrl     = `${docsBaseUrl}${doc.id}/`;
              const firstTagId = doc.data.tags[0] || "explanation";
              return (
                <DocCard
                  href={docUrl}
                  title={doc.data.title}
                  description={doc.data.description}
                  type={firstTagId}
                />
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </div>

</BaseLayout>

<style>
  .dot-grid {
    background-image: radial-gradient(circle, var(--border) 1px, transparent 1px);
    background-size: 26px 26px;
    opacity: 0.45;
  }
  .hero-cursor {
    animation: cursor-blink 1.1s step-end infinite;
  }
  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  .hero-pulse {
    animation: hero-pulse 2.4s ease-in-out infinite;
  }
  @keyframes hero-pulse {
    0%, 75%, 100% { opacity: 1; }
    87%            { opacity: 0.1; }
  }
</style>
