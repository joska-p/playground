---
import BaseLayout from "../../layouts/base-layout.astro";
import DocCard from "../../components/ui/doc-card/index.astro";
import { Book, Wrench, Lightbulb, Code } from "lucide-react";
import { getDocs } from "../../utils/docs";

const baseUrl = import.meta.env.BASE_URL || "";

type DocVariant = "default" | "tutorial" | "howTo" | "explanation" | "reference";

const docs = await getDocs();

const docsByType = {
  tutorial: [] as typeof docs,
  "how-to": [] as typeof docs,
  explanation: [] as typeof docs,
  reference: [] as typeof docs,
};

for (const doc of docs) {
  docsByType[doc.data.type].push(doc);
}

const TYPE_LABELS: Record<string, string> = {
  tutorial: "Tutorials",
  "how-to": "How-To Guides",
  explanation: "Explanation",
  reference: "Reference",
};

const iconMap = {
  tutorial: Book,
  "how-to": Wrench,
  explanation: Lightbulb,
  reference: Code,
};

const docsBaseUrl = `${baseUrl}docs/`;

function getVariant(type: string): DocVariant {
  const variantMap: Record<string, DocVariant> = {
    "how-to": "howTo",
    tutorial: "tutorial",
    explanation: "explanation",
    reference: "reference",
  };
  return variantMap[type] ?? "default";
}
---

<BaseLayout title="Documentation Hub">
  <div class="mx-auto max-w-5xl px-6 py-16 lg:py-24">
    <header class="mb-20 text-center">
      <h1 class="font-serif text-5xl font-bold tracking-tight lg:text-6xl">
        Documentation <span class="text-primary">Hub</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
        Master the Creative Playground with our comprehensive guides, technical references, and architectural deep-dives.
      </p>
    </header>

    <div class="grid gap-16">
      {Object.entries(docsByType).map(([type, items]) => {
        if (items.length === 0) return null;
        const Icon = iconMap[type as keyof typeof iconMap];
        return (
          <section id={type} class="scroll-mt-24">
            <div class="mb-8 flex items-center gap-4 border-b border-border/40 pb-4">
              <div class="rounded-xl bg-primary/10 p-3">
                <Icon className="h-6 w-6 text-primary" />
              </div>
              <div>
                <h2 class="text-3xl font-bold tracking-tight">{TYPE_LABELS[type as string]}</h2>
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              {items.map((doc) => (
                <DocCard
                  href={`${docsBaseUrl}${doc.id}/`}
                  variant={getVariant(type)}
                  icon={Icon}
                  title={doc.data.title}
                  description={`Detailed documentation and guides for ${doc.data.title.toLowerCase()}.`}
                />
              ))}
            </div>
          </section>
        );
      })}
    </div>

    <footer class="mt-24 border-t border-border/40 pt-12 text-center">
      <p class="text-muted-foreground">
        Can't find what you're looking for?
        <a href="https://github.com/joska-p/playground/issues" class="ml-1 font-medium text-primary hover:underline">
          Open an issue on GitHub
        </a>
      </p>
    </footer>
  </div>
</BaseLayout>