---
import BaseLayout from "../../layouts/base-layout.astro";
import DocCard from "../../components/ui/cards/DocCard.astro";
import { getDocsByCategory, docsBaseUrl } from "../../data/docs";

const docsByCategory = await getDocsByCategory();
---

<BaseLayout title="Documentation">

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section class="relative flex flex-col justify-end overflow-hidden border-b border-border px-6 py-20 lg:py-28">
    <div class="dot-grid absolute inset-0 z-0" aria-hidden="true" />
    <div class="absolute -left-24 top-0 z-0 h-72 w-72 -translate-y-1/3 rounded-full bg-primary opacity-[0.06] blur-3xl" aria-hidden="true" />

    <div class="relative z-10 mx-auto w-full max-w-6xl">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/6 px-4 py-1.5 text-[10px] font-semibold tracking-[0.2em] text-primary uppercase">
        <span class="relative flex h-1.5 w-1.5">
          <span class="ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-60" />
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-primary" />
        </span>
        Documentation
      </div>

      <h1 class="text-[clamp(2.8rem,7vw,5.5rem)] font-black leading-[0.93] tracking-tight">
        Knowledge<br />
        <span class="text-primary">Base<span class="cursor">_</span></span>
      </h1>

      <p class="mt-6 max-w-lg text-base text-muted-foreground leading-relaxed">
        Manifesto, guides, and references for collaborators and contributors.
      </p>
    </div>
  </section>

  <!-- ── CATEGORIES ────────────────────────────────────────────── -->
  <div class="mx-auto w-full max-w-5xl px-6 py-16 lg:py-20">
    <div class="space-y-16">
      {docsByCategory.map((category) => (
        <section id={category.id} class="scroll-mt-20">

          <!-- Category header -->
          <header class="mb-8 flex items-start gap-4">
            <span
              class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-border bg-card"
              style={{ color: `var(--category-${category.id}, var(--primary))` }}
            >
              <category.Icon className="h-3.5 w-3.5" />
            </span>
            <div>
              <div class="flex items-center gap-3 mb-1">
                <h2
                  class="text-xs font-bold tracking-[0.18em] uppercase m-0"
                  style={{ color: `var(--category-${category.id}, var(--primary))` }}
                >
                  {category.label}
                </h2>
                <span class="h-px flex-1 bg-border" />
              </div>
              {category.description && (
                <p class="text-sm text-muted-foreground max-w-2xl leading-relaxed">
                  {category.description}
                </p>
              )}
            </div>
          </header>

          <!-- Cards -->
          <div class="grid gap-4 sm:grid-cols-2">
            {category.articles.map((doc) => {
              const docUrl     = `${docsBaseUrl}${doc.id}/`;
              const firstTagId = doc.data.tags[0] || "explanation";
              return (
                <DocCard
                  href={docUrl}
                  title={doc.data.title}
                  description={doc.data.description}
                  type={firstTagId}
                />
              );
            })}
          </div>

        </section>
      ))}
    </div>
  </div>

</BaseLayout>

<style>
  .dot-grid {
    background-image: radial-gradient(circle, var(--border) 1px, transparent 1px);
    background-size: 28px 28px;
    opacity: 0.5;
  }
  .cursor {
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  .ping {
    animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  @keyframes ping { 75%, 100% { transform: scale(2.2); opacity: 0; } }
</style>
