---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Hero } from '@repo/ui/data-display/Hero';
import { DocCard } from '@repo/ui/DocCard';
import Footer from '../../layouts/Footer.astro';
import { SectionHeader } from '@repo/ui/SectionHeader';
import type { CSSProperties } from 'react';

const baseUrl = import.meta.env.BASE_URL || '/';
const docsBaseUrl = `${baseUrl}docs/`;

const docsCategories = await getCollection('docs-categories');
const allDocs = await getCollection('docs', ({ data }) => !data.draft);

const docsByCategory = docsCategories.map((cat) => {
  const articles = allDocs
    .filter((doc) => doc.data.category.id === cat.id)
    .sort((a, b) => a.data.order - b.data.order);
  return {
    id: cat.id,
    label: cat.data.name,
    description: cat.data.description,
    iconName: cat.data.icon,
    articles
  };
});
---

<BaseLayout title="Documentation">
  <Hero
    badgeText="Documentation"
    highlight="Knowledge"
    title="Base"
    description="Manifesto, guides, and references for collaborators and contributors."
  />
  <div class="mx-auto w-full max-w-5xl space-y-16 px-6 py-16 lg:py-20">
    {
      docsByCategory.map((category) => {
        const cardStyle = {
          '--_color': `var(--color-docs-${category.id})`
        } as CSSProperties;

        return (
          <section>
            <SectionHeader
              title={category.label}
              description={category.description}
              iconName="bluesky"
              className="mb-12"
              style={cardStyle}
            />
            <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4">
              {category.articles.map((doc) => {
                const docUrl = `${docsBaseUrl}${doc.id}/`;
                return (
                  <DocCard
                    href={docUrl}
                    title={doc.data.title}
                    description={doc.data.description ?? ''}
                    type={category.id}
                    iconName={category.iconName}
                    style={cardStyle}
                  />
                );
              })}
            </div>
          </section>
        );
      })
    }
  </div>

  <Footer>
    <span slot="default">Crafted with creativity.</span>
  </Footer>
</BaseLayout>
