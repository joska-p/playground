---
import { render } from "astro:content";
import { processedDocs } from "../../data/docs";
import DocumentationLayout from "../../layouts/documentation/documentation-layout.astro";

export async function getStaticPaths() {
  return processedDocs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<DocumentationLayout entry={entry}>
  <Content />
</DocumentationLayout>
