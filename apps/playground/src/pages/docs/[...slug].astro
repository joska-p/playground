---
import { render, getCollection } from "astro:content";
import BaseLayout from "../../layouts/base-layout.astro";
import DocNav from "../../components/ui/docs/doc-nav.astro";
import SectionHeader from "../../components/ui/features/section-header.astro";
import { Book } from "lucide-react";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
---

<BaseLayout title={doc.data.title}>
  <div class="flex min-h-screen">
    <DocNav />

    <div class="flex-1">
      <div class="mx-auto max-w-3xl px-6 py-12 md:px-10 lg:py-16">
        <article class="prose prose-playground">
          <SectionHeader title={doc.data.category} description={doc.data.description} icon={Book} />
          <Content />
        </article>
      </div>
    </div>
  </div>
</BaseLayout>
