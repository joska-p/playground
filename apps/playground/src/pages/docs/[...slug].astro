---
import { render, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocNav from '../../components/ui/docs/DocNav.astro';
import { Hero } from '@repo/ui/data-display';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc }
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const allTags = await getCollection('tags');
const mainTag = doc.data.tags[0];
const tagEntry = allTags.find((t) => t.data.slug === mainTag);
const heroTitle = tagEntry?.data.name ?? mainTag;
---

<BaseLayout title={doc.data.title}>
  <Hero
    badgeText="Documentation"
    highlight="Knowledge"
    title={heroTitle}
    description={doc.data.description ?? ''}
  />
  <div class="flex justify-center">
    <article
      class="prose prose-playground max-w-3xl flex-1 place-self-center px-[clamp(1.5rem,3vw,2.5rem)] py-[clamp(3rem,4vw,4rem)]"
    >
      <Content />
    </article>
    <DocNav />
  </div>
</BaseLayout>
