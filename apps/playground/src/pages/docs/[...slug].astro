---
import { render, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocNav from '../../components/ui/docs/DocNav.astro';
import { Hero } from '@repo/ui/data-display';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc }
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const allTags = await getCollection('tags');
const mainTag = doc.data.tags[0];
const tagEntry = allTags.find((t) => t.data.slug === mainTag);
const heroTitle = tagEntry?.data.name ?? mainTag;
---

<BaseLayout title={doc.data.title}>
  <Hero
    badgeText="Documentation"
    highlight="Knowledge"
    title={heroTitle}
    description={doc.data.description ?? ''}
  />
  <div class="flex justify-center">
    <article
      class="prose prose-playground bg-surface/30 text-foreground t max-w-3xl flex-1 place-self-center rounded px-[clamp(1.5rem,3vw,2.5rem)] py-[clamp(3rem,4vw,4rem)] shadow-[inset_0_1px_0_0_color-mix(in_oklch,var(--glow-color)_22%,transparent),0_1px_28px_-10px_color-mix(in_oklch,var(--glow-color)_35%,transparent)] backdrop-blur-md"
    >
      <Content />
    </article>
    <DocNav />
  </div>
</BaseLayout>
