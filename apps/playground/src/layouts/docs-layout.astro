---
import Layout from "./layout.astro";
import { baseUrl } from "../constants/routes";
import { getDocsNav, type DocType } from "../utils/docs";
import DocsNav from "../components/docs-nav/index.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props;

const docsNav = await getDocsNav();
const docsBaseUrl = `${baseUrl}/docs`.replace(/\/+/g, "/");

const TYPE_LABELS: Record<DocType, string> = {
  tutorial: "Tutorials",
  "how-to": "How-To Guides",
  explanation: "Explanation",
  reference: "Reference",
};

const currentPath = Astro.url.pathname;
---

<Layout title={entry.data.title}>
  <div class="flex h-full overflow-hidden">
    <DocsNav
      sections={docsNav}
      currentPath={currentPath}
      docsBaseUrl={docsBaseUrl}
    />

    <main class="flex-1 overflow-y-auto">
      <div class="mx-auto max-w-4xl px-6 py-12 md:px-12">
        <article class="prose prose-gruvbox dark:prose-invert max-w-none prose-headings:font-serif prose-a:text-primary hover:prose-a:text-accent transition-colors">
          <slot />
        </article>
      </div>
    </main>
  </div>
</Layout>