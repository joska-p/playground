---
import NavLogo from './NavLogo.astro';
import NavLinks from './NavLinks.astro';
import NavActions from './NavActions.astro';
import MobileMenu from './MobileMenu.astro';

const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL || '/';

type Route = { label: string; href: string };
const routes: Route[] = [
  { label: '~/home', href: baseUrl },
  { label: '~/projects', href: `${baseUrl}projects/` },
  { label: '~/notes', href: `${baseUrl}notes/` },
  { label: '~/docs', href: `${baseUrl}docs/` }
];
---

<header class="sticky top-0 z-50 w-full md:top-4 md:px-6">
  <div
    class="border-border/30 bg-surface/30 md:hover:border-primary/20 relative z-30 mx-auto flex h-14 max-w-7xl items-center justify-between border-b px-4 shadow-[inset_0_1px_0_0_color-mix(in_srgb,var(--primary)_18%,transparent),0_1px_24px_-10px_color-mix(in_srgb,var(--primary)_25%,transparent),var(--shadow-md)] backdrop-blur-md transition-all duration-300 md:rounded-full md:border md:hover:shadow-[inset_0_1px_0_0_color-mix(in_srgb,var(--primary)_35%,transparent),0_4px_36px_-10px_color-mix(in_srgb,var(--primary)_40%,transparent),var(--shadow-lg)]"
  >
    <NavLogo href={baseUrl} />
    <NavLinks
      routes={routes}
      currentPath={currentPath}
      baseUrl={baseUrl}
    />
    <NavActions />
  </div>

  <MobileMenu
    routes={routes}
    currentPath={currentPath}
    baseUrl={baseUrl}
  />
</header>

<!-- Bundled scripts: Astro deduplicates these automatically -->
<script>
  import './scripts/theme.js';
  import './scripts/mobileMenu.js';
  import './scripts/smartNavbar.js';
</script>
