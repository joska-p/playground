---
import { Icon } from '@repo/ui/Icon';
// Social links, theme toggle button, and mobile burger button
---

<div class="flex items-center gap-2">
  <!-- Social links (desktop only) -->
  <div class="hidden items-center gap-2 md:flex">
    <a
      href="https://github.com/joska-p/playground"
      target="_blank"
      rel="noopener noreferrer"
      class="bg-muted/50 text-muted-foreground hover:border-primary/40 hover:bg-card hover:text-primary flex h-8 w-8 items-center justify-center rounded-full border-2 border-transparent transition-all duration-200 hover:shadow-[0_0_0_1px_color-mix(in_srgb,var(--primary)_50%,transparent),0_0_14px_-4px_color-mix(in_srgb,var(--primary)_60%,transparent)] focus-visible:ring-2 focus-visible:ring-[color-mix(in_srgb,var(--primary)_70%,var(--ring))] focus-visible:outline-none active:scale-[.97]"
      aria-label="GitHub"
    >
      <Icon
        name="github"
        className="h-3.5 w-3.5"
      />
    </a>

    <a
      href="https://gitlab.com/joska-p/playground"
      target="_blank"
      rel="noopener noreferrer"
      class="bg-muted/50 text-muted-foreground hover:border-primary/40 hover:bg-card hover:text-primary flex h-8 w-8 items-center justify-center rounded-full border-2 border-transparent transition-all duration-200 hover:shadow-[0_0_0_1px_color-mix(in_srgb,var(--primary)_50%,transparent),0_0_14px_-4px_color-mix(in_srgb,var(--primary)_60%,transparent)] focus-visible:ring-2 focus-visible:ring-[color-mix(in_srgb,var(--primary)_70%,var(--ring))] focus-visible:outline-none active:scale-[.97]"
      aria-label="GitLab"
    >
      <Icon
        name="gitlab"
        className="h-3.5 w-3.5"
      />
    </a>
  </div>

  <!-- Theme toggle -->
  <button
    id="theme-toggle"
    class="bg-muted/50 text-muted-foreground hover:border-primary/40 hover:bg-primary/10 hover:text-primary flex h-8 w-8 items-center justify-center rounded-full border-2 border-transparent transition-all duration-200 hover:shadow-[0_0_0_1px_color-mix(in_srgb,var(--primary)_50%,transparent),0_0_14px_-4px_color-mix(in_srgb,var(--primary)_60%,transparent)] focus-visible:ring-2 focus-visible:ring-[color-mix(in_srgb,var(--primary)_70%,var(--ring))] focus-visible:outline-none active:scale-[.97]"
    aria-label="Toggle theme"
  >
    <svg
      id="icon-sun"
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle
        cx="12"
        cy="12"
        r="4"
      ></circle>
      <path
        d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
        stroke-dasharray="none"
      ></path>
    </svg>
    <svg
      id="icon-moon"
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
    </svg>
  </button>

  <!-- Mobile burger button -->
  <button
    id="mobile-menu-toggle"
    aria-expanded="false"
    class="bg-muted/50 text-muted-foreground flex h-8 w-8 flex-col items-center justify-center gap-1.5 rounded-full transition-all duration-200 hover:shadow-[0_0_14px_-4px_var(--primary)] focus-visible:ring-2 focus-visible:ring-[color-mix(in_srgb,var(--primary)_70%,var(--ring))] focus-visible:outline-none active:scale-[.97] md:hidden"
    aria-label="Toggle menu"
  >
    <span
      class="h-0.5 w-4 rounded-full bg-current transition-transform duration-300"
      id="burger-top"
    ></span>
    <span
      class="h-0.5 w-4 rounded-full bg-current transition-all duration-300"
      id="burger-bottom"
    ></span>
  </button>

  <style>
    html[data-theme='dark'] #icon-moon {
      display: none;
    }
    html[data-theme='light'] #icon-sun {
      display: none;
    }

    #mobile-menu-toggle[aria-expanded='true'] #burger-top {
      transform: translateY(4px) rotate(45deg);
    }
    #mobile-menu-toggle[aria-expanded='true'] #burger-bottom {
      transform: translateY(-4px) rotate(-45deg);
    }
  </style>
</div>
