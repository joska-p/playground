---
type Route = {
  label: string;
  href: string;
};

type Props = {
  routes: Route[];
  currentPath: string;
  baseUrl: string;
};

const { routes, currentPath, baseUrl } = Astro.props;

const isActive = (href: string): boolean => {
  if (href === baseUrl) {
    return currentPath === href || currentPath === href + '/';
  }
  return currentPath.startsWith(href);
};
---

<nav
  class="hidden items-center gap-1.5 rounded-full p-1 md:flex"
  aria-label="Desktop navigation"
>
  {
    routes.map((route) => {
      const active = isActive(route.href);
      return (
        <a
          href={route.href}
          data-active={active ? '' : undefined}
          class="text-foreground-muted data-active:bg-primary data-active:text-primary-foreground data-active:hover:bg-primary/90 hover:text--glow-color) relative flex items-center justify-center rounded-full px-4 py-1.5 text-xs font-bold uppercase transition-all duration-200 hover:bg-[color-mix(in_oklch,var(--glow-color)_12%,transparent)] hover:shadow-[0_0_14px_-4px_var(--glow-color)] active:translate-y-0 active:scale-95 data-active:shadow-[0_0_20px_-3px_var(--primar),0_0_5px_-1px_var(--primary)]"
          aria-current={active ? 'page' : false}
        >
          {route.label}
        </a>
      );
    })
  }
</nav>
