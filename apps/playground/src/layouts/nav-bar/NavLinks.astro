---
interface Route {
  label: string;
  href: string;
}

interface Props {
  routes: Route[];
  currentPath: string;
  baseUrl: string;
}

const { routes, currentPath, baseUrl } = Astro.props;

const isActive = (href: string): boolean => {
  if (href === baseUrl) {
    return currentPath === href || currentPath === href + '/';
  }
  return currentPath.startsWith(href);
};
---

<nav
  class="hidden items-center gap-1.5 rounded-full p-1 md:flex"
  aria-label="Desktop navigation"
>
  {
    routes.map((route) => {
      const active = isActive(route.href);
      return (
        <a
          href={route.href}
          data-active={active ? '' : undefined}
          class="text-muted-foreground hover:bg-primary/10 hover:text-primary data-active:bg-primary data-active:text-primary-foreground data-active:hover:bg-primary/90 relative flex items-center justify-center rounded-full px-4 py-1.5 text-xs font-bold uppercase transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:scale-95 data-active:shadow-md"
          aria-current={active ? 'page' : undefined}
        >
          {route.label}
        </a>
      );
    })
  }
</nav>
