---
type Props = {
  href: string;
};
const { href } = Astro.props;
---

<a
  href={href}
  class="group text-foreground flex items-center gap-2 text-xs font-bold transition-all duration-300"
  aria-label="Playground home"
>
  <span
    class="relative flex h-6 w-6 items-center justify-center"
    aria-hidden="true"
  >
    <span
      class="group-hover:bg-accent absolute inset-0 animate-ping rounded-full border-2 border-(--glow-color) bg-(--glow-color) opacity-30"
    ></span>
    <span
      class="group-hover:bg-accent group-hover:before:bg-accent group-hover:after:bg-accent relative flex h-3 w-3 items-center justify-center rounded-full border-3 border-transparent bg-(--glow-color) shadow-[0_0_8px_1px_var(--glow-color)] transition-all duration-300 group-hover:scale-110 group-hover:shadow-[0_0_12px_2px_var(--accent)]"
    ></span>
  </span>
  PG_LAB
</a>

