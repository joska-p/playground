---
interface Props {
  baseUrl: string;
  title?: string;
}

const { baseUrl, title } = Astro.props;
---

<div class="flex items-center gap-2 font-mono font-bold tracking-tight">
  <a href={baseUrl} class="flex items-center gap-3 outline-none group">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 transition-transform group-hover:scale-110 duration-300" viewBox="0 0 2 2">
      <rect fill="#331436" x="0" y="0" width="1" height="1"></rect>
      <rect fill="#eb9961" x="1" y="0" width="1" height="1"></rect>
      <rect fill="#cb4f57" x="0" y="1" width="1" height="1"></rect>
      <rect fill="#7a1745" x="1" y="1" width="1" height="1"></rect>
    </svg>
    <span class="text-xl font-bold tracking-tight sm:text-2xl text-foreground">
      Playground
    </span>
  </a>
</div>
