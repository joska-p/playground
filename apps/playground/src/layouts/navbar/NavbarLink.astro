---
import { cn } from "../../lib/utils";

interface Props {
  href: string;
  isActive: boolean;
  className?: string;
}

const { href, isActive, className } = Astro.props;
---

<a
  href={href}
  class={cn(
    "group relative px-4 py-2 text-sm font-mono font-medium transition-all outline-none active:translate-y-[1px]",
    isActive
      ? "text-primary"
      : "text-foreground/70 hover:text-primary",
    className
  )}
>
  <span class="relative z-10 flex items-center gap-1">
    <span class={cn(
      "transition-all duration-300 ease-out inline-block",
      isActive ? "opacity-100 translate-x-0" : "opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0"
    )}>[</span>
    <slot />
    <span class={cn(
      "transition-all duration-300 ease-out inline-block",
      isActive ? "opacity-100 translate-x-0" : "opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0"
    )}>]</span>
  </span>
  <span class={cn(
    "absolute inset-0 rounded-md bg-primary/10 transition-all duration-300 opacity-0 scale-95",
    isActive ? "opacity-100 scale-100" : "group-hover:opacity-100 group-hover:scale-100"
  )} />
</a>
