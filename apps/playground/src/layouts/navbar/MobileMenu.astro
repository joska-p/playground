---
import { cn } from "../../lib/utils";

interface Route {
  text: string;
  url: string;
}

interface Props {
  routes: Route[];
  isActive: (url: string) => boolean;
}

const { routes, isActive } = Astro.props;
---

<div id="mobile-menu" class="absolute top-16 inset-x-0 z-50 p-4 md:hidden hidden animate-in slide-in-from-top-2 duration-200">
  <div class="rounded-xl border border-border bg-card p-4 shadow-2xl flex flex-col gap-2">
    {routes.map((route) => (
      <a
        href={route.url}
        class={cn(
          "group relative px-4 py-2 rounded-md text-sm font-mono font-medium transition-all outline-none active:translate-y-px",
          isActive(route.url)
            ? "bg-primary text-primary-foreground"
            : "text-foreground/70 hover:bg-primary/10 hover:text-primary"
        )}
      >
        {route.text}
      </a>
    ))}
    <div class="pt-2 border-t border-border mt-2">
      <button
        id="github-button"
        class="w-full inline-flex items-center justify-center px-4 py-2 rounded-md border border-border bg-transparent text-sm font-medium text-foreground hover:bg-primary/10 hover:text-primary transition-all active:translate-y-px cursor-pointer"
      >
        GitHub
      </button>
    </div>
  </div>
</div>
