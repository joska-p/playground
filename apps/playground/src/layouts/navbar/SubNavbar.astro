---
import { cn } from "../../lib/utils";
import type { Route } from "../../constants/routes";

interface Props {
  parentRoute: Route;
  currentPath: string;
}

const { parentRoute, currentPath } = Astro.props;
const children = parentRoute.children || [];

const isActive = (href: string) => currentPath === href || currentPath === href + "/";
---

<div class="w-full border-b border-border/50 bg-background/50 backdrop-blur-sm transition-all overflow-x-auto no-scrollbar">
  <div class="mx-auto flex h-10 max-w-7xl items-center gap-1 px-4 sm:px-6 lg:px-8">
    <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mr-2 select-none">
      {parentRoute.label} //
    </span>

    <nav class="flex items-center gap-1">
      {children.map((child) => (
        <a
          href={child.href}
          class={cn(
            "px-3 py-1 text-xs font-mono font-medium rounded-md transition-all whitespace-nowrap",
            isActive(child.href)
              ? "text-primary bg-primary/10"
              : "text-foreground/60 hover:text-primary hover:bg-primary/5"
          )}
        >
          {child.label}
        </a>
      ))}
    </nav>
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
