---
import NavbarBrand from "./NavbarBrand.astro";
import NavbarLink from "./NavbarLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import MobileMenuToggle from "./MobileMenuToggle.astro";
import MobileMenu from "./MobileMenu.astro";
import type { Route } from "../../constants/routes";

interface Props {
  routes: Route[];
  currentPath: string;
  title?: string;
  baseUrl: string;
}

const { routes, currentPath, title, baseUrl } = Astro.props;

// Helper to check active state
const isActive = (href: string) => currentPath === href || currentPath === href + "/";
---

<header class="w-full border-b border-border bg-background/80 backdrop-blur-md transition-all sticky top-0 z-50">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <NavbarBrand baseUrl={baseUrl} title={title} />

    <!-- Desktop Links -->
    <nav class="hidden md:flex items-center gap-2">
      {routes.map((route) => (
        <NavbarLink
          href={route.href}
          isActive={isActive(route.href)}
        >
          {route.label}
        </NavbarLink>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <MobileMenuToggle />
    </div>
  </div>

  <MobileMenu routes={routes} isActive={isActive} />
</header>

<script>
  const setupNavbar = () => {
    const themeToggle = document.getElementById('theme-toggle');
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIconOpen = document.getElementById('menu-icon-open');
    const menuIconClose = document.getElementById('menu-icon-close');
    const githubButton = document.getElementById('github-button');

    // Theme Toggle
    themeToggle?.addEventListener('click', () => {
      const root = document.documentElement;
      root.dataset.theme = root.dataset.theme === "dark" ? "light" : "dark";
    });

    // Mobile Menu Toggle
    const toggleMobileMenu = () => {
      const isOpen = mobileMenu?.classList.contains('hidden');
      if (isOpen) {
        mobileMenu?.classList.remove('hidden');
        menuIconOpen?.classList.add('hidden');
        menuIconClose?.classList.remove('hidden');
        mobileMenuToggle?.setAttribute('aria-expanded', 'true');
      } else {
        mobileMenu?.classList.add('hidden');
        menuIconOpen?.classList.remove('hidden');
        menuIconClose?.classList.add('hidden');
        mobileMenuToggle?.setAttribute('aria-expanded', 'false');
      }
    };

    mobileMenuToggle?.addEventListener('click', toggleMobileMenu);

    // Close menu when clicking links
    const mobileLinks = mobileMenu?.querySelectorAll('a');
    mobileLinks?.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        menuIconOpen?.classList.remove('hidden');
        menuIconClose?.classList.add('hidden');
        mobileMenuToggle?.setAttribute('aria-expanded', 'false');
      });
    });

    // GitHub Button
    githubButton?.addEventListener('click', () => {
      window.open('https://github.com/joska-p/playground', '_blank');
    });
  };

  // Initial setup
  setupNavbar();

  // Re-setup on view transitions
  document.addEventListener('astro:after-swap', setupNavbar);
</script>
