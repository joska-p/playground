---
import NavbarBrand from "./NavbarBrand.astro";
import NavbarLink from "./NavbarLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import UtilityLinks from "./UtilityLinks.astro";
import MobileMenuToggle from "./MobileMenuToggle.astro";
import MobileMenu from "./MobileMenu.astro";

interface Route {
  label: string;
  href: string;
  description?: string;
  isUtility?: boolean;
}

// Get base URL from Astro config (Vercel="/" or GitHub Pages="/playground")
const baseUrl = import.meta.env.BASE_URL || "/";

// Nav routes - normalized with baseUrl
const routes: Route[] = [
  {
    label: "Projects",
    href: `${baseUrl}projects/`,
    description: "Browse creative projects by category",
  },
  {
    label: "Docs",
    href: `${baseUrl}docs/`,
    description: "Documentation",
  },
  {
    label: "GitHub",
    href: "https://github.com/joska-p/playground",
    description: "View source on GitHub",
    isUtility: true,
  },
];

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// Helper to check active state
function isLinkActive(href: string) {
  return currentPath === href || currentPath === href + "/";
}

function isTopLevelActive(route: Route) {
  return isLinkActive(route.href);
}
---

<header class="w-full border-b border-border bg-background/80 backdrop-blur-md transition-all sticky top-0 z-50">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <NavbarBrand baseUrl={baseUrl} />

    <!-- Desktop Links -->
    <nav class="hidden md:flex items-center gap-2">
      {routes.filter((route) => !route.isUtility).map((route) => (
        <NavbarLink
          href={route.href}
          isActive={isTopLevelActive(route) || false}
          title={route.description ?? ""}
        >
          {route.label}
        </NavbarLink>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <UtilityLinks />
      <ThemeToggle />
      <MobileMenuToggle />
    </div>
  </div>

  <MobileMenu routes={routes} isActive={isLinkActive} />
</header>

<script>
  const setupNavbar = () => {
    const themeToggle = document.getElementById('theme-toggle');
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIconOpen = document.getElementById('menu-icon-open');
    const menuIconClose = document.getElementById('menu-icon-close');
    const githubButton = document.getElementById('github-button');

    // Theme Toggle
    themeToggle?.addEventListener('click', () => {
      const root = document.documentElement;
      root.dataset["theme"] = root.dataset["theme"] === "dark" ? "light" : "dark";
    });

    // Mobile Menu Toggle
    const toggleMobileMenu = () => {
      const isOpen = mobileMenu?.classList.contains('hidden');
      if (isOpen) {
        mobileMenu?.classList.remove('hidden');
        menuIconOpen?.classList.add('hidden');
        menuIconClose?.classList.remove('hidden');
        mobileMenuToggle?.setAttribute('aria-expanded', 'true');
      } else {
        mobileMenu?.classList.add('hidden');
        menuIconOpen?.classList.remove('hidden');
        menuIconClose?.classList.add('hidden');
        mobileMenuToggle?.setAttribute('aria-expanded', 'false');
      }
    };

    mobileMenuToggle?.addEventListener('click', toggleMobileMenu);

    // Close menu when clicking links
    const mobileLinks = mobileMenu?.querySelectorAll('a');
    mobileLinks?.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        menuIconOpen?.classList.remove('hidden');
        menuIconClose?.classList.add('hidden');
        mobileMenuToggle?.setAttribute('aria-expanded', 'false');
      });
    });

    // GitHub Button
    githubButton?.addEventListener('click', () => {
      window.open('https://github.com/joska-p/playground', '_blank');
    });
  };

  // Initial setup
  setupNavbar();

  // Re-setup on view transitions
  document.addEventListener('astro:after-swap', setupNavbar);
</script>