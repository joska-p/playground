---
/**
 * Navbar — self-contained. No sub-components needed.
 *
 * NOTE: You can delete header.astro entirely; base-layout.astro
 * now imports this file directly.
 */

const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL || "/";

type Route = {
  label: string;
  href: string;
};

const routes: Route[] = [
  { label: "~/home", href: baseUrl },
  { label: "~/projects", href: `${baseUrl}projects/` },
  { label: "~/docs", href: `${baseUrl}docs/` },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath === href + "/";
}
---

<header class="border-border bg-background/80 sticky top-0 z-50 w-full border-b backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Brand -->
    <a
      href={baseUrl}
      class="text-muted-foreground hover:text-foreground flex items-center gap-2.5 font-mono text-xs font-bold tracking-widest transition-colors"
      aria-label="Playground home"
    >
      <span class="nav-pulse bg-primary h-2 w-2 rounded-full"></span>
      PG_LAB
    </a>

    <!-- Desktop tab strip -->
    <nav
      class="border-border bg-card hidden items-center gap-1 rounded-lg border px-1 py-1 md:flex"
      aria-label="Main navigation"
    >
      {
        routes.map((route) => (
          <a
            href={route.href}
            class:list={[
              "rounded-md px-4 py-1.5 font-mono text-[11px] tracking-wide transition-all",
              isActive(route.href)
                ? "bg-primary text-primary-foreground font-bold"
                : "text-muted-foreground hover:text-foreground hover:bg-muted",
            ]}
            aria-current={isActive(route.href) ? "page" : undefined}
          >
            {route.label}
          </a>
        ))
      }
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <!-- GitLab -->
      <a
        href="https://gitlab.com/joska-p/playground"
        target="_blank"
        rel="noopener noreferrer"
        class="border-border bg-card text-muted-foreground hover:text-foreground hover:border-foreground flex h-8 w-8 cursor-pointer items-center justify-center rounded-sm border transition-all"
        aria-label="View source on GitLab"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="m22 13.29-3.33-10a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18l-2.26 6.67H8.32L6.06 3.27a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18L2 13.29a.74.74 0 0 0 .27.83L12 21l9.73-6.88a.74.74 0 0 0 .27-.83Z"
          >
          </path>
        </svg>
      </a>
      <!-- GitHub -->
      <a
        href="https://github.com/joska-p/playground"
        target="_blank"
        rel="noopener noreferrer"
        class="border-border bg-card text-muted-foreground hover:text-foreground hover:border-foreground flex h-8 w-8 cursor-pointer items-center justify-center rounded-sm border transition-all"
        aria-label="View source on GitHub"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
          ></path>
        </svg>
      </a>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="border-border bg-card text-muted-foreground hover:text-foreground hover:border-foreground flex h-8 w-8 cursor-pointer items-center justify-center rounded-sm border transition-all"
        aria-label="Toggle theme"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg
          id="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle><path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg
          id="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
        </svg>
      </button>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-toggle"
        class="border-border bg-card text-muted-foreground hover:text-foreground hover:border-foreground flex h-8 w-8 cursor-pointer items-center justify-center rounded-sm border transition-all md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          id="menu-icon-open"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"
          ></line><line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
        <svg
          id="menu-icon-close"
          class="hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="border-border bg-background/95 hidden border-t backdrop-blur-md md:hidden"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <ul class="mx-auto max-w-7xl px-4 py-2 sm:px-6">
      {
        routes.map((route) => (
          <li>
            <a
              href={route.href}
              class:list={[
                "border-border flex items-center gap-3 border-b py-3 font-mono text-xs tracking-wide transition-colors last:border-0",
                isActive(route.href)
                  ? "text-primary font-bold"
                  : "text-muted-foreground hover:text-foreground",
              ]}
              aria-current={isActive(route.href) ? "page" : undefined}
            >
              <span
                class:list={[
                  "h-1.5 w-1.5 rounded-full",
                  isActive(route.href) ? "bg-primary" : "bg-border",
                ]}
              />
              {route.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<style>
  .nav-pulse {
    animation: nav-pulse 2.4s ease-in-out infinite;
  }
  @keyframes nav-pulse {
    0%,
    75%,
    100% {
      opacity: 1;
    }
    87% {
      opacity: 0.15;
    }
  }

  /* Show correct sun/moon icon based on current theme */
  html[data-theme="dark"] #icon-moon {
    display: none;
  }
  html[data-theme="light"] #icon-sun {
    display: none;
  }
</style>

<script>
  function setupNavbar() {
    const themeToggle = document.getElementById("theme-toggle");
    const mobileToggle = document.getElementById("mobile-menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuIconOpen = document.getElementById("menu-icon-open");
    const menuIconClose = document.getElementById("menu-icon-close");

    // ── Theme ──────────────────────────────────────────
    themeToggle?.addEventListener("click", () => {
      const root = document.documentElement;
      root.dataset.theme = root.dataset.theme === "dark" ? "light" : "dark";
    });

    // ── Mobile menu ────────────────────────────────────
    function openMenu() {
      mobileMenu?.classList.remove("hidden");
      menuIconOpen?.classList.add("hidden");
      menuIconClose?.classList.remove("hidden");
      mobileToggle?.setAttribute("aria-expanded", "true");
    }

    function closeMenu() {
      mobileMenu?.classList.add("hidden");
      menuIconOpen?.classList.remove("hidden");
      menuIconClose?.classList.add("hidden");
      mobileToggle?.setAttribute("aria-expanded", "false");
    }

    mobileToggle?.addEventListener("click", () => {
      mobileMenu?.classList.contains("hidden") ? openMenu() : closeMenu();
    });

    // Close on link click
    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });
  }

  setupNavbar();
  document.addEventListener("astro:after-swap", setupNavbar);
</script>
