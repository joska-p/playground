---
import Navbar from './nav-bar/NavBar.astro';
import { Font } from 'astro:assets';
import '../styles/styles.css';
import BackgroundCanvas from '../components/ui/features/BackgroundCanvas.astro';
import { EdgeFieldMask } from '@repo/ui/widgets';

const baseUrl = import.meta.env.BASE_URL || '';

const {
  title,
  description = 'A creative and technical playground: generative art, mathematics, data visualization, and frontend tutorials.',
  keywords = 'Generative Art, D3.js, Canvas, Astro, Tailwind, TypeScript, Mathematics, Frontend',
  ogImage
} = Astro.props;

const siteTitle = title ? `${title} — Playground` : 'Playground — Generative Art & Dev Notes';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage || `${baseUrl}default-og-image.jpg`, Astro.site).href;

const { className } = Astro.props;
---

<!-- Theme must be is:inline to run before first paint (prevents flash) -->
<script is:inline>
  const getThemePreference = () => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  };
  const applyTheme = (theme) => {
    const root = document.documentElement;
    root.classList.toggle('dark', theme === 'dark');
    root.dataset.theme = theme;
    localStorage.setItem('theme', theme);
  };
  applyTheme(getThemePreference());
</script>

<html
  lang="en"
  data-theme="dark"
>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width"
    />
    <meta
      name="theme-color"
      content="#000000"
      media="(prefers-color-scheme: dark)"
    />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      href={`${baseUrl}favicon.ico`}
      sizes="32x32"
    />
    <link
      rel="icon"
      href={`${baseUrl}favicon-16x16.png`}
      type="image/png"
      sizes="16x16"
    />
    <link
      rel="icon"
      href={`${baseUrl}favicon-32x32.png`}
      type="image/png"
      sizes="32x32"
    />
    <link
      rel="apple-touch-icon"
      href={`${baseUrl}apple-touch-icon.png`}
      sizes="180x180"
    />
    <link
      rel="manifest"
      href={`${baseUrl}site.webmanifest`}
    />
    <link
      rel="sitemap"
      href={`${baseUrl}sitemap-index.xml`}
    />
    <meta
      name="robots"
      content="noindex"
    />
    <meta
      name="generator"
      content={Astro.generator}
    />

    <title>{siteTitle}</title>
    <meta
      name="description"
      content={description}
    />
    <meta
      name="keywords"
      content={keywords}
    />
    <link
      rel="canonical"
      href={canonicalURL}
    />
    <meta
      name="author"
      content="joska"
    />

    <meta
      property="og:type"
      content="website"
    />
    <meta
      property="og:url"
      content={canonicalURL}
    />
    <meta
      property="og:title"
      content={siteTitle}
    />
    <meta
      property="og:description"
      content={description}
    />
    <meta
      property="og:image"
      content={ogImageURL}
    />
    <meta
      property="og:image:width"
      content="1200"
    />
    <meta
      property="og:image:height"
      content="630"
    />
    <meta
      property="og:image:alt"
      content={description}
    />
    <meta
      property="og:locale"
      content="en_US"
    />

    <meta
      name="twitter:card"
      content="summary_large_image"
    />
    <meta
      name="twitter:url"
      content={canonicalURL}
    />
    <meta
      name="twitter:title"
      content={siteTitle}
    />
    <meta
      name="twitter:description"
      content={description}
    />
    <meta
      name="twitter:image"
      content={ogImageURL}
    />

    <Font cssVariable="--font-jetbrains-mono" />
  </head>
  <body
    id="home"
    class="bg-background text-foreground relative min-h-screen antialiased"
  >
    <EdgeFieldMask />
    <BackgroundCanvas />
    <Navbar />
    <main
      class:list={className}
      id="main"
    >
      <slot />
    </main>
  </body>
</html>
