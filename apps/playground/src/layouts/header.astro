---
import Navbar from "./navbar/Navbar.astro";
import { routes } from "../constants/routes";

interface Props {
  title?: string;
}

const baseUrl = import.meta.env.BASE_URL;
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<Navbar
  routes={routes}
  currentPath={currentPath}
  title={title}
  baseUrl={baseUrl}
/>
