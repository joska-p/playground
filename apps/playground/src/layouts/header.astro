---
import { SiteNavbar } from "./SiteNavbar";
import { routes } from "../constants/routes";

interface Props {
  title?: string;
}

const baseUrl = import.meta.env.BASE_URL;
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<SiteNavbar
  client:load
  routes={routes}
  currentPath={currentPath}
  title={title}
  baseUrl={baseUrl}
/>
