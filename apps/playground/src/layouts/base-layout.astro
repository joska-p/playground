---
import Navbar from "./navbar.astro";
import Footer from "./footer.astro";
import { Font } from "astro:assets";
import "../styles/styles.css";

const baseUrl = import.meta.env.BASE_URL || "";

const { title, katex = false } = Astro.props;
const siteTitle = title ? `${title} — Playground` : "Playground";
---

<html lang="en" data-theme="dark">
  <head>
    <Font cssVariable="--font-jetbrains-mono" />
    {katex && <link rel="stylesheet" href={`${baseUrl}katex.css`} />}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href={`${baseUrl}favicon.svg`} />
    <link rel="sitemap" href={`${baseUrl}/sitemap-index.xml`} />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>
  </head>
  <body
    class="bg-background text-foreground grid min-h-dvh grid-cols-1 grid-rows-[auto_1fr] antialiased"
  >
    <Navbar />
    <main class="flex flex-col overflow-hidden">
      <slot />
    </main>

    <Footer>
      <span slot="default">Crafted with creativity.</span>
    </Footer>
  </body>
</html>
