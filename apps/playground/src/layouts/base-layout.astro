---
import Navbar from "./navbar/Navbar.astro";
import { Font } from "astro:assets";
import "../styles/styles.css";

const baseUrl = import.meta.env.BASE_URL || "";

type Props = { title?: string };
const { title } = Astro.props;
const siteTitle = title ? `${title} — Playground` : "Playground";
---

<script is:inline type="module">
  const getTheme = () => {
    try {
      return (
        localStorage.getItem("theme") ??
        (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
      );
    } catch {
      return "dark";
    }
  };
  document.documentElement.dataset.theme = getTheme();

  if (typeof MutationObserver !== "undefined") {
    new MutationObserver(() => {
      try {
        localStorage.setItem("theme", document.documentElement.dataset.theme ?? "dark");
      } catch {}
    }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
  }
</script>

<html lang="en" data-theme="dark">
  <head>
    <Font cssVariable="--font-jetbrains-mono" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href={`${baseUrl}favicon.svg`} />
    <link rel="sitemap" href={`${baseUrl}/sitemap-index.xml`} />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>
  </head>
  <body
    class="bg-background text-foreground prose prose-gruvbox prose-a:no-underline grid min-h-dvh max-w-none grid-cols-1 grid-rows-[auto_1fr] antialiased"
  >
    <Navbar />
    <main class="flex flex-col overflow-hidden">
      <slot />
    </main>
  </body>
</html>
