---
import BaseLayout from "../layout.astro";
import ExperimentCard from "../../components/ui/experiment-card/index.astro";

interface Project {
  label: string;
  href: string;
  description: string;
  icon?: any;
  iconBgColor?: string;
  iconColor?: string;
  tags?: { label: string; color?: string }[];
}

interface Props {
  title: string;
  description?: string;
  projects: Project[];
}

const { title, description, projects = [] } = Astro.props;
---

<BaseLayout title={title}>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-foreground">{title}</h1>
      {description && <p class="mt-2 text-lg text-muted-foreground">{description}</p>}
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <ExperimentCard
          href={project.href}
          title={project.label}
          description={project.description}
          icon={project.icon}
          iconBgColor={project.iconBgColor ?? ""}
          iconColor={project.iconColor ?? ""}
          tags={project.tags ?? []}
        />
      ))}
    </div>
  </div>
</BaseLayout>