---
const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL || "/";

type Route = { label: string; href: string };
const routes: Route[] = [
  { label: "./home", href: baseUrl },
  { label: "./projects", href: `${baseUrl}projects/` },
  { label: "./notebook", href: `${baseUrl}notebook/` },
  { label: "./docs", href: `${baseUrl}docs/` },
];

function isActive(href: string): boolean {
  if (href === baseUrl) {
    return currentPath === href || currentPath === href + "/";
  }
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 w-full transition-all duration-500 md:top-4 md:px-6">
  <div
    class="border-border/50 bg-background/90 md:hover:border-primary/30 relative z-30 mx-auto flex h-14 max-w-7xl items-center justify-between border-b px-4 shadow-sm backdrop-blur-md transition-colors md:rounded-2xl md:border-2"
  >
    <div class="flex items-center">
      <a
        href={baseUrl}
        class="group text-foreground hover:text-primary flex items-center gap-2 font-mono text-xs font-bold tracking-[0.25em] transition-all duration-300"
        aria-label="Playground home"
      >
        <span class="relative flex h-2.5 w-2.5" aria-hidden="true">
          <span
            class="bg-primary group-hover:bg-accent absolute inset-0 animate-ping rounded-full opacity-60"
          ></span>
          <span
            class="bg-primary group-hover:bg-accent relative h-2.5 w-2.5 rounded-full transition-colors group-hover:scale-110"
          ></span>
        </span>
        PG_LAB
      </a>
    </div>

    <nav
      class="hidden items-center gap-1.5 rounded-full p-1 md:flex"
      aria-label="Desktop navigation"
    >
      {
        routes.map((route) => {
          const active = isActive(route.href);
          return (
            <a
              href={route.href}
              data-active={active ? "" : undefined}
              class="text-muted-foreground hover:bg-primary/10 hover:text-primary data-active:bg-primary data-active:text-primary-foreground data-active:hover:bg-primary/90 relative flex items-center justify-center rounded-full px-4 py-1.5 font-mono text-[10px] font-bold tracking-widest uppercase transition-all duration-200 hover:-translate-y-0.5 active:translate-y-0 active:scale-95 data-active:shadow-md"
              aria-current={active ? "page" : undefined}
            >
              {route.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <div class="hidden items-center gap-2 md:flex">
        <a
          href="https://gitlab.com/joska-p/playground"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-muted/50 text-muted-foreground hover:border-primary/40 hover:bg-card hover:text-primary flex h-8 w-8 items-center justify-center rounded-full border-2 border-transparent transition-all duration-300 hover:-translate-y-0.5 hover:scale-110 hover:rotate-12 active:scale-95"
          aria-label="GitLab"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><path
              d="m22 13.29-3.33-10a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18l-2.26 6.67H8.32L6.06 3.27a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18L2 13.29a.74.74 0 0 0 .27.83L12 21l9.73-6.88a.74.74 0 0 0 .27-.83Z"
            ></path></svg
          >
        </a>
        <a
          href="https://github.com/joska-p/playground"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-muted/50 text-muted-foreground hover:border-primary/40 hover:bg-card hover:text-primary flex h-8 w-8 items-center justify-center rounded-full border-2 border-transparent transition-all duration-300 hover:-translate-y-0.5 hover:scale-110 hover:-rotate-12 active:scale-95"
          aria-label="GitHub"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            ><path
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
            ></path></svg
          >
        </a>
      </div>

      <button
        id="theme-toggle"
        class="bg-muted/50 text-muted-foreground hover:border-primary/40 hover:text-accent flex h-8 w-8 items-center justify-center rounded-full border-2 border-transparent transition-all duration-500 hover:scale-110 hover:rotate-180 active:scale-95"
        aria-label="Toggle theme"
      >
        <svg
          id="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="4"></circle><path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
            stroke-dasharray="none"></path></svg
        >
        <svg
          id="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path></svg
        >
      </button>

      <button
        id="mobile-menu-toggle"
        aria-expanded="false"
        class="bg-muted/50 text-muted-foreground flex h-8 w-8 flex-col items-center justify-center gap-1.5 rounded-full transition-all active:scale-95 md:hidden"
        aria-label="Toggle menu"
      >
        <span
          class="h-0.5 w-4 rounded-full bg-current transition-transform duration-300"
          id="burger-top"></span>
        <span
          class="h-0.5 w-4 rounded-full bg-current transition-all duration-300"
          id="burger-bottom"></span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    data-open="false"
    class="border-border/50 bg-background/95 pointer-events-none absolute inset-x-0 top-full -z-10 flex origin-top -translate-y-4 flex-col gap-4 border-b px-6 py-8 opacity-0 shadow-2xl backdrop-blur-xl transition-all duration-300 data-[open=true]:pointer-events-auto data-[open=true]:translate-y-0 data-[open=true]:opacity-100 md:hidden"
  >
    <nav class="flex flex-col gap-2" aria-label="Mobile navigation">
      {
        routes.map((route) => {
          const active = isActive(route.href);
          return (
            <a
              href={route.href}
              data-active={active ? "" : undefined}
              class="text-muted-foreground data-active:bg-primary/10 data-active:text-primary flex items-center rounded-xl px-4 py-3 font-mono text-sm font-bold tracking-widest uppercase transition-all active:scale-95"
              aria-current={active ? "page" : undefined}
            >
              {route.label}
            </a>
          );
        })
      }
    </nav>
    <div class="border-border/50 mt-4 flex gap-4 border-t pt-4">
      <a
        href="https://gitlab.com/joska-p/playground"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-primary flex items-center gap-2 font-mono text-xs"
        >GitLab</a
      >
      <a
        href="https://github.com/joska-p/playground"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-primary flex items-center gap-2 font-mono text-xs"
        >GitHub</a
      >
    </div>
  </div>
</header>

<style>
  html[data-theme="dark"] #icon-moon {
    display: none;
  }
  html[data-theme="light"] #icon-sun {
    display: none;
  }

  /* Animated Hamburger to X */
  #mobile-menu-toggle[aria-expanded="true"] #burger-top {
    transform: translateY(4px) rotate(45deg);
  }
  #mobile-menu-toggle[aria-expanded="true"] #burger-bottom {
    transform: translateY(-4px) rotate(-45deg);
  }
</style>

<script is:inline>
  const getThemePreference = () => {
    if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
      return localStorage.getItem("theme");
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  };

  const applyTheme = (theme) => {
    const root = document.documentElement;
    if (theme === "dark") {
      root.classList.add("dark");
      root.dataset.theme = "dark";
    } else {
      root.classList.remove("dark");
      root.dataset.theme = "light";
    }
    localStorage.setItem("theme", theme);
  };

  applyTheme(getThemePreference());

  const setupInteractions = () => {
    // Theme Toggle
    const themeToggle = document.getElementById("theme-toggle");
    if (themeToggle && !themeToggle.dataset.bound) {
      themeToggle.dataset.bound = "true";
      themeToggle.addEventListener("click", () => {
        const isDark = document.documentElement.dataset.theme === "dark";
        applyTheme(isDark ? "light" : "dark");
      });
    }

    // Mobile Menu Toggle
    const mobileToggle = document.getElementById("mobile-menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    if (mobileToggle && mobileMenu && !mobileToggle.dataset.bound) {
      mobileToggle.dataset.bound = "true"; // Prevent duplicate listeners on Astro nav

      const closeMenu = () => {
        mobileToggle.setAttribute("aria-expanded", "false");
        mobileMenu.setAttribute("data-open", "false");
      };

      mobileToggle.addEventListener("click", () => {
        const isExpanded = mobileToggle.getAttribute("aria-expanded") === "true";
        mobileToggle.setAttribute("aria-expanded", String(!isExpanded));
        mobileMenu.setAttribute("data-open", String(!isExpanded));
      });

      // Close menu when a link inside it is clicked
      mobileMenu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMenu);
      });
    }
  };

  setupInteractions();
  document.addEventListener("astro:after-swap", setupInteractions);
  document.addEventListener("astro:page-load", setupInteractions);
</script>
