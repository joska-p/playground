---
import Layout from "./layout.astro";
import CardLink from "../components/ui/card-link/index.astro";

interface Props {
  title: string;
  description: string;
  projects: {
    label: string;
    href: string;
    description: string;
  }[];
}

const { title, description, projects } = Astro.props;
---

<Layout title={title}>
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-foreground">{title}</h1>
      {description && <p class="mt-2 text-lg text-muted-foreground">{description}</p>}
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <CardLink
          href={project.href}
          title={project.label}
          description={project.description}
        />
      ))}
    </div>
  </div>
</Layout>