---
interface Props {
  class?: string;
  ariaLabel?: string;
  title?: string;
}

const {
  class: className = "",
  ariaLabel = "Étape 03 — ℚ : Les Nombres Rationnels",
  title: titleProp = "Étape 03 — ℚ : Les Nombres Rationnels",
} = Astro.props;
---

<figure class:list={["not-prose", className]} aria-label={ariaLabel}>
  <svg
    viewBox="0 0 720 240"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    class="h-auto w-full"
    style="max-width: 720px;"
  >
    <title>{titleProp}</title>
    <defs>
      <linearGradient id="s3-bg" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color: var(--card); stop-opacity: 1"></stop>
        <stop offset="100%" style="stop-color: var(--background); stop-opacity: 1"></stop>
      </linearGradient>
    </defs>

    <rect width="720" height="240" fill="url(#s3-bg)" rx="10"></rect>
    <rect
      width="720"
      height="240"
      fill="none"
      stroke="var(--border)"
      stroke-width="1"
      rx="10"
      opacity="0.5"></rect>

    <!-- Badge -->
    <rect x="24" y="20" width="80" height="22" rx="11" fill="var(--secondary)" opacity="0.15"
    ></rect>
    <text
      x="64"
      y="35"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)"
      font-weight="600">Étape 03</text
    >

    <!-- Title -->
    <text
      x="24"
      y="72"
      font-size="20"
      font-weight="700"
      font-family="var(--font-sans)"
      fill="var(--foreground)">ℚ — Les Rationnels</text
    >
    <text x="24" y="92" font-size="12" font-family="var(--font-sans)" fill="var(--muted-foreground)"
      >La droite devient dense — une infinité entre deux entiers.</text
    >

    <!-- Dense tick marks representing rationals -->
    {
      Array.from({ length: 120 }, (_, i) => {
        const x = 40 + i * 5.3;
        const isInteger = i % 20 === 0;
        const isHalf = i % 10 === 5;
        return (
          <line
            x1={x}
            y1={isInteger ? 140 : isHalf ? 147 : 152}
            x2={x}
            y2="162"
            stroke={
              isInteger ? "var(--secondary)" : isHalf ? "var(--muted-foreground)" : "var(--border)"
            }
            stroke-width={isInteger ? 2 : isHalf ? 1.2 : 0.6}
            opacity={isInteger ? 0.9 : isHalf ? 0.6 : 0.3}
          />
        );
      })
    }

    <!-- Main line -->
    <line x1="36" y1="157" x2="684" y2="157" stroke="var(--border)" stroke-width="1" opacity="0.4"
    ></line>

    <!-- Arrow right -->
    <polygon points="688,157 678,152 678,162" fill="var(--secondary)" opacity="0.6"></polygon>

    <!-- Integer labels: 0, 1, 2 -->
    <text
      x="40"
      y="180"
      text-anchor="middle"
      font-size="13"
      font-family="var(--font-mono)"
      fill="var(--foreground)">0</text
    >
    <text
      x="146"
      y="180"
      text-anchor="middle"
      font-size="13"
      font-family="var(--font-mono)"
      fill="var(--foreground)">1</text
    >
    <text
      x="252"
      y="180"
      text-anchor="middle"
      font-size="13"
      font-family="var(--font-mono)"
      fill="var(--foreground)">2</text
    >
    <text
      x="358"
      y="180"
      text-anchor="middle"
      font-size="13"
      font-family="var(--font-mono)"
      fill="var(--foreground)">3</text
    >

    <!-- Key fractions between 0 and 1 -->
    <circle cx="73" cy="157" r="3" fill="var(--secondary)" opacity="0.7"></circle>
    <text
      x="73"
      y="200"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)">1/3</text
    >
    <line
      x1="73"
      y1="183"
      x2="73"
      y2="195"
      stroke="var(--secondary)"
      stroke-width="0.8"
      opacity="0.5"
      stroke-dasharray="2 2"></line>

    <circle cx="93" cy="157" r="3" fill="var(--secondary)" opacity="0.7"></circle>
    <text
      x="93"
      y="200"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)">5/12</text
    >
    <line
      x1="93"
      y1="183"
      x2="93"
      y2="195"
      stroke="var(--secondary)"
      stroke-width="0.8"
      opacity="0.5"
      stroke-dasharray="2 2"></line>

    <circle cx="103" cy="157" r="3" fill="var(--secondary)" opacity="0.7"></circle>
    <text
      x="103"
      y="213"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--muted-foreground)"
      opacity="0.7">11/24</text
    >
    <line
      x1="103"
      y1="183"
      x2="103"
      y2="208"
      stroke="var(--muted-foreground)"
      stroke-width="0.8"
      opacity="0.4"
      stroke-dasharray="2 2"></line>

    <circle cx="119" cy="157" r="3" fill="var(--secondary)" opacity="0.7"></circle>
    <text
      x="119"
      y="200"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)">1/2</text
    >
    <line
      x1="119"
      y1="183"
      x2="119"
      y2="195"
      stroke="var(--secondary)"
      stroke-width="0.8"
      opacity="0.5"
      stroke-dasharray="2 2"></line>

    <!-- a/b formula badge -->
    <rect
      x="570"
      y="104"
      width="108"
      height="42"
      rx="8"
      fill="var(--card)"
      stroke="var(--border)"
      stroke-width="1"></rect>
    <text
      x="624"
      y="122"
      text-anchor="middle"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--muted-foreground)">tout rationnel</text
    >
    <text
      x="624"
      y="140"
      text-anchor="middle"
      font-size="15"
      font-family="var(--font-mono)"
      fill="var(--foreground)"
      font-weight="600">a / b</text
    >

    <!-- Key insight -->
    <rect x="24" y="200" width="672" height="28" rx="6" fill="var(--muted)" opacity="0.5"></rect>
    <text
      x="360"
      y="218"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-sans)"
      fill="var(--muted-foreground)">ℚ est clos pour la division — 1 ÷ 2 a enfin une réponse.</text
    >
  </svg>
</figure>
