<div class="not-prose my-16 flex flex-col items-center justify-center py-16 select-none">
  <div class="relative flex h-40 w-40 items-center justify-center">
    <div class="ring0 ring1"></div>
    <div class="ring0 ring2"></div>
    <div class="point"></div>
  </div>
</div>

<style>
  .ring0 {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    border: 1px solid var(--color-accent, oklch(75% 0.18 85deg));
    opacity: 0;
  }
  .ring1 {
    animation: ripple 4s ease-out 0s infinite;
  }
  .ring2 {
    animation: ripple 4s ease-out 1.8s infinite;
  }

  .point {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 9999px;
    background-color: var(--color-accent, oklch(75% 0.18 85deg));
    box-shadow: 0 0 14px 4px
      color-mix(in oklch, var(--color-accent, oklch(75% 0.18 85deg)) 50%, transparent);
    animation: breathe 4s ease-in-out infinite;
  }

  @keyframes ripple {
    0% {
      transform: scale(0.2);
      opacity: 0.5;
    }
    70% {
      opacity: 0.08;
    }
    100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }

  @keyframes breathe {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(0.9);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }
</style>
