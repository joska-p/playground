---
// EulerFormula.astro
// Visualizes the ultimate unity of Euler's Identity on the unit circle.
const {
  realLabel = "Real",
  imagLabel = "Imag",
  description = 'Traveling a distance of <span class="text-accent font-bold">π</span> along the continuous rotation field of <span class="text-accent font-bold">e<sup>iθ</sup></span> lands perfectly on <span class="text-accent font-bold">-1</span>. Adding <span class="text-secondary font-bold">1</span> pulls the universe back to the void (<span class="text-secondary font-bold">0</span>).',
} = Astro.props;
---

<div
  class="not-prose bg-secondary/10 border-secondary/20 my-12 flex flex-col items-center justify-center rounded-xl border p-8"
>
  <div
    class="bg-bg border-secondary/10 relative aspect-square w-full max-w-md rounded-lg border p-4"
  >
    <svg viewBox="0 0 200 200" class="h-full w-full overflow-visible">
      <line x1="0" y1="100" x2="200" y2="100" class="stroke-secondary/20 stroke-1"></line>
      <line x1="100" y1="0" x2="100" y2="200" class="stroke-secondary/20 stroke-1"></line>

      <circle
        cx="100"
        cy="100"
        r="60"
        class="stroke-secondary/20 fill-none stroke-1"
        stroke-dasharray="4,4"></circle>

      <text x="185" y="92" class="fill-secondary/50 font-mono text-[10px] tracking-wider"
        >{realLabel}</text
      >
      <text x="106" y="15" class="fill-secondary/50 font-mono text-[10px] tracking-wider"
        >{imagLabel}</text
      >

      <circle cx="100" cy="100" r="3.5" class="fill-secondary"></circle>
      <text x="106" y="112" class="fill-secondary font-mono text-[10px]">0</text>

      <circle cx="160" cy="100" r="3" class="fill-secondary/60"></circle>
      <text x="165" y="112" class="fill-secondary/60 font-mono text-xs">1</text>

      <circle cx="100" cy="40" r="3" class="fill-secondary/40"></circle>
      <text x="106" y="48" class="fill-secondary/40 font-mono text-xs">i</text>

      <path d="M 160 100 A 60 60 0 0 0 40 100" class="stroke-accent fill-none stroke-[3px]"></path>
      <text x="75" y="28" class="fill-accent bg-bg font-mono text-xs font-bold tracking-widest"
        >e^(iπ)</text
      >

      <circle cx="40" cy="100" r="5" class="fill-accent animate-pulse"></circle>
      <text x="22" y="112" class="fill-accent font-mono text-xs font-bold">-1</text>

      <polygon points="40,100 48,96 48,104" class="fill-accent"></polygon>

      <path d="M 40 100 L 92 100" class="stroke-secondary fill-none stroke-2"></path>
      <polygon points="96,100 88,97 88,103" class="fill-secondary"></polygon>
      <text x="60" y="92" class="fill-secondary font-mono text-xs font-bold">+ 1</text>
    </svg>
  </div>

  <p
    class="text-secondary mt-6 max-w-sm text-center text-sm tracking-widest italic"
    set:html={description}
  />
</div>
