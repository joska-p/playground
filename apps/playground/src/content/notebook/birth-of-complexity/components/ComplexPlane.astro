---
// complex-plane.astro
---

<div class="not-prose my-16 flex flex-col items-center justify-center py-4 select-none">
  <div class="plane-wrap">
    <svg
      viewBox="0 0 200 200"
      xmlns="http://www.w3.org/2000/svg"
      class="plane-svg"
      aria-hidden="true"
    >
      <!-- Axes — near-invisible hairlines -->
      <line x1="10" y1="100" x2="190" y2="100" class="axis"></line>
      <line x1="100" y1="10" x2="100" y2="190" class="axis"></line>

      <!-- Axis arrowheads -->
      <polygon points="190,98 184,101 184,99" class="arrowhead"></polygon>
      <polygon points="100,10 98,16 102,16" class="arrowhead"></polygon>

      <!-- Unit circle — very faint dashed -->
      <circle cx="100" cy="100" r="60" class="unit-circle" stroke-dasharray="3 5"></circle>

      <!-- Cardinal points — secondary, low opacity -->
      <circle cx="160" cy="100" r="2.5" class="pt-secondary"></circle>
      <circle cx="40" cy="100" r="2.5" class="pt-secondary" style="opacity:0.4"></circle>
      <circle cx="100" cy="160" r="2.5" class="pt-secondary" style="opacity:0.25"></circle>

      <!-- Point i — accent -->
      <circle cx="100" cy="40" r="3" class="pt-accent"></circle>

      <!-- Arc from 1 to i (quarter, counterclockwise) — draws itself in -->
      <!-- M 160 100 A 60 60 0 0 0 100 40  → length ≈ 94.25 -->
      <path
        d="M 160 100 A 60 60 0 0 0 100 40"
        class="arc"
        stroke-dasharray="95"
        stroke-dashoffset="95"
        fill="none"></path>

      <!-- Arrowhead at i end of arc -->
      <polygon points="100,38 96,46 104,46" class="arc-arrow" transform="rotate(-42 100 40)"
      ></polygon>

      <!-- Labels -->
      <text x="167" y="107" class="lbl lbl-secondary">1</text>
      <text x="107" y="37" class="lbl lbl-accent">i</text>
      <text x="26" y="107" class="lbl lbl-secondary" style="opacity:0.4">−1</text>
      <text x="107" y="175" class="lbl lbl-secondary" style="opacity:0.25">−i</text>

      <!-- Axis labels -->
      <text x="177" y="94" class="axis-lbl">ℝ</text>
      <text x="105" y="18" class="axis-lbl">𝕚</text>
    </svg>
  </div>
</div>

<style>
  .plane-wrap {
    width: 100%;
    max-width: 18rem;
  }
  .plane-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .axis {
    stroke: var(--color-secondary, oklch(65% 0.04 240deg));
    stroke-width: 0.5;
    opacity: 0.2;
  }
  .arrowhead {
    fill: var(--color-secondary, oklch(65% 0.04 240deg));
    opacity: 0.2;
  }
  .unit-circle {
    stroke: var(--color-secondary, oklch(65% 0.04 240deg));
    stroke-width: 0.5;
    fill: none;
    opacity: 0.12;
  }

  .pt-secondary {
    fill: var(--color-secondary, oklch(65% 0.04 240deg));
    opacity: 0.5;
  }
  .pt-accent {
    fill: var(--color-accent, oklch(75% 0.18 85deg));
    opacity: 0;
    animation: fadeIn 0.6s ease-out 2.4s forwards;
    filter: drop-shadow(
      0 0 4px color-mix(in oklch, var(--color-accent, oklch(75% 0.18 85deg)) 60%, transparent)
    );
  }

  .arc {
    stroke: var(--color-accent, oklch(75% 0.18 85deg));
    stroke-width: 1.2;
    opacity: 0.8;
    animation: drawArc 2.2s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
  }
  .arc-arrow {
    fill: var(--color-accent, oklch(75% 0.18 85deg));
    opacity: 0;
    animation: fadeIn 0.4s ease-out 2.4s forwards;
  }

  .lbl {
    font-size: 9px;
    font-family: inherit;
    font-style: italic;
  }
  .lbl-secondary {
    fill: var(--color-secondary, oklch(65% 0.04 240deg));
    opacity: 0.5;
  }
  .lbl-accent {
    fill: var(--color-accent, oklch(75% 0.18 85deg));
    opacity: 0;
    animation: fadeIn 0.6s ease-out 2.4s forwards;
  }
  .axis-lbl {
    font-size: 8px;
    font-family: inherit;
    fill: var(--color-secondary, oklch(65% 0.04 240deg));
    opacity: 0.18;
  }

  @keyframes drawArc {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>
