---
interface Props {
  class?: string;
  ariaLabel?: string;
  title?: string;
}

const {
  class: className = "",
  ariaLabel = "Illustration héros — L'Émergence de la Complexité",
  title = "L'Émergence de la Complexité",
} = Astro.props;
---

<figure class:list={["not-prose", className]} aria-label={ariaLabel}>
  <svg
    viewBox="0 0 720 320"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    class="h-auto w-full"
    style="max-width: 720px;"
  >
    <title>{title}</title>
    <defs>
      <!-- Background gradient -->
      <linearGradient id="hero-bg" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color: var(--background); stop-opacity: 1"></stop>
        <stop offset="100%" style="stop-color: var(--card); stop-opacity: 1"></stop>
      </linearGradient>
      <!-- Number line gradient -->
      <linearGradient id="line-grad" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" style="stop-color: var(--secondary); stop-opacity: 0.2"></stop>
        <stop offset="50%" style="stop-color: var(--secondary); stop-opacity: 1"></stop>
        <stop offset="100%" style="stop-color: var(--accent); stop-opacity: 0.2"></stop>
      </linearGradient>
      <!-- Glow filter -->
      <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
        <feMerge>
          <feMergeNode in="blur"></feMergeNode>
          <feMergeNode in="SourceGraphic"></feMergeNode>
        </feMerge>
      </filter>
      <!-- Subtle grid pattern -->
      <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
        <path
          d="M 40 0 L 0 0 0 40"
          fill="none"
          stroke="var(--border)"
          stroke-width="0.4"
          opacity="0.5"></path>
      </pattern>
    </defs>

    <!-- Background -->
    <rect width="720" height="320" fill="url(#hero-bg)" rx="12"></rect>
    <rect width="720" height="320" fill="url(#grid)" rx="12"></rect>

    <!-- Decorative arc (number-line extension into complex plane) -->
    <ellipse
      cx="360"
      cy="320"
      rx="310"
      ry="180"
      fill="none"
      stroke="var(--secondary)"
      stroke-width="0.8"
      opacity="0.15"></ellipse>
    <ellipse
      cx="360"
      cy="320"
      rx="200"
      ry="120"
      fill="none"
      stroke="var(--accent)"
      stroke-width="0.8"
      opacity="0.12"></ellipse>

    <!-- Number line (horizontal) -->
    <line x1="60" y1="200" x2="660" y2="200" stroke="url(#line-grad)" stroke-width="2"></line>
    <!-- Arrow right -->
    <polygon points="660,200 650,195 650,205" fill="var(--secondary)" opacity="0.6"></polygon>

    <!-- Imaginary axis (vertical) -->
    <line
      x1="360"
      y1="280"
      x2="360"
      y2="60"
      stroke="var(--accent)"
      stroke-width="1.5"
      opacity="0.5"
      stroke-dasharray="6 4"></line>
    <!-- Arrow up -->
    <polygon points="360,60 355,72 365,72" fill="var(--accent)" opacity="0.5"></polygon>

    <!-- Number sets labels on the line -->
    <!-- ℕ -->
    <circle cx="180" cy="200" r="4" fill="var(--secondary)" filter="url(#glow)"></circle>
    <text
      x="180"
      y="220"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)"
      opacity="0.85">ℕ</text
    >

    <!-- ℤ -->
    <circle cx="270" cy="200" r="4" fill="var(--secondary)" filter="url(#glow)"></circle>
    <text
      x="270"
      y="220"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)"
      opacity="0.85">ℤ</text
    >

    <!-- ℚ -->
    <circle cx="360" cy="200" r="5" fill="var(--secondary)" filter="url(#glow)"></circle>
    <text
      x="360"
      y="220"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)"
      opacity="0.85">ℚ</text
    >

    <!-- ℝ -->
    <circle cx="450" cy="200" r="4" fill="var(--secondary)" filter="url(#glow)"></circle>
    <text
      x="450"
      y="220"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)"
      opacity="0.85">ℝ</text
    >

    <!-- ℂ -->
    <circle cx="360" cy="140" r="6" fill="var(--accent)" filter="url(#glow)"></circle>
    <text
      x="378"
      y="136"
      text-anchor="start"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      opacity="0.9">ℂ</text
    >

    <!-- i axis label -->
    <text
      x="370"
      y="72"
      text-anchor="start"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      opacity="0.6">i</text
    >

    <!-- Euler's formula highlight -->
    <rect
      x="420"
      y="115"
      width="200"
      height="36"
      rx="8"
      fill="var(--card)"
      stroke="var(--border)"
      stroke-width="1"
      opacity="0.9"></rect>
    <text
      x="520"
      y="138"
      text-anchor="middle"
      font-size="15"
      font-family="var(--font-mono)"
      fill="var(--foreground)">e^iπ + 1 = 0</text
    >

    <!-- Main title -->
    <text
      x="360"
      y="68"
      text-anchor="middle"
      font-size="22"
      font-weight="700"
      font-family="var(--font-sans)"
      fill="var(--foreground)"
      letter-spacing="-0.5">L'Émergence de la Complexité</text
    >

    <!-- Subtitle -->
    <text
      x="360"
      y="92"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-sans)"
      fill="var(--muted-foreground)">De ℕ à ℂ — par nécessité logique</text
    >

    <!-- Small decorative dots on number line -->
    {
      [120, 150, 210, 240, 300, 330, 390, 420, 480, 510, 540, 570, 600].map((x) => (
        <circle cx={x} cy="200" r="1.5" fill="var(--border)" opacity="0.6" />
      ))
    }

    <!-- Rotation arc from real to imaginary -->
    <path
      d="M 420 200 A 60 60 0 0 0 360 140"
      fill="none"
      stroke="var(--accent)"
      stroke-width="1.2"
      stroke-dasharray="4 3"
      opacity="0.5"></path>
    <text
      x="405"
      y="168"
      text-anchor="middle"
      font-size="9"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      opacity="0.7">×i = 90°</text
    >

    <!-- Bottom note -->
    <text
      x="360"
      y="300"
      text-anchor="middle"
      font-size="9"
      font-family="var(--font-sans)"
      fill="var(--muted-foreground)"
      opacity="0.6">Et si on inversait cela ?</text
    >
  </svg>
</figure>
