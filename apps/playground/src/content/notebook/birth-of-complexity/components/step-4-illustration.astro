---
type Props = {
  class?: string;
  ariaLabel?: string;
  title?: string;
}

const {
  class: className = "",
  ariaLabel = "Étape 04 — log : Apprivoiser l'Explosion",
  title: titleProp = "Étape 04 — log : Apprivoiser l'Explosion",
} = Astro.props;

// Data for the two curves
const logPoints: { x: number; y: number }[] = [];
const expPoints: { x: number; y: number }[] = [];
const W = 300,
  H = 130,
  padX = 10,
  padY = 10;

for (let i = 0; i <= 50; i++) {
  const t = i / 50; // 0 to 1
  const xVal = t * 4; // domain 0-4
  const xPx = padX + t * W;

  // Exp: y = 10^x clamped
  const expY = Math.pow(10, xVal);
  const expNorm = Math.min(expY / 10000, 1);
  const expPy = H - padY - expNorm * (H - 2 * padY);
  expPoints.push({ x: xPx, y: expPy });

  // Log: y = log10(1 + x*9999)/4 mapped
  const logY = Math.log10(1 + t * 9999);
  const logNorm = logY / 4;
  const logPy = H - padY - logNorm * (H - 2 * padY);
  logPoints.push({ x: xPx, y: logPy });
}

const expPath = expPoints
  .map((p, i) => `${i === 0 ? "M" : "L"} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`)
  .join(" ");
const logPath = logPoints
  .map((p, i) => `${i === 0 ? "M" : "L"} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`)
  .join(" ");
---

<figure class:list={["not-prose", className]} aria-label={ariaLabel}>
  <svg
    viewBox="0 0 720 240"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    class="h-auto w-full"
    style="max-width: 720px;"
  >
    <title>{titleProp}</title>
    <defs>
      <linearGradient id="s4-bg" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color: var(--card); stop-opacity: 1"></stop>
        <stop offset="100%" style="stop-color: var(--background); stop-opacity: 1"></stop>
      </linearGradient>
      <clipPath id="s4-clip">
        <rect x="360" y="50" width="330" height="160" rx="0"></rect>
      </clipPath>
    </defs>

    <rect width="720" height="240" fill="url(#s4-bg)" rx="10"></rect>
    <rect
      width="720"
      height="240"
      fill="none"
      stroke="var(--border)"
      stroke-width="1"
      rx="10"
      opacity="0.5"></rect>

    <!-- Badge -->
    <rect x="24" y="20" width="80" height="22" rx="11" fill="var(--secondary)" opacity="0.15"
    ></rect>
    <text
      x="64"
      y="35"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)"
      font-weight="600">Étape 04</text
    >

    <!-- Title -->
    <text
      x="24"
      y="72"
      font-size="20"
      font-weight="700"
      font-family="var(--font-sans)"
      fill="var(--foreground)">log — Apprivoiser l'Explosion</text
    >
    <text x="24" y="92" font-size="12" font-family="var(--font-sans)" fill="var(--muted-foreground)"
      >L'inverse de la puissance — rendre l'immense lisible.</text
    >

    <!-- Table on the left -->
    <rect x="24" y="108" width="200" height="116" rx="8" fill="var(--muted)" opacity="0.4"></rect>
    <!-- Table header -->
    <text
      x="64"
      y="126"
      text-anchor="middle"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--muted-foreground)">n</text
    >
    <text
      x="164"
      y="126"
      text-anchor="middle"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--muted-foreground)">10ⁿ</text
    >
    <line x1="24" y1="130" x2="224" y2="130" stroke="var(--border)" stroke-width="0.8" opacity="0.6"
    ></line>

    {
      [
        [1, "10"],
        [3, "1 000"],
        [6, "1 000 000"],
        [9, "10⁹"],
        [12, "10¹²"],
      ].map(([n, label], i) => (
        <Fragment>
          <text
            x="64"
            y={147 + i * 17}
            text-anchor="middle"
            font-size="11"
            font-family="var(--font-mono)"
            fill="var(--secondary)"
          >
            {n}
          </text>
          <text
            x="184"
            y={147 + i * 17}
            text-anchor="end"
            font-size="11"
            font-family="var(--font-mono)"
            fill="var(--foreground)"
          >
            {label}
          </text>
        </Fragment>
      ))
    }

    <!-- Chart area -->
    <rect
      x="360"
      y="50"
      width="330"
      height="160"
      rx="6"
      fill="var(--card)"
      stroke="var(--border)"
      stroke-width="0.8"
      opacity="0.6"></rect>

    <!-- Chart axes -->
    <g transform="translate(360, 50)" clip-path="url(#s4-clip)">
      <!-- Exponential curve -->
      <path d={expPath} fill="none" stroke="var(--accent)" stroke-width="2" opacity="0.6"></path>
      <!-- Logarithmic curve -->
      <path d={logPath} fill="none" stroke="var(--secondary)" stroke-width="2.5"></path>
    </g>

    <!-- Legend -->
    <line x1="368" y1="68" x2="390" y2="68" stroke="var(--accent)" stroke-width="2" opacity="0.6"
    ></line>
    <text
      x="394"
      y="72"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--muted-foreground)">10ⁿ</text
    >

    <line x1="430" y1="68" x2="452" y2="68" stroke="var(--secondary)" stroke-width="2.5"></line>
    <text
      x="456"
      y="72"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--muted-foreground)">log₁₀</text
    >

    <!-- Key formula -->
    <rect
      x="240"
      y="160"
      width="112"
      height="34"
      rx="8"
      fill="var(--card)"
      stroke="var(--secondary)"
      stroke-width="1"
      opacity="0.9"></rect>
    <text
      x="296"
      y="174"
      text-anchor="middle"
      font-size="8"
      font-family="var(--font-mono)"
      fill="var(--muted-foreground)">propriété clé</text
    >
    <text
      x="296"
      y="188"
      text-anchor="middle"
      font-size="12"
      font-family="var(--font-mono)"
      fill="var(--foreground)">log(A×B) = log A + log B</text
    >

    <!-- Key insight -->
    <rect x="24" y="200" width="672" height="28" rx="6" fill="var(--muted)" opacity="0.5"></rect>
    <text
      x="360"
      y="218"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-sans)"
      fill="var(--muted-foreground)"
      >La multiplication devient addition — les grands nombres deviennent maniables.</text
    >
  </svg>
</figure>
