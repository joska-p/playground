---
interface Props {
  class?: string;
  ariaLabel?: string;
  title?: string;
}

const {
  class: className = "",
  ariaLabel = "Étape 05 — i : Le Mur de l'Impossible",
  title: titleProp = "Étape 05 — i : Le Mur de l'Impossible",
} = Astro.props;
---

<figure class:list={["not-prose", className]} aria-label={ariaLabel}>
  <svg
    viewBox="0 0 720 240"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    class="h-auto w-full"
    style="max-width: 720px;"
  >
    <title>{titleProp}</title>
    <defs>
      <linearGradient id="s5-bg" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color: var(--card); stop-opacity: 1"></stop>
        <stop offset="100%" style="stop-color: var(--background); stop-opacity: 1"></stop>
      </linearGradient>
      <filter id="s5-glow">
        <feGaussianBlur stdDeviation="4" result="blur"></feGaussianBlur>
        <feMerge>
          <feMergeNode in="blur"></feMergeNode>
          <feMergeNode in="SourceGraphic"></feMergeNode>
        </feMerge>
      </filter>
    </defs>

    <rect width="720" height="240" fill="url(#s5-bg)" rx="10"></rect>
    <rect
      width="720"
      height="240"
      fill="none"
      stroke="var(--border)"
      stroke-width="1"
      rx="10"
      opacity="0.5"></rect>

    <!-- Badge -->
    <rect x="24" y="20" width="80" height="22" rx="11" fill="var(--accent)" opacity="0.18"></rect>
    <text
      x="64"
      y="35"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      font-weight="600">Étape 05</text
    >

    <!-- Title -->
    <text
      x="24"
      y="72"
      font-size="20"
      font-weight="700"
      font-family="var(--font-sans)"
      fill="var(--foreground)">i — Le Mur de l'Impossible</text
    >
    <text x="24" y="92" font-size="12" font-family="var(--font-sans)" fill="var(--muted-foreground)"
      >Un nombre qui ne vit pas sur la droite réelle.</text
    >

    <!-- Real number line -->
    <line x1="40" y1="160" x2="340" y2="160" stroke="var(--border)" stroke-width="1.5" opacity="0.5"
    ></line>
    <polygon points="345,160 335,155 335,165" fill="var(--border)" opacity="0.5"></polygon>
    <text
      x="350"
      y="164"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--muted-foreground)"
      opacity="0.7">ℝ</text
    >

    <!-- Ticks on real line -->
    {
      [-2, -1, 0, 1, 2].map((n) => {
        const x = 190 + n * 50;
        return [
          <line
            x1={x}
            y1="153"
            x2={x}
            y2="167"
            stroke="var(--border)"
            stroke-width="1.2"
            opacity="0.7"
          />,
          <text
            x={x}
            y="180"
            text-anchor="middle"
            font-size="12"
            font-family="var(--font-mono)"
            fill="var(--foreground)"
          >
            {n === 0 ? "0" : n > 0 ? `+${n}` : n}
          </text>,
        ];
      })
    }

    <!-- Parabola: y = x^2, all values ≥ 0 -->
    <!-- Drawn in range x=[-2,2], scaled around center 190, y ↑ (screen ↓) -->
    <path
      d="M 90 160 Q 190 80 290 160"
      fill="none"
      stroke="var(--secondary)"
      stroke-width="2"
      opacity="0.6"></path>
    <text
      x="190"
      y="75"
      text-anchor="middle"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--secondary)"
      opacity="0.8">y = x² ≥ 0</text
    >

    <!-- The wall: x² = -1 has no solution on real line -->
    <line
      x1="40"
      y1="190"
      x2="340"
      y2="190"
      stroke="var(--accent)"
      stroke-width="1"
      stroke-dasharray="5 3"
      opacity="0.4"></line>
    <text
      x="190"
      y="205"
      text-anchor="middle"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      opacity="0.7">x² = −1 : aucune solution réelle</text
    >

    <!-- The vertical separator / wall -->
    <line
      x1="380"
      y1="40"
      x2="380"
      y2="220"
      stroke="var(--border)"
      stroke-width="1"
      stroke-dasharray="6 4"
      opacity="0.3"></line>

    <!-- Right side: the postulate and i -->
    <!-- Big i symbol -->
    <circle cx="510" cy="128" r="44" fill="var(--accent)" opacity="0.08" filter="url(#s5-glow)"
    ></circle>
    <text
      x="510"
      y="148"
      text-anchor="middle"
      font-size="60"
      font-family="var(--font-mono)"
      font-weight="700"
      fill="var(--accent)"
      opacity="0.85">i</text
    >

    <!-- i² = -1 box -->
    <rect
      x="570"
      y="100"
      width="120"
      height="56"
      rx="8"
      fill="var(--card)"
      stroke="var(--accent)"
      stroke-width="1.2"
      opacity="0.9"></rect>
    <text
      x="630"
      y="121"
      text-anchor="middle"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--muted-foreground)">postulat</text
    >
    <text
      x="630"
      y="144"
      text-anchor="middle"
      font-size="17"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      font-weight="600">i² = −1</text
    >

    <!-- Arrow from wall to i -->
    <path
      d="M 348 128 Q 400 128 456 128"
      fill="none"
      stroke="var(--accent)"
      stroke-width="1.5"
      opacity="0.5"
      stroke-dasharray="4 3"></path>
    <polygon points="460,128 450,123 450,133" fill="var(--accent)" opacity="0.5"></polygon>
    <text
      x="404"
      y="122"
      text-anchor="middle"
      font-size="9"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      opacity="0.7">on postule</text
    >

    <!-- Key insight -->
    <rect x="24" y="210" width="672" height="22" rx="6" fill="var(--muted)" opacity="0.4"></rect>
    <text
      x="360"
      y="225"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-sans)"
      fill="var(--muted-foreground)"
      >i n'est pas irrationnel — il est imaginaire. L'univers s'étend à nouveau.</text
    >
  </svg>
</figure>
