---
interface Props {
  class?: string;
  ariaLabel?: string;
  title?: string;
}

const {
  class: className = "",
  ariaLabel = "Épilogue — e^iπ + 1 = 0 : La Convergence Improbable",
  title: titleProp = "Épilogue — La Formule d'Euler",
} = Astro.props;

// Unit circle points for e^iθ
const circlePoints: string[] = [];
const cx = 560,
  cy = 130,
  r = 80;
for (let deg = 0; deg <= 360; deg += 10) {
  const rad = (deg * Math.PI) / 180;
  const x = cx + r * Math.cos(rad);
  const y = cy - r * Math.sin(rad);
  circlePoints.push(`${deg === 0 ? "M" : "L"} ${x.toFixed(2)} ${y.toFixed(2)}`);
}
const circlePath = circlePoints.join(" ") + " Z";

// Point at θ = π (180°): x=-1, y=0 on unit circle → pixel: cx-r, cy
const piX = cx - r;
const piY = cy;
---

<figure class:list={["not-prose", className]} aria-label={ariaLabel}>
  <svg
    viewBox="0 0 720 280"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    class="h-auto w-full"
    style="max-width: 720px;"
  >
    <title>{titleProp}</title>
    <defs>
      <linearGradient id="ep-bg" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color: var(--card); stop-opacity: 1"></stop>
        <stop offset="100%" style="stop-color: var(--background); stop-opacity: 1"></stop>
      </linearGradient>
      <radialGradient id="ep-glow-grad" cx="50%" cy="50%" r="50%">
        <stop offset="0%" style="stop-color: var(--secondary); stop-opacity: 0.15"></stop>
        <stop offset="100%" style="stop-color: var(--secondary); stop-opacity: 0"></stop>
      </radialGradient>
      <filter id="ep-glow">
        <feGaussianBlur stdDeviation="5" result="blur"></feGaussianBlur>
        <feMerge>
          <feMergeNode in="blur"></feMergeNode>
          <feMergeNode in="SourceGraphic"></feMergeNode>
        </feMerge>
      </filter>
      <pattern id="ep-grid" width="20" height="20" patternUnits="userSpaceOnUse">
        <path
          d="M 20 0 L 0 0 0 20"
          fill="none"
          stroke="var(--border)"
          stroke-width="0.3"
          opacity="0.4"></path>
      </pattern>
    </defs>

    <!-- Background -->
    <rect width="720" height="280" fill="url(#ep-bg)" rx="10"></rect>
    <rect x="430" y="30" width="270" height="220" fill="url(#ep-grid)" rx="8"></rect>
    <rect
      width="720"
      height="280"
      fill="none"
      stroke="var(--border)"
      stroke-width="1"
      rx="10"
      opacity="0.4"></rect>

    <!-- Badge -->
    <rect x="24" y="20" width="80" height="22" rx="11" fill="var(--secondary)" opacity="0.18"
    ></rect>
    <text
      x="64"
      y="35"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--secondary)"
      font-weight="600">Épilogue</text
    >

    <!-- Title -->
    <text
      x="24"
      y="72"
      font-size="20"
      font-weight="700"
      font-family="var(--font-sans)"
      fill="var(--foreground)">La Formule d'Euler</text
    >
    <text x="24" y="92" font-size="12" font-family="var(--font-sans)" fill="var(--muted-foreground)"
      >Cinq constantes. Un seul chemin.</text
    >

    <!-- Five constants listed on left -->
    {
      [
        { sym: "0", desc: "le néant", color: "var(--muted-foreground)", y: 118 },
        { sym: "1", desc: "l'unité", color: "var(--secondary)", y: 143 },
        { sym: "π", desc: "la géométrie", color: "var(--secondary)", y: 168 },
        { sym: "e", desc: "la croissance", color: "var(--accent)", y: 193 },
        { sym: "i", desc: "l'imaginaire", color: "var(--accent)", y: 218 },
      ].map(({ sym, desc, color, y }) => (
        <Fragment>
          <text
            x="44"
            y={y}
            font-size="16"
            font-family="var(--font-mono)"
            fill={color}
            font-weight="600"
          >
            {sym}
          </text>
          <text
            x="70"
            y={y}
            font-size="12"
            font-family="var(--font-sans)"
            fill="var(--muted-foreground)"
          >
            — {desc}
          </text>
        </Fragment>
      ))
    }

    <!-- Convergence arrow -->
    <path
      d="M 200 168 Q 290 168 340 168"
      fill="none"
      stroke="var(--border)"
      stroke-width="1.5"
      stroke-dasharray="5 3"
      opacity="0.5"></path>
    <polygon points="344,168 334,163 334,173" fill="var(--border)" opacity="0.5"></polygon>

    <!-- THE formula box (center) -->
    <rect
      x="350"
      y="148"
      width="72"
      height="40"
      rx="8"
      fill="var(--card)"
      stroke="var(--secondary)"
      stroke-width="1.5"
      opacity="0.95"></rect>
    <text
      x="386"
      y="174"
      text-anchor="middle"
      font-size="17"
      font-family="var(--font-mono)"
      fill="var(--foreground)"
      font-weight="700">e^iπ+1=0</text
    >

    <!-- Unit circle on the right -->
    <!-- Glow -->
    <circle cx={cx} cy={cy} r={r + 20} fill="url(#ep-glow-grad)"></circle>
    <!-- Circle -->
    <path d={circlePath} fill="none" stroke="var(--secondary)" stroke-width="1.5" opacity="0.6"
    ></path>

    <!-- Axes -->
    <line
      x1={cx - r - 20}
      y1={cy}
      x2={cx + r + 20}
      y2={cy}
      stroke="var(--border)"
      stroke-width="1"
      opacity="0.5"></line>
    <line
      x1={cx}
      y1={cy + r + 20}
      x2={cx}
      y2={cy - r - 20}
      stroke="var(--accent)"
      stroke-width="1"
      opacity="0.4"
      stroke-dasharray="4 3"></line>

    <!-- Point at θ=π (e^iπ = -1) -->
    <circle cx={piX} cy={piY} r="6" fill="var(--accent)" filter="url(#ep-glow)"></circle>
    <!-- Vector from center to point -->
    <line x1={cx} y1={cy} x2={piX + 4} y2={piY} stroke="var(--secondary)" stroke-width="1.8"></line>
    <polygon
      points={`${piX + 4},${piY} ${piX + 13},${piY - 4} ${piX + 13},${piY + 4}`}
      fill="var(--secondary)"></polygon>

    <!-- π arc label -->
    <path
      d={`M ${cx + 40} ${cy} A 40 40 0 0 0 ${cx - 40} ${cy}`}
      fill="none"
      stroke="var(--accent)"
      stroke-width="1.2"
      stroke-dasharray="4 3"
      opacity="0.5"></path>
    <text
      x={cx}
      y={cy - 48}
      text-anchor="middle"
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      opacity="0.8">θ = π</text
    >

    <!-- −1 label at the point -->
    <text
      x={piX - 12}
      y={piY - 10}
      text-anchor="end"
      font-size="11"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      font-weight="600">e^iπ = −1</text
    >

    <!-- +1 annotation at right -->
    <circle cx={cx + r} cy={cy} r="4" fill="var(--secondary)" opacity="0.6"></circle>
    <text
      x={cx + r + 8}
      y={cy + 4}
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--secondary)"
      opacity="0.8">+1</text
    >

    <!-- i label at top -->
    <circle cx={cx} cy={cy - r} r="4" fill="var(--accent)" opacity="0.6"></circle>
    <text
      x={cx + 8}
      y={cy - r}
      font-size="10"
      font-family="var(--font-mono)"
      fill="var(--accent)"
      opacity="0.8">+i</text
    >

    <!-- Closing quote -->
    <rect x="24" y="244" width="672" height="24" rx="6" fill="var(--muted)" opacity="0.4"></rect>
    <text
      x="360"
      y="260"
      text-anchor="middle"
      font-size="11"
      font-family="var(--font-sans)"
      fill="var(--muted-foreground)"
      font-style="italic">« Une invitation à poursuivre la promenade. »</text
    >
  </svg>
</figure>
