---
import Figure from "./figure.astro";
import "./common-animations.css";
import SvgNode from "./SvgNode.astro";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 700 200" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl">
    <style>
      .succ-n1 {
        animation: pop-in 0.5s 0.1s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 80px 100px;
      }
      .succ-n2 {
        animation: pop-in 0.5s 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 230px 100px;
      }
      .succ-n3 {
        animation: pop-in 0.5s 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 380px 100px;
      }
      .succ-n4 {
        animation: pop-in 0.5s 1.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 530px 100px;
      }
      .succ-n5 {
        animation: pop-in 0.5s 1.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 660px 100px;
      }
      .succ-a1 {
        animation: fade-in 0.35s 0.3s ease-out both;
      }
      .succ-a2 {
        animation: fade-in 0.35s 0.7s ease-out both;
      }
      .succ-a3 {
        animation: fade-in 0.35s 1.1s ease-out both;
      }
      .succ-a4 {
        animation: fade-in 0.35s 1.5s ease-out both;
      }
      .succ-dots {
        animation: pop-in 0.5s 2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 660px 100px;
      }
    </style>

    <defs>
      <marker id="succ-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" class="fill-muted-foreground"></path>
      </marker>
    </defs>

    <SvgNode cx={80} cy={100} label="1" class="succ-n1" r={36} />
    <SvgNode cx={230} cy={100} label="2" class="succ-n2" r={36} />
    <SvgNode cx={380} cy={100} label="3" class="succ-n3" r={36} />
    <SvgNode cx={530} cy={100} label="4" class="succ-n4" r={36} />

    <g class="stroke-muted-foreground" stroke-width="1.5" fill="none" marker-end="url(#succ-arrow)">
      <path d="M118,100 L186,100" class="succ-a1"></path>
      <path d="M268,100 L336,100" class="succ-a2"></path>
      <path d="M418,100 L486,100" class="succ-a3"></path>
      <path d="M568,100 L624,100" class="succ-a4"></path>
    </g>

    <g class="fill-muted-foreground text-sm" text-anchor="middle">
      <text x="152" y="88" class="succ-a1">+1</text>
      <text x="302" y="88" class="succ-a2">+1</text>
      <text x="452" y="88" class="succ-a3">+1</text>
      <text x="596" y="88" class="succ-a4">+1</text>
    </g>

    <g class="succ-dots">
      <text x="650" y="108" class="fill-muted-foreground/70 text-3xl">…</text>
    </g>

    <text
      x="350"
      y="170"
      text-anchor="middle"
      class="fill-muted-foreground/80 text-sm"
      letter-spacing="2">ONE RULE · INFINITE CONSEQUENCE</text
    >
  </svg>
</Figure>
