---

---

<figure class="my-10 flex flex-col items-center">
  <svg viewBox="0 0 560 160" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-xl">
    <style>
      .node-1 {
        animation: node-pop 0.5s 0.1s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }
      .node-2 {
        animation: node-pop 0.5s 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }
      .node-3 {
        animation: node-pop 0.5s 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }
      .node-4 {
        animation: node-pop 0.5s 1.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }
      .node-5 {
        animation: node-pop 0.5s 1.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }
      @keyframes node-pop {
        from {
          opacity: 0;
          transform: scale(0.4);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }
      .arrow-1 {
        animation: arrow-draw 0.35s 0.3s ease-out both;
      }
      .arrow-2 {
        animation: arrow-draw 0.35s 0.7s ease-out both;
      }
      .arrow-3 {
        animation: arrow-draw 0.35s 1.1s ease-out both;
      }
      .arrow-4 {
        animation: arrow-draw 0.35s 1.5s ease-out both;
      }
      @keyframes arrow-draw {
        from {
          opacity: 0;
          stroke-dashoffset: 60;
        }
        to {
          opacity: 1;
          stroke-dashoffset: 0;
        }
      }
      .arrow-path {
        stroke-dasharray: 60;
      }
      .dots-in {
        animation: node-pop 0.5s 2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }
    </style>

    <!-- node circles + labels -->
    <!-- Node 1 -->
    <g class="node-1" style="transform-origin:80px 78px">
      <circle cx="80" cy="78" r="32" fill="var(--card)" stroke="var(--primary)" stroke-width="2"
      ></circle>
      <text
        x="80"
        y="85"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="26"
        font-weight="bold"
        fill="var(--primary)">1</text
      >
    </g>
    <!-- Node 2 -->
    <g class="node-2" style="transform-origin:200px 78px">
      <circle cx="200" cy="78" r="32" fill="var(--card)" stroke="var(--secondary)" stroke-width="2"
      ></circle>
      <text
        x="200"
        y="85"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="26"
        font-weight="bold"
        fill="var(--secondary)">2</text
      >
    </g>
    <!-- Node 3 -->
    <g class="node-3" style="transform-origin:320px 78px">
      <circle cx="320" cy="78" r="32" fill="var(--card)" stroke="var(--primary)" stroke-width="2"
      ></circle>
      <text
        x="320"
        y="85"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="26"
        font-weight="bold"
        fill="var(--primary)">3</text
      >
    </g>
    <!-- Node 4 -->
    <g class="node-4" style="transform-origin:440px 78px">
      <circle cx="440" cy="78" r="32" fill="var(--card)" stroke="var(--secondary)" stroke-width="2"
      ></circle>
      <text
        x="440"
        y="85"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="26"
        font-weight="bold"
        fill="var(--secondary)">4</text
      >
    </g>

    <!-- Arrows with +1 labels -->
    <defs>
      <marker id="succ-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="var(--muted-foreground)"></path>
      </marker>
    </defs>

    <g
      stroke="var(--muted-foreground)"
      stroke-width="1.5"
      fill="none"
      marker-end="url(#succ-arrow)"
    >
      <path d="M114,78 L162,78" class="arrow-path arrow-1"></path>
      <path d="M234,78 L282,78" class="arrow-path arrow-2"></path>
      <path d="M354,78 L402,78" class="arrow-path arrow-3"></path>
      <path d="M474,78 L510,78" class="arrow-path arrow-4"></path>
    </g>

    <!-- +1 labels -->
    <g
      font-family="Georgia,serif"
      font-size="11"
      fill="var(--muted-foreground)"
      text-anchor="middle"
    >
      <text x="138" y="68" class="arrow-1">+1</text>
      <text x="258" y="68" class="arrow-2">+1</text>
      <text x="378" y="68" class="arrow-3">+1</text>
      <text x="493" y="68" class="arrow-4">+1</text>
    </g>

    <!-- dots -->
    <g class="dots-in" style="transform-origin:530px 78px">
      <text
        x="528"
        y="85"
        font-family="Georgia,serif"
        font-size="24"
        fill="var(--muted-foreground)"
        opacity="0.7">…</text
      >
    </g>

    <!-- caption -->
    <text
      x="280"
      y="140"
      text-anchor="middle"
      font-family="Georgia,serif"
      font-size="11"
      fill="var(--muted-foreground)"
      letter-spacing="2"
      opacity="0.8">ONE RULE · INFINITE CONSEQUENCE</text
    >
  </svg>
</figure>
