---
import Figure from "./figure.astro";
import "./common-animations.css";
import SvgNode from "./SvgNode.astro";

const nodes = [
  { cx: 80, cy: 78, label: "1", cls: "succ-n1", stroke: "var(--primary)" },
  { cx: 200, cy: 78, label: "2", cls: "succ-n2", stroke: "var(--secondary)" },
  { cx: 320, cy: 78, label: "3", cls: "succ-n3", stroke: "var(--primary)" },
  { cx: 440, cy: 78, label: "4", cls: "succ-n4", stroke: "var(--secondary)" },
];
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 560 160" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-xl">
    <style>
      .succ-n1 { animation: pop-in 0.5s 0.1s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
      .succ-n2 { animation: pop-in 0.5s 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
      .succ-n3 { animation: pop-in 0.5s 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
      .succ-n4 { animation: pop-in 0.5s 1.3s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
      .succ-n5 { animation: pop-in 0.5s 1.7s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
      .succ-a1 { animation: fade-in 0.35s 0.3s ease-out both; }
      .succ-a2 { animation: fade-in 0.35s 0.7s ease-out both; }
      .succ-a3 { animation: fade-in 0.35s 1.1s ease-out both; }
      .succ-a4 { animation: fade-in 0.35s 1.5s ease-out both; }
      .succ-dots { animation: pop-in 0.5s 2s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
    </style>

    <defs>
      <marker id="succ-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="var(--muted-foreground)"></path>
      </marker>
    </defs>

    {nodes.map((n) => (
      <SvgNode cx={n.cx} cy={n.cy} label={n.label} class={n.cls} stroke={n.stroke} r={32} labelSize={26} />
    ))}

    <g
      stroke="var(--muted-foreground)"
      stroke-width="1.5"
      fill="none"
      marker-end="url(#succ-arrow)"
    >
      <path d="M114,78 L162,78" class="succ-a1" />
      <path d="M234,78 L282,78" class="succ-a2" />
      <path d="M354,78 L402,78" class="succ-a3" />
      <path d="M474,78 L510,78" class="succ-a4" />
    </g>

    <g
      font-family="Georgia,serif"
      font-size="11"
      fill="var(--muted-foreground)"
      text-anchor="middle"
    >
      <text x="138" y="68" class="succ-a1">+1</text>
      <text x="258" y="68" class="succ-a2">+1</text>
      <text x="378" y="68" class="succ-a3">+1</text>
      <text x="493" y="68" class="succ-a4">+1</text>
    </g>

    <g class="succ-dots" style="transform-origin:530px 78px">
      <text x="528" y="85" font-family="Georgia,serif" font-size="24" fill="var(--muted-foreground)" opacity="0.7">…</text>
    </g>

    <text x="280" y="140" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="var(--muted-foreground)" letter-spacing="2" opacity="0.8">ONE RULE · INFINITE CONSEQUENCE</text>
  </svg>
</Figure>
