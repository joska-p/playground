---
interface Props {
  cx: number;
  cy: number;
  label: string;
  subtitle?: string;
  r?: number;
  class?: string;
  stroke?: string;
}
const {
  cx,
  cy,
  label,
  subtitle,
  r = 26,
  class: className,
  stroke = "var(--primary)",
} = Astro.props;
---

<g class={className}>
  <circle cx={cx} cy={cy} r={r} fill="var(--card)" stroke={stroke} stroke-width="2"></circle>
  <text x={cx} y={cy} dy=".35em" text-anchor="middle" class="text-2xl font-bold" fill={stroke}
    >{label}</text
  >
  {
    subtitle && (
      <text x={cx} y={cy + r + 14} text-anchor="middle" class="fill-muted-foreground text-sm">
        {subtitle}
      </text>
    )
  }
</g>
