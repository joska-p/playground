---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="lex flex-col items-center">
  <svg viewBox="0 0 640 240" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl">
    <style>
      .rat-axis {
        stroke-dasharray: 500;
        animation: draw-in 0.7s 0.1s ease-out both;
      }
      @keyframes draw-in {
        from {
          stroke-dashoffset: 500;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      .rat-l0 {
        animation: fade-up 0.4s 0.3s ease-out both;
      }
      .rat-l1 {
        animation: fade-up 0.5s 0.8s ease-out both;
      }
      .rat-l2 {
        animation: fade-up 0.5s 1.3s ease-out both;
      }
      .rat-l3 {
        animation: fade-up 0.5s 1.8s ease-out both;
      }
      .rat-bracket {
        animation: fade-up 0.4s 2.1s ease-out both;
      }
    </style>

    <line
      x1="60"
      y1="110"
      x2="580"
      y2="110"
      class="stroke-border"
      stroke-width="1.5"
      class="rat-axis"></line>
    <polygon points="580,106 580,114 596,110" class="fill-border rat-axis"></polygon>

    <g class="rat-l0">
      <line x1="110" y1="102" x2="110" y2="118" class="stroke-primary" stroke-width="2.5"></line>
      <text x="110" y="88" text-anchor="middle" class="fill-primary text-lg font-bold">0</text>
      <line x1="530" y1="102" x2="530" y2="118" class="stroke-primary" stroke-width="2.5"></line>
      <text x="530" y="88" text-anchor="middle" class="fill-primary text-lg font-bold">1</text>
    </g>

    <g class="rat-l1">
      <line x1="253" y1="104" x2="253" y2="116" class="stroke-secondary" stroke-width="2"></line>
      <text x="253" y="136" text-anchor="middle" class="fill-secondary text-base">⅓</text>
      <line x1="320" y1="103" x2="320" y2="117" class="stroke-secondary" stroke-width="2.5"></line>
      <text x="320" y="136" text-anchor="middle" class="fill-secondary text-base">½</text>
    </g>

    <g class="rat-l2">
      <line x1="286" y1="105" x2="286" y2="115" class="stroke-accent" stroke-width="1.8"></line>
      <text x="286" y="160" text-anchor="middle" class="fill-accent text-sm">⁵⁄₁₂</text>
    </g>

    <g class="rat-l3">
      <line
        x1="303"
        y1="106"
        x2="303"
        y2="114"
        class="stroke-muted-foreground/70"
        stroke-width="1.4"></line>
      <text x="303" y="180" text-anchor="middle" class="fill-muted-foreground/70 text-sm"
        >¹¹⁄₂₄</text
      >
    </g>

    <g class="rat-bracket">
      <line x1="253" y1="188" x2="253" y2="200" class="stroke-border/60" stroke-width="1.2"></line>
      <line x1="320" y1="188" x2="320" y2="200" class="stroke-border/60" stroke-width="1.2"></line>
      <line x1="253" y1="200" x2="320" y2="200" class="stroke-border/60" stroke-width="1.2"></line>
      <text
        x="286"
        y="218"
        text-anchor="middle"
        class="fill-muted-foreground/70 text-sm"
        letter-spacing="0.5">infinitely many fractions between any two</text
      >
    </g>

    <text
      x="320"
      y="40"
      text-anchor="middle"
      class="fill-muted-foreground/80 text-sm"
      letter-spacing="1.5">ℚ · THE DENSE NUMBER LINE</text
    >
  </svg>
</Figure>
