---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="lex flex-col items-center">
  <svg viewBox="0 0 540 220" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-xl">
    <style>
      .rat-axis { stroke-dasharray: 500; animation: draw-in 0.7s 0.1s ease-out both; }
      @keyframes draw-in {
        from { stroke-dashoffset: 500; opacity: 0; }
        to { stroke-dashoffset: 0; opacity: 1; }
      }
      .rat-l0 { animation: fade-up 0.4s 0.3s ease-out both; }
      .rat-l1 { animation: fade-up 0.5s 0.8s ease-out both; }
      .rat-l2 { animation: fade-up 0.5s 1.3s ease-out both; }
      .rat-l3 { animation: fade-up 0.5s 1.8s ease-out both; }
      .rat-bracket { animation: fade-up 0.4s 2.1s ease-out both; }
    </style>

    <line x1="40" y1="100" x2="500" y2="100" stroke="var(--border)" stroke-width="1.5" class="rat-axis"></line>
    <polygon points="500,96 500,104 512,100" fill="var(--border)" class="rat-axis"></polygon>

    <g class="rat-l0">
      <line x1="80" y1="92" x2="80" y2="108" stroke="var(--primary)" stroke-width="2.5"></line>
      <text x="80" y="78" text-anchor="middle" font-family="Georgia,serif" font-size="15" font-weight="bold" fill="var(--primary)">0</text>
      <line x1="440" y1="92" x2="440" y2="108" stroke="var(--primary)" stroke-width="2.5"></line>
      <text x="440" y="78" text-anchor="middle" font-family="Georgia,serif" font-size="15" font-weight="bold" fill="var(--primary)">1</text>
    </g>

    <g class="rat-l1">
      <line x1="186" y1="94" x2="186" y2="106" stroke="var(--secondary)" stroke-width="2"></line>
      <text x="186" y="126" text-anchor="middle" font-family="Georgia,serif" font-size="13" fill="var(--secondary)">⅓</text>
      <line x1="260" y1="93" x2="260" y2="107" stroke="var(--secondary)" stroke-width="2.5"></line>
      <text x="260" y="126" text-anchor="middle" font-family="Georgia,serif" font-size="14" fill="var(--secondary)">½</text>
    </g>

    <g class="rat-l2">
      <line x1="223" y1="95" x2="223" y2="105" stroke="var(--accent)" stroke-width="1.8"></line>
      <text x="223" y="147" text-anchor="middle" font-family="Georgia,serif" font-size="12" fill="var(--accent)">⁵⁄₁₂</text>
    </g>

    <g class="rat-l3">
      <line x1="241" y1="96" x2="241" y2="104" stroke="var(--muted-foreground)" stroke-width="1.4" opacity="0.7"></line>
      <text x="241" y="165" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="var(--muted-foreground)" opacity="0.7">¹¹⁄₂₄</text>
    </g>

    <g class="rat-bracket">
      <line x1="186" y1="170" x2="186" y2="183" stroke="var(--border)" stroke-width="1.2" opacity="0.6"></line>
      <line x1="260" y1="170" x2="260" y2="183" stroke="var(--border)" stroke-width="1.2" opacity="0.6"></line>
      <line x1="186" y1="183" x2="260" y2="183" stroke="var(--border)" stroke-width="1.2" opacity="0.6"></line>
      <text x="223" y="198" text-anchor="middle" font-family="Georgia,serif" font-size="10" fill="var(--muted-foreground)" opacity="0.7" letter-spacing="0.5">infinitely many fractions between any two</text>
    </g>

    <text x="270" y="36" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="var(--muted-foreground)" letter-spacing="1.5" opacity="0.8">ℚ · THE DENSE NUMBER LINE</text>
  </svg>
</Figure>
