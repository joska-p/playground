---
import Figure from "./figure.astro";
---

<Figure className="lex flex-col items-center">
  <svg viewBox="0 0 540 220" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-xl">
    <style>
      .rat-axis {
        animation: rat-in 0.7s 0.1s ease-out both;
      }
      @keyframes rat-in {
        from {
          opacity: 0;
          stroke-dashoffset: 500;
        }
        to {
          opacity: 1;
          stroke-dashoffset: 0;
        }
      }
      .rat-level-0 {
        animation: level-appear 0.4s 0.3s ease-out both;
      }
      .rat-level-1 {
        animation: level-appear 0.5s 0.8s ease-out both;
      }
      .rat-level-2 {
        animation: level-appear 0.5s 1.3s ease-out both;
      }
      .rat-level-3 {
        animation: level-appear 0.5s 1.8s ease-out both;
      }
      @keyframes level-appear {
        from {
          opacity: 0;
          transform: translateY(-6px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .rat-bracket {
        animation: level-appear 0.4s 2.1s ease-out both;
      }
    </style>

    <!-- main axis -->
    <line
      x1="40"
      y1="100"
      x2="500"
      y2="100"
      stroke="var(--border)"
      stroke-width="1.5"
      stroke-dasharray="500"
      class="rat-axis"></line>
    <!-- arrowheads -->
    <polygon points="500,96 500,104 512,100" fill="var(--border)" class="rat-axis"></polygon>

    <!-- Level 0: 0 and 1 -->
    <g class="rat-level-0">
      <!-- 0 -->
      <line x1="80" y1="92" x2="80" y2="108" stroke="var(--primary)" stroke-width="2.5"></line>
      <text
        x="80"
        y="78"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="15"
        font-weight="bold"
        fill="var(--primary)">0</text
      >
      <!-- 1 -->
      <line x1="440" y1="92" x2="440" y2="108" stroke="var(--primary)" stroke-width="2.5"></line>
      <text
        x="440"
        y="78"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="15"
        font-weight="bold"
        fill="var(--primary)">1</text
      >
    </g>

    <!-- Level 1: 1/3 and 1/2 -->
    <g class="rat-level-1">
      <!-- 1/3 at x≈186 -->
      <line x1="186" y1="94" x2="186" y2="106" stroke="var(--secondary)" stroke-width="2"></line>
      <text
        x="186"
        y="126"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="13"
        fill="var(--secondary)">⅓</text
      >
      <!-- 1/2 at x=260 -->
      <line x1="260" y1="93" x2="260" y2="107" stroke="var(--secondary)" stroke-width="2.5"></line>
      <text
        x="260"
        y="126"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="14"
        fill="var(--secondary)">½</text
      >
    </g>

    <!-- Level 2: 5/12 between 1/3 and 1/2 -->
    <g class="rat-level-2">
      <!-- 5/12 at x≈223 -->
      <line x1="223" y1="95" x2="223" y2="105" stroke="var(--accent)" stroke-width="1.8"></line>
      <text
        x="223"
        y="147"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="12"
        fill="var(--accent)">⁵⁄₁₂</text
      >
      <!-- connecting ticks: 5/12 is midpoint of 1/3 and 1/2 -->
    </g>

    <!-- Level 3: 11/24 between 5/12 and 1/2 -->
    <g class="rat-level-3">
      <!-- 11/24 at x≈241 -->
      <line
        x1="241"
        y1="96"
        x2="241"
        y2="104"
        stroke="var(--muted-foreground)"
        stroke-width="1.4"
        opacity="0.7"></line>
      <text
        x="241"
        y="165"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="11"
        fill="var(--muted-foreground)"
        opacity="0.7">¹¹⁄₂₄</text
      >
    </g>

    <!-- zoom bracket showing the [1/3, 1/2] interval -->
    <g class="rat-bracket">
      <!-- vertical bracket lines -->
      <line
        x1="186"
        y1="170"
        x2="186"
        y2="183"
        stroke="var(--border)"
        stroke-width="1.2"
        opacity="0.6"></line>
      <line
        x1="260"
        y1="170"
        x2="260"
        y2="183"
        stroke="var(--border)"
        stroke-width="1.2"
        opacity="0.6"></line>
      <line
        x1="186"
        y1="183"
        x2="260"
        y2="183"
        stroke="var(--border)"
        stroke-width="1.2"
        opacity="0.6"></line>
      <text
        x="223"
        y="198"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="10"
        fill="var(--muted-foreground)"
        opacity="0.7"
        letter-spacing="0.5"
      >
        infinitely many fractions between any two
      </text>
    </g>

    <!-- top label -->
    <text
      x="270"
      y="36"
      text-anchor="middle"
      font-family="Georgia,serif"
      font-size="11"
      fill="var(--muted-foreground)"
      letter-spacing="1.5"
      opacity="0.8">ℚ · THE DENSE NUMBER LINE</text
    >
  </svg>
</Figure>
