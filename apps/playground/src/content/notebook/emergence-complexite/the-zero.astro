---
import Figure from "./figure.astro";
import "./common-animations.css";
import SvgNode from "./SvgNode.astro";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 520 240" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg">
    <style>
      .z-crisis-line { stroke-dasharray: 400; animation: draw-in 0.8s 0.1s ease-out both; }
      @keyframes draw-in { from { stroke-dashoffset: 400; opacity: 0; } to { stroke-dashoffset: 0; opacity: 1; } }
      .z-question { animation: fade-up 0.6s 1s ease-out both; }
      .z-crack { animation: fade-in 0.4s 1.5s ease-out both; }
      .z-resolution-line { stroke-dasharray: 400; animation: draw-res 0.8s 2s ease-out both; }
      @keyframes draw-res { from { stroke-dashoffset: 400; opacity: 0; } to { stroke-dashoffset: 0; opacity: 1; } }
      .z-zero { animation: pop-in 0.6s 2.6s cubic-bezier(0.34, 1.56, 0.64, 1) both; transform-origin: 260px 190px; }
      .z-label { animation: fade-up 0.5s 3s ease-out both; }
    </style>

    <defs>
      <marker id="z-fwd" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="var(--secondary)"></path>
      </marker>
    </defs>

    <!-- Top number line: 1, 2, 3 with crisis at 0 -->
    <line x1="60" y1="70" x2="420" y2="70" stroke="var(--border)" stroke-width="1.5" class="z-crisis-line"></line>

    <g stroke="var(--border)" stroke-width="1.2" opacity="0.5">
      <line x1="100" y1="62" x2="100" y2="78"></line>
      <line x1="180" y1="62" x2="180" y2="78"></line>
      <line x1="260" y1="62" x2="260" y2="78"></line>
      <line x1="340" y1="62" x2="340" y2="78"></line>
    </g>

    <g font-family="Georgia,serif" font-size="14" font-weight="bold" text-anchor="middle" fill="var(--primary)">
      <text x="100" y="48" class="z-crisis-line">1</text>
      <text x="180" y="48" class="z-crisis-line">2</text>
      <text x="340" y="48" class="z-crisis-line">3</text>
    </g>

    <!-- Crisis: the void at 0 -->
    <g class="z-question">
      <rect x="220" y="30" width="80" height="36" rx="6" fill="var(--card)" stroke="var(--accent)" stroke-width="2" opacity="0.95"></rect>
      <text x="260" y="55" text-anchor="middle" font-family="Georgia,serif" font-size="22" font-weight="bold" fill="var(--accent)">?</text>
    </g>

    <!-- Crack/abyss at position 0 -->
    <g class="z-crack">
      <line x1="250" y1="70" x2="230" y2="100" stroke="var(--accent)" stroke-width="2" opacity="0.8"></line>
      <line x1="250" y1="70" x2="270" y2="100" stroke="var(--accent)" stroke-width="2" opacity="0.8"></line>
      <line x1="230" y1="100" x2="245" y2="120" stroke="var(--accent)" stroke-width="1.5" opacity="0.5"></line>
      <line x1="270" y1="100" x2="255" y2="125" stroke="var(--accent)" stroke-width="1.5" opacity="0.5"></line>
    </g>

    <!-- "3 - 3" label above the void -->
    <text x="100" y="105" text-anchor="middle" font-family="Georgia,serif" font-size="12" fill="var(--accent)" class="z-question">3 − 3 =</text>
    <text x="180" y="105" text-anchor="middle" font-family="Georgia,serif" font-size="12" fill="var(--accent)" class="z-question">3 − 5 =</text>

    <!-- Divider between crisis and resolution -->
    <line x1="60" y1="145" x2="420" y2="145" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="6,4" opacity="0.3" class="z-crack"></line>

    <!-- Resolution: new number line with 0 -->
    <line x1="60" y1="190" x2="420" y2="190" stroke="var(--border)" stroke-width="1.5" class="z-resolution-line"></line>

    <g stroke="var(--border)" stroke-width="1.2" opacity="0.5">
      <line x1="100" y1="182" x2="100" y2="198"></line>
      <line x1="180" y1="182" x2="180" y2="198"></line>
      <line x1="260" y1="182" x2="260" y2="198"></line>
      <line x1="340" y1="182" x2="340" y2="198"></line>
      <line x1="420" y1="182" x2="420" y2="198"></line>
    </g>

    <g class="z-zero">
      <SvgNode cx={260} cy={190} label="0" r={20} labelSize={22} stroke="var(--primary)" />
    </g>

    <g font-family="Georgia,serif" font-size="13" font-weight="bold" text-anchor="middle" fill="var(--border)" opacity="0.6">
      <text x="100" y="218" class="z-resolution-line">−2</text>
      <text x="180" y="218" class="z-resolution-line">−1</text>
      <text x="340" y="218" class="z-resolution-line">1</text>
      <text x="420" y="218" class="z-resolution-line">2</text>
    </g>

    <g class="z-label">
      <text x="260" y="234" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="var(--muted-foreground)" letter-spacing="1">zero emerges · 3 − 3 = 0 · 3 − 5 = −2</text>
    </g>
  </svg>
</Figure>
