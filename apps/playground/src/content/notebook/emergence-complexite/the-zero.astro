---
import Figure from "./figure.astro";
import "./common-animations.css";
import SvgNode from "./SvgNode.astro";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 640 260" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl">
    <style>
      .z-crisis-line {
        stroke-dasharray: 400;
        animation: draw-in 0.8s 0.1s ease-out both;
      }
      @keyframes draw-in {
        from {
          stroke-dashoffset: 400;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      .z-question {
        animation: fade-up 0.6s 1s ease-out both;
      }
      .z-crack {
        animation: fade-in 0.4s 1.5s ease-out both;
      }
      .z-resolution-line {
        stroke-dasharray: 400;
        animation: draw-res 0.8s 2s ease-out both;
      }
      @keyframes draw-res {
        from {
          stroke-dashoffset: 400;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      .z-zero {
        animation: pop-in 0.6s 2.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 320px 200px;
      }
      .z-label {
        animation: fade-up 0.5s 3s ease-out both;
      }
    </style>

    <defs>
      <marker id="z-fwd" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" class="fill-secondary"></path>
      </marker>
    </defs>

    <line x1="80" y1="74" x2="540" y2="74" class="stroke-border z-crisis-line" stroke-width="1.5"
    ></line>

    <g class="stroke-border" stroke-width="1.2" opacity="0.5">
      <line x1="140" y1="66" x2="140" y2="82"></line>
      <line x1="230" y1="66" x2="230" y2="82"></line>
      <line x1="320" y1="66" x2="320" y2="82"></line>
      <line x1="410" y1="66" x2="410" y2="82"></line>
    </g>

    <g class="fill-primary text-anchor-middle text-lg font-bold">
      <text x="140" y="52" class="z-crisis-line">1</text>
      <text x="230" y="52" class="z-crisis-line">2</text>
      <text x="410" y="52" class="z-crisis-line">3</text>
    </g>

    <g class="z-question">
      <rect
        x="280"
        y="34"
        width="80"
        height="36"
        rx="6"
        class="fill-card stroke-accent"
        stroke-width="2"
        opacity="0.95"></rect>
      <text x="320" y="58" text-anchor="middle" class="fill-accent text-2xl font-bold">?</text>
    </g>

    <g class="z-crack">
      <line x1="310" y1="74" x2="280" y2="104" class="stroke-accent" stroke-width="2" opacity="0.8"
      ></line>
      <line x1="310" y1="74" x2="330" y2="104" class="stroke-accent" stroke-width="2" opacity="0.8"
      ></line>
      <line
        x1="280"
        y1="104"
        x2="300"
        y2="128"
        class="stroke-accent"
        stroke-width="1.5"
        opacity="0.5"></line>
      <line
        x1="330"
        y1="104"
        x2="310"
        y2="132"
        class="stroke-accent"
        stroke-width="1.5"
        opacity="0.5"></line>
    </g>

    <text x="140" y="112" text-anchor="middle" class="fill-accent z-question text-sm">3 − 3 =</text>
    <text x="230" y="112" text-anchor="middle" class="fill-accent z-question text-sm">3 − 5 =</text>

    <line
      x1="80"
      y1="155"
      x2="540"
      y2="155"
      class="stroke-border/30"
      stroke-width="0.5"
      stroke-dasharray="6,4"
      class="z-crack"></line>

    <line
      x1="80"
      y1="200"
      x2="540"
      y2="200"
      class="stroke-border"
      stroke-width="1.5"
      class="z-resolution-line"></line>

    <g class="stroke-border" stroke-width="1.2" opacity="0.5">
      <line x1="140" y1="192" x2="140" y2="208"></line>
      <line x1="230" y1="192" x2="230" y2="208"></line>
      <line x1="320" y1="192" x2="320" y2="208"></line>
      <line x1="410" y1="192" x2="410" y2="208"></line>
      <line x1="500" y1="192" x2="500" y2="208"></line>
    </g>

    <g class="z-zero">
      <SvgNode cx={320} cy={200} label="0" r={20} />
    </g>

    <g class="fill-border/60 text-anchor-middle text-base font-bold">
      <text x="140" y="228" class="z-resolution-line">−2</text>
      <text x="230" y="228" class="z-resolution-line">−1</text>
      <text x="410" y="228" class="z-resolution-line">1</text>
      <text x="500" y="228" class="z-resolution-line">2</text>
    </g>

    <g class="z-label">
      <text
        x="320"
        y="252"
        text-anchor="middle"
        class="fill-muted-foreground text-sm"
        letter-spacing="1">zero emerges · 3 − 3 = 0 · 3 − 5 = −2</text
      >
    </g>
  </svg>
</Figure>
