---
import Figure from "./figure.astro";
import "./common-animations.css";
import SvgNode from "./SvgNode.astro";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 520 200" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg">
    <style>
      .zero-line { stroke-dasharray: 400; animation: draw-in 0.8s 0.1s ease-out both; }
      @keyframes draw-in {
        from { stroke-dashoffset: 400; opacity: 0; }
        to { stroke-dashoffset: 0; opacity: 1; }
      }
      .z-fwd { stroke-dasharray: 160; animation: fade-in 0.9s 0.3s ease-out both; }
      .z-bwd { stroke-dasharray: 160; animation: fade-in 0.9s 0.9s ease-out both; }
      .z-pop { animation: pop-in 0.6s 1.6s cubic-bezier(0.34, 1.56, 0.64, 1) both; transform-origin: 260px 96px; }
      .z-label { animation: fade-up 0.5s 2s ease-out both; transform-origin: 260px 150px; }
    </style>

    <defs>
      <marker id="z-fwd" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="var(--secondary)"></path>
      </marker>
      <marker id="z-bwd" markerWidth="8" markerHeight="8" refX="1" refY="3" orient="auto-start-reverse">
        <path d="M0,0 L0,6 L8,3 z" fill="var(--accent)"></path>
      </marker>
    </defs>

    <line x1="60" y1="96" x2="460" y2="96" stroke="var(--border)" stroke-width="1.5" class="zero-line"></line>

    <g stroke="var(--border)" stroke-width="1.2" opacity="0.5">
      <line x1="100" y1="88" x2="100" y2="104"></line>
      <line x1="140" y1="88" x2="140" y2="104"></line>
      <line x1="180" y1="88" x2="180" y2="104"></line>
      <line x1="220" y1="88" x2="220" y2="104"></line>
      <line x1="300" y1="88" x2="300" y2="104"></line>
      <line x1="340" y1="88" x2="340" y2="104"></line>
      <line x1="380" y1="88" x2="380" y2="104"></line>
      <line x1="420" y1="88" x2="420" y2="104"></line>
    </g>

    <line x1="264" y1="64" x2="420" y2="64" stroke="var(--secondary)" stroke-width="2.5" marker-end="url(#z-fwd)" class="z-fwd"></line>
    <text x="342" y="54" text-anchor="middle" font-family="Georgia,serif" font-size="12" fill="var(--secondary)" class="z-fwd">+3</text>

    <line x1="256" y1="128" x2="100" y2="128" stroke="var(--accent)" stroke-width="2.5" marker-end="url(#z-bwd)" class="z-bwd"></line>
    <text x="178" y="148" text-anchor="middle" font-family="Georgia,serif" font-size="12" fill="var(--accent)" class="z-bwd">−3</text>

    <g class="z-pop">
      <SvgNode cx={260} cy={96} label="0" r={20} labelSize={22} stroke="var(--primary)" />
    </g>

    <g class="z-label">
      <text x="260" y="175" text-anchor="middle" font-family="Georgia,serif" font-size="12" fill="var(--muted-foreground)" letter-spacing="1">3 − 3 = 0 · the return to nothing</text>
    </g>
  </svg>
</Figure>
