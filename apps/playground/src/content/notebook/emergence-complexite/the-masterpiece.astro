---
const rows = [
  {
    set: "ℕ",
    cls: "text-[color:var(--category-tutorial)]",
    name: "Natural Numbers",
    rule: "+1 from nothing",
    eq: "1, 2, 3, …",
  },
  {
    set: "ℤ",
    cls: "text-[color:var(--category-how-to)]",
    name: "Integers",
    rule: "+ zero & negatives",
    eq: "…, −2, −1, 0, 1, …",
  },
  {
    set: "ℚ",
    cls: "text-[color:var(--category-explanation)]",
    name: "Rationals",
    rule: "+ fractions",
    eq: "a/b, b ≠ 0",
  },
  {
    set: "ℝ",
    cls: "text-[color:var(--category-data-viz)]",
    name: "Reals",
    rule: "+ √2, π, e …",
    eq: "√2, π, e, …",
  },
  { set: "ℂ", cls: "text-primary", name: "Complex", rule: "+ imaginary axis", eq: "a + ib" },
];

const arrows = [
  "Reverse addition → subtraction unsolvable",
  "Reverse multiplication → division unsolvable",
  "Completeness gaps → irrationals",
  "Reverse square root → x² = −1 unsolvable",
];

const chips = [
  {
    label: "1",
    cls: "text-[color:var(--category-tutorial)]   border-[color:var(--category-tutorial)]   bg-[color:var(--category-tutorial)]/10",
  },
  {
    label: "0",
    cls: "text-[color:var(--category-how-to)]     border-[color:var(--category-how-to)]     bg-[color:var(--category-how-to)]/10",
  },
  {
    label: "π",
    cls: "text-[color:var(--category-data-viz)]   border-[color:var(--category-data-viz)]   bg-[color:var(--category-data-viz)]/10",
  },
  {
    label: "e",
    cls: "text-[color:var(--category-explanation)] border-[color:var(--category-explanation)] bg-[color:var(--category-explanation)]/10",
  },
  {
    label: "i",
    cls: "text-primary                            border-primary                            bg-primary/10",
  },
];
---

<div class="bg-card border-border my-10 overflow-hidden rounded-lg border font-sans">
  <!-- Header -->
  <div
    class="text-muted-foreground border-border/50 border-b px-4 py-3 text-center text-[0.65rem] font-semibold tracking-[0.16em] uppercase"
  >
    The Full Architecture of Numbers
  </div>

  <!-- Tower -->
  <div class="flex flex-col gap-0 px-6 py-5">
    {
      rows.map((row, i) => (
        <>
          <div class="hover:bg-muted grid grid-cols-[2.5rem_1fr_auto] items-center gap-4 rounded-md px-4 py-3 transition-colors duration-150">
            <span class={`text-center text-[1.5rem] leading-none font-bold ${row.cls}`}>
              {row.set}
            </span>
            <div>
              <div class="text-foreground text-[0.85rem] font-semibold">{row.name}</div>
              <div class="text-muted-foreground mt-0.5 font-mono text-[0.7rem]">{row.rule}</div>
            </div>
            <div class="text-muted-foreground text-right text-[0.85rem] whitespace-nowrap">
              {row.eq}
            </div>
          </div>

          {i < arrows.length && (
            <div class="flex items-center gap-3 py-0.5 pl-7">
              <div class="bg-border ml-3 h-7 w-px shrink-0" />
              <span class="text-muted-foreground/60 flex-1 text-[0.65rem] italic">{arrows[i]}</span>
              <span class="text-border mr-1 text-sm">↓</span>
            </div>
          )}
        </>
      ))
    }
  </div>

  <!-- Euler banner -->
  <div
    class="border-border/50 bg-muted/40 flex flex-col items-center gap-2 border-t px-6 py-6 text-center"
  >
    <div class="text-muted-foreground text-[0.62rem] font-semibold tracking-[0.15em] uppercase">
      All paths converge
    </div>
    <div class="text-foreground text-[2rem] leading-snug">
      e<sup class="align-super">iπ</sup> + 1 = 0
    </div>
    <div class="mt-1 flex flex-wrap items-center justify-center gap-2">
      {
        chips.map((chip, i) => (
          <>
            <span class={`rounded-full border px-2.5 py-0.5 text-sm font-bold ${chip.cls}`}>
              {chip.label}
            </span>
            {i < chips.length - 1 && <span class="text-border text-sm">·</span>}
          </>
        ))
      }
    </div>
  </div>
</div>
