---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 560 240" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-xl">
    <style>
      .exp-axis { animation: fade-in 0.6s 0.1s ease-out both; }
      .exp-curve { stroke-dasharray: 800; animation: draw-curve 1.4s 0.4s ease-out both; }
      @keyframes draw-curve {
        from { stroke-dashoffset: 800; opacity: 0; }
        to { stroke-dashoffset: 0; opacity: 1; }
      }
      .exp-d { animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
      .exp-d1 { animation-delay: 0.5s; }
      .exp-d2 { animation-delay: 0.65s; }
      .exp-d3 { animation-delay: 0.8s; }
      .exp-d4 { animation-delay: 0.95s; }
      .exp-d5 { animation-delay: 1.1s; }
      .exp-d6 { animation-delay: 1.25s; }
      .exp-label { animation: fade-in 0.4s 1.5s ease-out both; }
    </style>

    <g class="exp-axis" stroke="var(--border)" stroke-width="1.5">
      <line x1="70" y1="20" x2="70" y2="190"></line>
      <polygon points="66,20 74,20 70,10" fill="var(--border)"></polygon>
      <line x1="70" y1="190" x2="520" y2="190"></line>
      <polygon points="520,186 520,194 530,190" fill="var(--border)"></polygon>
    </g>

    <g font-family="Georgia,serif" font-size="11" text-anchor="middle" fill="var(--muted-foreground)" class="exp-axis">
      <text x="70" y="206">0</text>
      <text x="140" y="206">1</text>
      <text x="210" y="206">2</text>
      <text x="280" y="206">3</text>
      <text x="350" y="206">4</text>
      <text x="420" y="206">5</text>
      <text x="490" y="206">6</text>
    </g>
    <text x="300" y="220" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="var(--muted-foreground)" class="exp-axis">n</text>
    <text x="55" y="100" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="var(--muted-foreground)" transform="rotate(-90,55,100)" class="exp-axis">10ⁿ</text>

    <g stroke="var(--border)" stroke-width="0.5" opacity="0.3" class="exp-axis">
      <line x1="140" y1="20" x2="140" y2="190"></line>
      <line x1="210" y1="20" x2="210" y2="190"></line>
      <line x1="280" y1="20" x2="280" y2="190"></line>
      <line x1="350" y1="20" x2="350" y2="190"></line>
      <line x1="420" y1="20" x2="420" y2="190"></line>
      <line x1="490" y1="20" x2="490" y2="190"></line>
    </g>

    <path d="M70,190 C100,188 140,183 210,168 S330,130 490,22" fill="none" stroke="var(--secondary)" stroke-width="2.5" stroke-linecap="round" class="exp-curve"></path>

    {
      [
        { x: 70, y: 190, label: "1", color: "var(--secondary)", cls: "exp-d1" },
        { x: 140, y: 185, label: "10", color: "var(--secondary)", cls: "exp-d2" },
        { x: 210, y: 171, label: "100", color: "var(--secondary)", cls: "exp-d3" },
        { x: 280, y: 143, label: "1k", color: "var(--secondary)", cls: "exp-d4" },
        { x: 350, y: 109, label: "10k", color: "var(--accent)", cls: "exp-d5" },
        { x: 420, y: 66, label: "100k", color: "var(--accent)", cls: "exp-d5" },
      ].map((d) => (
        <g class={`exp-d ${d.cls}`} style={`transform-origin:${d.x}px ${d.y}px`}>
          <circle cx={d.x} cy={d.y} r="5" fill={d.color} stroke="var(--card)" stroke-width="1.5"></circle>
          <text x={d.x + 5} y={d.y - 6} font-family="Georgia,serif" font-size="9" fill={d.color}>{d.label}</text>
        </g>
      ))
    }

    <g class="exp-d exp-d6" style="transform-origin:490px 22px">
      <circle cx="490" cy="22" r="5" fill="var(--accent)" stroke="var(--card)" stroke-width="1.5"></circle>
      <text x="470" y="18" font-family="Georgia,serif" font-size="9" fill="var(--accent)">1M</text>
    </g>

    <g class="exp-label">
      <text x="130" y="50" font-family="Georgia,serif" font-size="13" fill="var(--secondary)" font-style="italic">10ⁿ grows without bound</text>
    </g>
  </svg>
</Figure>
