---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 640 260" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl">
    <style>
      .exp-axis {
        animation: fade-in 0.6s 0.1s ease-out both;
      }
      .exp-curve {
        stroke-dasharray: 800;
        animation: draw-curve 1.4s 0.4s ease-out both;
      }
      @keyframes draw-curve {
        from {
          stroke-dashoffset: 800;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      .exp-d {
        animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }
      .exp-d1 {
        animation-delay: 0.5s;
      }
      .exp-d2 {
        animation-delay: 0.65s;
      }
      .exp-d3 {
        animation-delay: 0.8s;
      }
      .exp-d4 {
        animation-delay: 0.95s;
      }
      .exp-d5 {
        animation-delay: 1.1s;
      }
      .exp-d6 {
        animation-delay: 1.25s;
      }
      .exp-label {
        animation: fade-in 0.4s 1.5s ease-out both;
      }
    </style>

    <g class="exp-axis stroke-border" stroke-width="1.5">
      <line x1="80" y1="20" x2="80" y2="200"></line>
      <polygon points="76,20 84,20 80,12" class="fill-border"></polygon>
      <line x1="80" y1="200" x2="580" y2="200"></line>
      <polygon points="580,196 580,204 592,200" class="fill-border"></polygon>
    </g>

    <g class="fill-muted-foreground text-anchor-middle exp-axis text-sm">
      <text x="80" y="218">0</text>
      <text x="163" y="218">1</text>
      <text x="247" y="218">2</text>
      <text x="330" y="218">3</text>
      <text x="413" y="218">4</text>
      <text x="497" y="218">5</text>
      <text x="580" y="218">6</text>
    </g>
    <text x="330" y="238" text-anchor="middle" class="fill-muted-foreground exp-axis text-sm"
      >n</text
    >
    <text
      x="62"
      y="106"
      text-anchor="middle"
      class="fill-muted-foreground exp-axis text-sm"
      transform="rotate(-90,62,106)">10ⁿ</text
    >

    <g class="stroke-border/30 exp-axis" stroke-width="0.5">
      <line x1="163" y1="20" x2="163" y2="200"></line>
      <line x1="247" y1="20" x2="247" y2="200"></line>
      <line x1="330" y1="20" x2="330" y2="200"></line>
      <line x1="413" y1="20" x2="413" y2="200"></line>
      <line x1="497" y1="20" x2="497" y2="200"></line>
      <line x1="580" y1="20" x2="580" y2="200"></line>
    </g>

    <path
      d="M80,200 C105,198 163,194 247,180 S350,145 580,22"
      fill="none"
      class="exp-curve stroke-secondary"
      stroke-width="2.5"
      stroke-linecap="round"></path>

    {
      [
        { x: 80, y: 200, label: "1", color: "var(--secondary)", cls: "exp-d1" },
        { x: 163, y: 196, label: "10", color: "var(--secondary)", cls: "exp-d2" },
        { x: 247, y: 184, label: "100", color: "var(--secondary)", cls: "exp-d3" },
        { x: 330, y: 160, label: "1k", color: "var(--secondary)", cls: "exp-d4" },
        { x: 413, y: 126, label: "10k", color: "var(--accent)", cls: "exp-d5" },
        { x: 497, y: 82, label: "100k", color: "var(--accent)", cls: "exp-d5" },
      ].map((d) => (
        <g class={`exp-d ${d.cls}`} style={`transform-origin:${d.x}px ${d.y}px`}>
          <circle cx={d.x} cy={d.y} r="6" fill={d.color} stroke="var(--card)" stroke-width="1.5" />
          <text x={d.x + 8} y={d.y - 8} class="text-sm" fill={d.color}>
            {d.label}
          </text>
        </g>
      ))
    }

    <g class="exp-d exp-d6" style="transform-origin:580px 22px">
      <circle cx="580" cy="22" r="6" fill="var(--accent)" stroke="var(--card)" stroke-width="1.5"
      ></circle>
      <text x="550" y="16" class="fill-accent text-sm">1M</text>
    </g>

    <g class="exp-label">
      <text x="150" y="52" class="fill-secondary text-base italic">10ⁿ grows without bound</text>
    </g>
  </svg>
</Figure>
