---
import Figure from "./figure.astro";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 560 180" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-xl">
    <style>
      .int-axis {
        animation: axis-expand 1s 0.1s ease-out both;
        transform-origin: 280px 90px;
      }
      @keyframes axis-expand {
        from {
          transform: scaleX(0);
          opacity: 0;
        }
        to {
          transform: scaleX(1);
          opacity: 1;
        }
      }
      .int-neg {
        animation: int-reveal 0.5s ease-out both;
      }
      .int-neg-5 {
        animation-delay: 0.15s;
      }
      .int-neg-4 {
        animation-delay: 0.25s;
      }
      .int-neg-3 {
        animation-delay: 0.35s;
      }
      .int-neg-2 {
        animation-delay: 0.45s;
      }
      .int-neg-1 {
        animation-delay: 0.55s;
      }
      .int-zero {
        animation: zero-bloom 0.6s 0.65s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 280px 90px;
      }
      .int-pos {
        animation: int-reveal 0.5s ease-out both;
      }
      .int-pos-1 {
        animation-delay: 0.75s;
      }
      .int-pos-2 {
        animation-delay: 0.85s;
      }
      .int-pos-3 {
        animation-delay: 0.95s;
      }
      .int-pos-4 {
        animation-delay: 1.05s;
      }
      .int-pos-5 {
        animation-delay: 1.15s;
      }
      @keyframes int-reveal {
        from {
          opacity: 0;
          transform: translateY(-8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes zero-bloom {
        from {
          opacity: 0;
          transform: scale(0.3);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }
      .int-arrows {
        animation: int-reveal 0.5s 1.3s ease-out both;
      }
    </style>

    <defs>
      <marker id="int-left" markerWidth="8" markerHeight="8" refX="1" refY="3" orient="auto">
        <path d="M8,0 L8,6 L0,3 z" fill="var(--accent)"></path>
      </marker>
      <marker id="int-right" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="var(--secondary)"></path>
      </marker>
    </defs>

    <!-- axis -->
    <line
      x1="30"
      y1="90"
      x2="530"
      y2="90"
      stroke="var(--border)"
      stroke-width="1.5"
      class="int-axis"></line>

    <!-- arrowheads -->
    <g class="int-arrows">
      <line
        x1="50"
        y1="90"
        x2="30"
        y2="90"
        stroke="var(--accent)"
        stroke-width="2"
        marker-end="url(#int-left)"></line>
      <line
        x1="510"
        y1="90"
        x2="530"
        y2="90"
        stroke="var(--secondary)"
        stroke-width="2"
        marker-end="url(#int-right)"></line>
    </g>

    <!-- negative numbers -->
    <g font-family="Georgia,serif" font-size="18" font-weight="bold" text-anchor="middle">
      <g class="int-neg int-neg-5">
        <line
          x1="60"
          y1="82"
          x2="60"
          y2="98"
          stroke="var(--accent)"
          stroke-width="1.5"
          opacity="0.6"></line>
        <text x="60" y="120" fill="var(--accent)" opacity="0.6">−5</text>
      </g>
      <g class="int-neg int-neg-4">
        <line
          x1="104"
          y1="82"
          x2="104"
          y2="98"
          stroke="var(--accent)"
          stroke-width="1.5"
          opacity="0.7"></line>
        <text x="104" y="120" fill="var(--accent)" opacity="0.7">−4</text>
      </g>
      <g class="int-neg int-neg-3">
        <line
          x1="148"
          y1="82"
          x2="148"
          y2="98"
          stroke="var(--accent)"
          stroke-width="1.5"
          opacity="0.8"></line>
        <text x="148" y="120" fill="var(--accent)" opacity="0.8">−3</text>
      </g>
      <g class="int-neg int-neg-2">
        <line
          x1="192"
          y1="82"
          x2="192"
          y2="98"
          stroke="var(--accent)"
          stroke-width="1.8"
          opacity="0.9"></line>
        <text x="192" y="120" fill="var(--accent)" opacity="0.9">−2</text>
      </g>
      <g class="int-neg int-neg-1">
        <line x1="236" y1="82" x2="236" y2="98" stroke="var(--accent)" stroke-width="2"></line>
        <text x="236" y="120" fill="var(--accent)">−1</text>
      </g>
    </g>

    <!-- zero -->
    <g class="int-zero">
      <circle cx="280" cy="90" r="16" fill="var(--card)" stroke="var(--primary)" stroke-width="2.5"
      ></circle>
      <text
        x="280"
        y="97"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="18"
        font-weight="bold"
        fill="var(--primary)">0</text
      >
    </g>

    <!-- positive numbers -->
    <g font-family="Georgia,serif" font-size="18" font-weight="bold" text-anchor="middle">
      <g class="int-pos int-pos-1">
        <line x1="324" y1="82" x2="324" y2="98" stroke="var(--secondary)" stroke-width="2"></line>
        <text x="324" y="120" fill="var(--secondary)">1</text>
      </g>
      <g class="int-pos int-pos-2">
        <line
          x1="368"
          y1="82"
          x2="368"
          y2="98"
          stroke="var(--secondary)"
          stroke-width="1.8"
          opacity="0.9"></line>
        <text x="368" y="120" fill="var(--secondary)" opacity="0.9">2</text>
      </g>
      <g class="int-pos int-pos-3">
        <line
          x1="412"
          y1="82"
          x2="412"
          y2="98"
          stroke="var(--secondary)"
          stroke-width="1.5"
          opacity="0.8"></line>
        <text x="412" y="120" fill="var(--secondary)" opacity="0.8">3</text>
      </g>
      <g class="int-pos int-pos-4">
        <line
          x1="456"
          y1="82"
          x2="456"
          y2="98"
          stroke="var(--secondary)"
          stroke-width="1.5"
          opacity="0.7"></line>
        <text x="456" y="120" fill="var(--secondary)" opacity="0.7">4</text>
      </g>
      <g class="int-pos int-pos-5">
        <line
          x1="500"
          y1="82"
          x2="500"
          y2="98"
          stroke="var(--secondary)"
          stroke-width="1.5"
          opacity="0.6"></line>
        <text x="500" y="120" fill="var(--secondary)" opacity="0.6">5</text>
      </g>
    </g>

    <!-- symmetry brace + label -->
    <g class="int-arrows">
      <path
        d="M148,148 Q280,162 412,148"
        fill="none"
        stroke="var(--border)"
        stroke-width="1"
        opacity="0.5"
        stroke-dasharray="4,3"></path>
      <text
        x="280"
        y="168"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="11"
        fill="var(--muted-foreground)"
        letter-spacing="1.5">ℤ = "{" …, −2, −1, 0, 1, 2, … "}" · infinite in both directions</text
      >
    </g>
  </svg>
</Figure>
