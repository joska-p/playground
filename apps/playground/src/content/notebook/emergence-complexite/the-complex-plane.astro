---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure>
  <svg viewBox="0 0 640 320" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl">
    <style>
      .cp-axes {
        animation: fade-in 0.6s 0.1s ease-out both;
      }
      .cp-grid {
        animation: fade-in 0.5s 0.3s ease-out both;
      }
      .cp-dash-v {
        animation: cp-dash 0.6s 0.9s ease-out both;
      }
      .cp-dash-h {
        animation: cp-dash 0.6s 1.1s ease-out both;
      }
      @keyframes cp-dash {
        from {
          stroke-dashoffset: 200;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      .cp-point {
        animation: pop-in 0.5s 1.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 410px 116px;
      }
      .cp-label {
        animation: fade-in 0.4s 1.7s ease-out both;
      }
    </style>

    <g class="stroke-border/30 cp-grid" stroke-width="0.6">
      <line x1="130" y1="36" x2="130" y2="286"></line>
      <line x1="200" y1="36" x2="200" y2="286"></line>
      <line x1="270" y1="36" x2="270" y2="286"></line>
      <line x1="340" y1="36" x2="340" y2="286"></line>
      <line x1="410" y1="36" x2="410" y2="286"></line>
      <line x1="480" y1="36" x2="480" y2="286"></line>
      <line x1="550" y1="36" x2="550" y2="286"></line>
      <line x1="80" y1="60" x2="600" y2="60"></line>
      <line x1="80" y1="116" x2="600" y2="116"></line>
      <line x1="80" y1="172" x2="600" y2="172"></line>
      <line x1="80" y1="228" x2="600" y2="228"></line>
    </g>

    <g class="cp-axes stroke-border" stroke-width="1.8">
      <line x1="80" y1="172" x2="600" y2="172"></line>
      <polygon points="600,168 600,176 610,172" class="fill-border"></polygon>
      <line x1="270" y1="286" x2="270" y2="36"></line>
      <polygon points="266,36 274,36 270,28" class="fill-border"></polygon>
    </g>

    <g class="fill-muted-foreground text-anchor-middle cp-axes text-sm">
      <text x="340" y="190">1</text>
      <text x="410" y="190">2</text>
      <text x="480" y="190">3</text>
      <text x="550" y="190">4</text>
      <text x="200" y="190">−1</text>
      <text x="130" y="190">−2</text>
      <text x="256" y="120">2i</text>
      <text x="256" y="55">3i</text>
      <text x="256" y="246">−i</text>
      <text x="615" y="176" class="text-anchor-start">Re</text>
      <text x="270" y="24" text-anchor="middle">Im</text>
      <text x="258" y="186">0</text>
    </g>

    <line
      x1="480"
      y1="116"
      x2="480"
      y2="170"
      class="stroke-secondary cp-dash-v"
      stroke-width="1.4"
      stroke-dasharray="6,4"></line>
    <line
      x1="272"
      y1="116"
      x2="478"
      y2="116"
      class="stroke-accent cp-dash-h"
      stroke-width="1.4"
      stroke-dasharray="6,4"></line>

    <g class="cp-dash-v stroke-secondary" stroke-width="1.5">
      <line x1="475" y1="170" x2="485" y2="170" opacity="0.6"></line>
    </g>
    <g class="cp-dash-h stroke-accent" stroke-width="1.5">
      <line x1="268" y1="112" x2="272" y2="120" opacity="0.6"></line>
    </g>

    <text x="480" y="200" text-anchor="middle" class="fill-secondary cp-label text-sm">a = 3</text>
    <text x="248" y="118" text-anchor="end" class="fill-accent cp-label text-sm">b = 2</text>

    <g class="cp-point">
      <circle cx="480" cy="116" r="16" class="fill-primary/12"></circle>
      <circle cx="480" cy="116" r="7" class="fill-primary" stroke="var(--card)" stroke-width="2"
      ></circle>
    </g>

    <g class="cp-label">
      <rect
        x="492"
        y="94"
        width="90"
        height="30"
        rx="5"
        class="fill-card stroke-primary"
        stroke-width="1.2"
        opacity="0.95"></rect>
      <text x="537" y="115" text-anchor="middle" class="fill-primary text-base italic"
        >Z = 3 + 2i</text
      >
    </g>

    <text
      x="320"
      y="310"
      text-anchor="middle"
      class="fill-muted-foreground cp-label text-sm"
      letter-spacing="1"
    >
      the complex plane · every number a point in 2D space
    </text>
  </svg>
</Figure>
