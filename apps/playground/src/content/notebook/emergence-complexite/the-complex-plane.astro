---

---

<figure class="my-10 flex flex-col items-center">
  <svg viewBox="0 0 520 300" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg">
    <style>
      .cp-axes {
        animation: cp-in 0.6s 0.1s ease-out both;
      }
      @keyframes cp-in {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      .cp-grid {
        animation: cp-in 0.5s 0.3s ease-out both;
      }
      .cp-dash-v {
        animation: cp-dash 0.6s 0.9s ease-out both;
      }
      .cp-dash-h {
        animation: cp-dash 0.6s 1.1s ease-out both;
      }
      @keyframes cp-dash {
        from {
          stroke-dashoffset: 200;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      .cp-point {
        animation: cp-pop 0.5s 1.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 340px 110px;
      }
      @keyframes cp-pop {
        from {
          opacity: 0;
          transform: scale(0);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }
      .cp-label {
        animation: cp-in 0.4s 1.7s ease-out both;
      }
    </style>

    <!-- grid -->
    <g stroke="var(--border)" stroke-width="0.6" opacity="0.3" class="cp-grid">
      <!-- vertical -->
      <line x1="100" y1="30" x2="100" y2="270"></line>
      <line x1="160" y1="30" x2="160" y2="270"></line>
      <line x1="220" y1="30" x2="220" y2="270"></line>
      <line x1="280" y1="30" x2="280" y2="270"></line>
      <line x1="340" y1="30" x2="340" y2="270"></line>
      <line x1="400" y1="30" x2="400" y2="270"></line>
      <line x1="460" y1="30" x2="460" y2="270"></line>
      <!-- horizontal -->
      <line x1="60" y1="50" x2="480" y2="50"></line>
      <line x1="60" y1="110" x2="480" y2="110"></line>
      <line x1="60" y1="170" x2="480" y2="170"></line>
      <line x1="60" y1="230" x2="480" y2="230"></line>
    </g>

    <!-- axes -->
    <g class="cp-axes" stroke="var(--border)" stroke-width="1.8">
      <!-- real axis (horizontal, y=170) -->
      <line x1="60" y1="170" x2="480" y2="170"></line>
      <polygon points="480,166 480,174 490,170" fill="var(--border)"></polygon>
      <!-- imaginary axis (vertical, x=220) -->
      <line x1="220" y1="270" x2="220" y2="30"></line>
      <polygon points="216,30 224,30 220,22" fill="var(--border)"></polygon>
    </g>

    <!-- axis tick labels -->
    <g
      font-family="Georgia,serif"
      font-size="11"
      text-anchor="middle"
      fill="var(--muted-foreground)"
      class="cp-axes"
    >
      <!-- real axis -->
      <text x="280" y="186">1</text>
      <text x="340" y="186">2</text>
      <text x="400" y="186">3</text>
      <text x="460" y="186">4</text>
      <text x="160" y="186">−1</text>
      <text x="100" y="186">−2</text>
      <!-- imag axis -->
      <text x="206" y="115">2i</text>
      <text x="206" y="55">3i</text>
      <text x="206" y="235">−i</text>
      <!-- axis labels -->
      <text x="495" y="174" text-anchor="start">Re</text>
      <text x="220" y="18" text-anchor="middle">Im</text>
      <!-- origin -->
      <text x="208" y="184">0</text>
    </g>

    <!-- dashed projection lines -->
    <!-- Z = 3 + 2i → x_svg = 220+3*60=400, y_svg = 170-2*60=50 -->
    <line
      x1="400"
      y1="110"
      x2="400"
      y2="168"
      stroke="var(--secondary)"
      stroke-width="1.4"
      stroke-dasharray="6,4"
      class="cp-dash-v"></line>
    <line
      x1="222"
      y1="110"
      x2="398"
      y2="110"
      stroke="var(--accent)"
      stroke-width="1.4"
      stroke-dasharray="6,4"
      class="cp-dash-h"></line>

    <!-- tick marks at projection endpoints -->
    <g class="cp-dash-v" stroke="var(--secondary)" stroke-width="1.5">
      <line x1="395" y1="168" x2="405" y2="168" opacity="0.6"></line>
    </g>
    <g class="cp-dash-h" stroke="var(--accent)" stroke-width="1.5">
      <line x1="218" y1="105" x2="222" y2="115" opacity="0.6"></line>
    </g>

    <!-- projection labels -->
    <text
      x="400"
      y="195"
      text-anchor="middle"
      font-family="Georgia,serif"
      font-size="11"
      fill="var(--secondary)"
      class="cp-label">a = 3</text
    >
    <text
      x="192"
      y="113"
      text-anchor="end"
      font-family="Georgia,serif"
      font-size="11"
      fill="var(--accent)"
      class="cp-label">b = 2</text
    >

    <!-- the point Z = 3 + 2i -->
    <g class="cp-point">
      <!-- glow -->
      <circle cx="400" cy="110" r="14" fill="var(--primary)" opacity="0.12"></circle>
      <!-- dot -->
      <circle cx="400" cy="110" r="6" fill="var(--primary)" stroke="var(--card)" stroke-width="2"
      ></circle>
    </g>

    <!-- label for Z -->
    <g class="cp-label">
      <rect
        x="410"
        y="90"
        width="78"
        height="26"
        rx="5"
        fill="var(--card)"
        stroke="var(--primary)"
        stroke-width="1.2"
        opacity="0.95"></rect>
      <text
        x="449"
        y="108"
        text-anchor="middle"
        font-family="Georgia,serif"
        font-size="13"
        fill="var(--primary)"
        font-style="italic"
      >
        Z = 3 + 2i
      </text>
    </g>

    <!-- caption -->
    <text
      x="260"
      y="285"
      text-anchor="middle"
      font-family="Georgia,serif"
      font-size="11"
      fill="var(--muted-foreground)"
      letter-spacing="1"
      class="cp-label"
    >
      the complex plane · every number a point in 2D space
    </text>
  </svg>
</figure>
