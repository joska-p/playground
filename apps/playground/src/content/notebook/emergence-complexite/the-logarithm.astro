---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 640 260" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl">
    <style>
      .log-axis {
        animation: fade-in 0.5s 0.1s ease-out both;
      }
      .log-exp-curve {
        stroke-dasharray: 900;
        animation: draw-exp 1.2s 0.4s ease-out both;
      }
      .log-log-curve {
        stroke-dasharray: 600;
        animation: draw-log 1.2s 0.9s ease-out both;
      }
      @keyframes draw-exp {
        from {
          stroke-dashoffset: 900;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      @keyframes draw-log {
        from {
          stroke-dashoffset: 600;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      .log-labels {
        animation: fade-in 0.4s 1.6s ease-out both;
      }
      .log-key {
        animation: fade-in 0.4s 1.8s ease-out both;
      }
    </style>

    <g class="log-axis stroke-border" stroke-width="1.5">
      <line x1="80" y1="15" x2="80" y2="205"></line>
      <polygon points="76,15 84,15 80,8" class="fill-border"></polygon>
      <line x1="80" y1="205" x2="580" y2="205"></line>
      <polygon points="580,201 580,209 592,205" class="fill-border"></polygon>
    </g>

    <g class="stroke-border/25 log-axis" stroke-width="0.5">
      <line x1="80" y1="55" x2="580" y2="55"></line>
      <line x1="80" y1="105" x2="580" y2="105"></line>
      <line x1="80" y1="155" x2="580" y2="155"></line>
      <line x1="180" y1="15" x2="180" y2="205"></line>
      <line x1="280" y1="15" x2="280" y2="205"></line>
      <line x1="380" y1="15" x2="380" y2="205"></line>
      <line x1="480" y1="15" x2="480" y2="205"></line>
      <line x1="580" y1="15" x2="580" y2="205"></line>
    </g>

    <g class="fill-muted-foreground text-anchor-middle log-axis text-sm">
      <text x="180" y="222">1</text>
      <text x="280" y="222">2</text>
      <text x="380" y="222">3</text>
      <text x="480" y="222">4</text>
      <text x="580" y="222">5</text>
      <text x="330" y="240">x</text>
    </g>

    <path
      d="M80,204 C115,203 180,202 280,196 S420,165 480,140 L580,15"
      fill="none"
      class="log-exp-curve stroke-accent"
      stroke-width="2.5"
      stroke-linecap="round"></path>
    <path
      d="M80,205 C115,175 180,135 280,95 S420,55 580,15"
      fill="none"
      class="log-log-curve stroke-secondary"
      stroke-width="2.5"
      stroke-linecap="round"></path>

    <g class="log-labels">
      <text x="440" y="110" class="fill-accent text-base italic">eˣ</text>
      <text x="520" y="55" class="fill-secondary text-base italic">log(x)</text>
    </g>

    <g class="log-key">
      <rect x="84" y="24" width="12" height="4" rx="2" class="fill-accent"></rect>
      <text x="102" y="30" class="fill-muted-foreground text-sm">exponential — grows unbounded</text
      >
      <rect x="84" y="40" width="12" height="4" rx="2" class="fill-secondary"></rect>
      <text x="102" y="46" class="fill-muted-foreground text-sm"
        >logarithm — tames the explosion</text
      >
    </g>

    <g class="log-labels">
      <circle cx="580" cy="15" r="4" fill="none" class="stroke-primary/50" stroke-width="1.5"
      ></circle>
      <text x="460" y="14" class="fill-muted-foreground/70 text-sm">same value at x = 5</text>
    </g>
  </svg>
</Figure>
