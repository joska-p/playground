---
interface Props {
  caption?: string;
  label?: string;
}
const { caption, label } = Astro.props;
---

<figure class="my-8">
  <div class="bg-card border-border overflow-hidden rounded-lg border">
    <slot />
  </div>
  {
    (caption || label) && (
      <figcaption class="text-muted-foreground mt-2.5 flex items-baseline gap-1.5 font-sans text-[0.82rem]">
        {label && (
          <span class="text-primary font-mono text-[0.75rem] font-semibold tracking-wide uppercase">
            {label}
          </span>
        )}
        {caption && <span>{caption}</span>}
      </figcaption>
    )
  }
</figure>
