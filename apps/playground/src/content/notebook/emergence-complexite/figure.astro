---
interface Props {
  title?: string;
  symbol?: string;
  caption?: string;
}
const { title, symbol, caption } = Astro.props;
---

<div class="border-border bg-card my-10 overflow-hidden rounded-lg border">
  {
    title && (
      <div class="border-border flex items-center justify-between border-b px-5 py-3">
        <span class="text-muted-foreground font-mono text-[10px] tracking-[0.2em] uppercase">
          {title}
        </span>
        {symbol && (
          <span class="text-muted-foreground font-mono text-[10px] opacity-50">{symbol}</span>
        )}
      </div>
    )
  }

  <div class="bg-background flex w-full justify-center overflow-x-auto p-6">
    <slot />
  </div>

  {
    caption && (
      <div class="border-border border-t px-5 py-3">
        <p class="text-muted-foreground font-mono text-[11px] opacity-70" set:html={caption} />
      </div>
    )
  }
</div>
