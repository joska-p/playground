---

---

<div
  id="growth-wrapper"
  class="bg-card border-border my-8 rounded-lg border px-4 pt-5 pb-3 font-sans"
>
  <div class="mb-3 flex items-baseline justify-between">
    <div class="text-muted-foreground text-[0.75rem] font-semibold tracking-[0.08em] uppercase">
      Linear vs Logarithmic Growth
    </div>
    <div class="text-muted-foreground flex items-center gap-3 text-[0.72rem]">
      <span class="flex items-center gap-1.5">
        <span class="bg-category-explanation inline-block h-2 w-2 rounded-full"></span>
        Linear
      </span>
      <span class="flex items-center gap-1.5">
        <span class="bg-category-tutorial inline-block h-2 w-2 rounded-full"></span>
        Logarithmic
      </span>
    </div>
  </div>
  <canvas id="growth-canvas" class="block w-full" style="height:240px"></canvas>
  <div class="text-muted-foreground flex justify-between pt-1 text-[0.68rem] italic">
    <span>n</span>
    <span>Both start from the same point — then diverge entirely</span>
  </div>
</div>

<script>
  const canvas = document.getElementById("growth-canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  function resize() {
    const wrapper = document.getElementById("growth-wrapper")!;
    canvas.width = wrapper.offsetWidth * devicePixelRatio;
    canvas.height = 240 * devicePixelRatio;
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
  }
  window.addEventListener("resize", () => {
    resize();
    draw(progress);
  });
  resize();

  let progress = 0;

  function draw(t: number) {
    const style = getComputedStyle(document.documentElement);
    const border = style.getPropertyValue("--border").trim();
    const colorLin = style.getPropertyValue("--category-explanation").trim();
    const colorLog = style.getPropertyValue("--category-tutorial").trim();
    const mutedFg = style.getPropertyValue("--muted-foreground").trim();

    const w = canvas.offsetWidth,
      h = 240;
    ctx.clearRect(0, 0, w, h);

    const pL = 44,
      pR = 20,
      pT = 16,
      pB = 32;
    const cW = w - pL - pR,
      cH = h - pT - pB;
    const N = 120;

    // Grid
    ctx.strokeStyle = `oklch(${border} / 0.4)`;
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 4; i++) {
      const y = pT + (i / 4) * cH;
      ctx.beginPath();
      ctx.moveTo(pL, y);
      ctx.lineTo(pL + cW, y);
      ctx.stroke();
    }
    for (let i = 0; i <= 6; i++) {
      const x = pL + (i / 6) * cW;
      ctx.beginPath();
      ctx.moveTo(x, pT);
      ctx.lineTo(x, pT + cH);
      ctx.stroke();
    }

    // Axes
    ctx.strokeStyle = `oklch(${border} / 0.8)`;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(pL, pT);
    ctx.lineTo(pL, pT + cH);
    ctx.lineTo(pL + cW, pT + cH);
    ctx.stroke();

    const steps = Math.floor(t * N);
    const maxLog = Math.log(N + 1);

    // Linear
    ctx.beginPath();
    ctx.lineWidth = 2;
    ctx.strokeStyle = `oklch(${colorLin})`;
    for (let n = 0; n <= steps; n++) {
      const x = pL + (n / N) * cW;
      const y = pT + cH - (n / N) * cH;
      n === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Log
    ctx.beginPath();
    ctx.lineWidth = 2;
    ctx.strokeStyle = `oklch(${colorLog})`;
    for (let n = 0; n <= steps; n++) {
      const x = pL + (n / N) * cW;
      const y = pT + cH - (Math.log(n + 1) / maxLog) * cH;
      n === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Y-axis labels
    ctx.fillStyle = `oklch(${mutedFg})`;
    ctx.font = "10px ui-monospace, monospace";
    ctx.textAlign = "right";
    ctx.fillText("max", pL - 4, pT + 4);
    ctx.fillText("0", pL - 4, pT + cH + 4);
  }

  function animate() {
    if (progress < 1) {
      progress = Math.min(1, progress + 0.008);
      draw(progress);
      requestAnimationFrame(animate);
    }
  }

  new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting && progress === 0) {
        animate();
      }
    },
    { threshold: 0.3 }
  ).observe(canvas);
</script>
