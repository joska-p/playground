---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 520 240" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg">
    <style>
      .d-intact { animation: fade-in 0.6s 0.1s ease-out both; }
      .d-question { animation: fade-up 0.5s 0.8s ease-out both; }
      .d-shatter { animation: fade-in 0.4s 1.3s ease-out both; }
      .d-crack-l { animation: d-crack-l 0.5s 1.6s ease-out both; }
      .d-crack-r { animation: d-crack-r 0.5s 1.6s ease-out both; }
      @keyframes d-crack-l { from { opacity: 0; transform: translateX(40px); } to { opacity: 1; transform: translateX(0); } }
      @keyframes d-crack-r { from { opacity: 0; transform: translateX(-40px); } to { opacity: 1; transform: translateX(0); } }
      .d-resolution { animation: fade-up 0.5s 2.2s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
    </style>

    <!-- Phase 1: the intact integer universe -->
    <g class="d-intact">
      <!-- Number line with integers -->
      <line x1="80" y1="42" x2="440" y2="42" stroke="var(--border)" stroke-width="1.5"></line>
      <g stroke="var(--border)" stroke-width="1" opacity="0.4">
        <line x1="140" y1="36" x2="140" y2="48"></line>
        <line x1="200" y1="36" x2="200" y2="48"></line>
        <line x1="320" y1="36" x2="320" y2="48"></line>
        <line x1="380" y1="36" x2="380" y2="48"></line>
      </g>
      <g font-family="Georgia,serif" font-size="13" font-weight="bold" text-anchor="middle" fill="var(--border)" opacity="0.5">
        <text x="80" y="28">0</text>
        <text x="140" y="28">1</text>
        <text x="200" y="28">2</text>
        <text x="320" y="28">3</text>
        <text x="380" y="28">4</text>
      </g>
      <text x="260" y="62" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="var(--muted-foreground)" letter-spacing="1">ℤ — the integer universe</text>
    </g>

    <!-- Question: 1 ÷ 2 = ? -->
    <g class="d-question">
      <rect x="170" y="72" width="180" height="36" rx="6" fill="var(--card)" stroke="var(--accent)" stroke-width="2"></rect>
      <text x="260" y="96" text-anchor="middle" font-family="Georgia,serif" font-size="16" fill="var(--accent)" font-style="italic">
        1 ÷ 2 = ?
      </text>
    </g>

    <!-- The crack — the integer universe shatters -->
    <g class="d-shatter">
      <!-- Lightning crack through the integer -->
      <line x1="200" y1="42" x2="210" y2="70" stroke="var(--accent)" stroke-width="2.5" opacity="0.8"></line>
      <line x1="210" y1="70" x2="195" y2="90" stroke="var(--accent)" stroke-width="1.8" opacity="0.6"></line>
      <line x1="210" y1="70" x2="220" y2="88" stroke="var(--accent)" stroke-width="1.8" opacity="0.6"></line>
      <line x1="220" y1="88" x2="225" y2="105" stroke="var(--accent)" stroke-width="1.2" opacity="0.4"></line>
      <!-- Shards -->
      <polygon points="195,92 188,100 200,98" fill="var(--accent)" opacity="0.15"></polygon>
      <polygon points="220,88 228,95 215,96" fill="var(--accent)" opacity="0.12"></polygon>
    </g>

    <!-- Divider -->
    <line x1="80" y1="125" x2="440" y2="125" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="6,4" opacity="0.3" class="d-shatter"></line>

    <!-- Resolution: the two halves -->
    <g class="d-crack-l">
      <rect x="96" y="138" width="142" height="38" rx="6" fill="var(--secondary)" opacity="0.18"></rect>
      <rect x="96" y="138" width="142" height="38" rx="6" fill="none" stroke="var(--secondary)" stroke-width="2"></rect>
      <text x="167" y="163" text-anchor="middle" font-family="Georgia,serif" font-size="18" font-weight="bold" fill="var(--secondary)">½</text>
    </g>

    <g class="d-crack-r">
      <rect x="282" y="138" width="142" height="38" rx="6" fill="var(--secondary)" opacity="0.18"></rect>
      <rect x="282" y="138" width="142" height="38" rx="6" fill="none" stroke="var(--secondary)" stroke-width="2"></rect>
      <text x="353" y="163" text-anchor="middle" font-family="Georgia,serif" font-size="18" font-weight="bold" fill="var(--secondary)">½</text>
    </g>

    <!-- Equation chip -->
    <g class="d-resolution">
      <text x="260" y="218" text-anchor="middle" font-family="Georgia,serif" font-size="14" fill="var(--muted-foreground)" letter-spacing="1">
        1 ÷ 2 = ½ · a new kind of number is born
      </text>
    </g>
  </svg>
</Figure>
