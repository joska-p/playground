---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 520 200" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg">
    <style>
      .div-whole { animation: scale-x 0.6s 0.1s ease-out both; transform-origin: 260px 54px; }
      .div-label-1 { animation: fade-up 0.4s 0.7s ease-out both; }
      .div-split { animation: fade-in 0.5s 1.1s ease-out both; }
      .div-half-l { animation: slide-left 0.6s 1.5s ease-out both; }
      .div-half-r { animation: slide-right 0.6s 1.5s ease-out both; }
      .div-result { animation: fade-up 0.5s 2.1s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
    </style>

    <g class="div-whole">
      <rect x="110" y="38" width="300" height="32" rx="5" fill="var(--primary)" opacity="0.18"></rect>
      <rect x="110" y="38" width="300" height="32" rx="5" fill="none" stroke="var(--primary)" stroke-width="2"></rect>
      <text x="260" y="59" text-anchor="middle" font-family="Georgia,serif" font-size="16" font-weight="bold" fill="var(--primary)">1</text>
    </g>
    <text x="260" y="88" text-anchor="middle" font-family="Georgia,serif" font-size="12" fill="var(--muted-foreground)" class="div-label-1">the unit — whole</text>

    <line x1="260" y1="110" x2="260" y2="152" stroke="var(--accent)" stroke-width="1.5" stroke-dasharray="3,3" class="div-split" style="transform-origin: 260px 131px"></line>
    <text x="260" y="108" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="var(--accent)" class="div-split">÷ 2</text>

    <g class="div-half-l">
      <rect x="112" y="115" width="142" height="32" rx="5" fill="var(--secondary)" opacity="0.20"></rect>
      <rect x="112" y="115" width="142" height="32" rx="5" fill="none" stroke="var(--secondary)" stroke-width="2"></rect>
      <text x="183" y="136" text-anchor="middle" font-family="Georgia,serif" font-size="14" fill="var(--secondary)">½</text>
    </g>

    <g class="div-half-r">
      <rect x="266" y="115" width="142" height="32" rx="5" fill="var(--secondary)" opacity="0.20"></rect>
      <rect x="266" y="115" width="142" height="32" rx="5" fill="none" stroke="var(--secondary)" stroke-width="2"></rect>
      <text x="337" y="136" text-anchor="middle" font-family="Georgia,serif" font-size="14" fill="var(--secondary)">½</text>
    </g>

    <g class="div-result">
      <text x="260" y="175" text-anchor="middle" font-family="Georgia,serif" font-size="13" fill="var(--muted-foreground)" letter-spacing="1">1 ÷ 2 = ½ · not in ℤ, so we must go further</text>
    </g>
  </svg>
</Figure>
