---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 640 260" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl">
    <style>
      .d-intact {
        animation: fade-in 0.6s 0.1s ease-out both;
      }
      .d-question {
        animation: fade-up 0.5s 0.8s ease-out both;
      }
      .d-shatter {
        animation: fade-in 0.4s 1.3s ease-out both;
      }
      .d-crack-l {
        animation: d-crack-l 0.5s 1.6s ease-out both;
      }
      .d-crack-r {
        animation: d-crack-r 0.5s 1.6s ease-out both;
      }
      @keyframes d-crack-l {
        from {
          opacity: 0;
          transform: translateX(40px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }
      @keyframes d-crack-r {
        from {
          opacity: 0;
          transform: translateX(-40px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }
      .d-resolution {
        animation: fade-up 0.5s 2.2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      }
    </style>

    <g class="d-intact">
      <line x1="100" y1="44" x2="540" y2="44" class="stroke-border" stroke-width="1.5"></line>
      <g class="stroke-border/40" stroke-width="1">
        <line x1="180" y1="38" x2="180" y2="50"></line>
        <line x1="260" y1="38" x2="260" y2="50"></line>
        <line x1="380" y1="38" x2="380" y2="50"></line>
        <line x1="460" y1="38" x2="460" y2="50"></line>
      </g>
      <g class="fill-border/50 text-anchor-middle text-base font-bold">
        <text x="100" y="28">0</text>
        <text x="180" y="28">1</text>
        <text x="260" y="28">2</text>
        <text x="380" y="28">3</text>
        <text x="460" y="28">4</text>
      </g>
      <text
        x="320"
        y="66"
        text-anchor="middle"
        class="fill-muted-foreground text-sm"
        letter-spacing="1">ℤ — the integer universe</text
      >
    </g>

    <g class="d-question">
      <rect
        x="220"
        y="74"
        width="200"
        height="40"
        rx="6"
        class="fill-card stroke-accent"
        stroke-width="2"></rect>
      <text x="320" y="100" text-anchor="middle" class="fill-accent text-lg italic">
        1 ÷ 2 = ?
      </text>
    </g>

    <g class="d-shatter">
      <line x1="260" y1="44" x2="275" y2="74" class="stroke-accent" stroke-width="2.5" opacity="0.8"
      ></line>
      <line x1="275" y1="74" x2="255" y2="96" class="stroke-accent" stroke-width="1.8" opacity="0.6"
      ></line>
      <line x1="275" y1="74" x2="290" y2="94" class="stroke-accent" stroke-width="1.8" opacity="0.6"
      ></line>
      <line
        x1="290"
        y1="94"
        x2="295"
        y2="112"
        class="stroke-accent"
        stroke-width="1.2"
        opacity="0.4"></line>
      <polygon points="255,96 246,106 260,104" class="fill-accent/15"></polygon>
      <polygon points="290,94 300,102 284,104" class="fill-accent/12"></polygon>
    </g>

    <line
      x1="100"
      y1="132"
      x2="540"
      y2="132"
      class="stroke-border/30"
      stroke-width="0.5"
      stroke-dasharray="6,4"
      class="d-shatter"></line>

    <g class="d-crack-l">
      <rect
        x="128"
        y="148"
        width="160"
        height="42"
        rx="6"
        class="fill-secondary/18 stroke-secondary"
        stroke-width="2"></rect>
      <text x="208" y="176" text-anchor="middle" class="fill-secondary text-2xl font-bold">½</text>
    </g>

    <g class="d-crack-r">
      <rect
        x="352"
        y="148"
        width="160"
        height="42"
        rx="6"
        class="fill-secondary/18 stroke-secondary"
        stroke-width="2"></rect>
      <text x="432" y="176" text-anchor="middle" class="fill-secondary text-2xl font-bold">½</text>
    </g>

    <g class="d-resolution">
      <text
        x="320"
        y="240"
        text-anchor="middle"
        class="fill-muted-foreground text-sm"
        letter-spacing="1"
      >
        1 ÷ 2 = ½ · a new kind of number is born
      </text>
    </g>
  </svg>
</Figure>
