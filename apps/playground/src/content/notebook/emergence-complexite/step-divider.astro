---
interface Props {
  step: string;
  symbol: string;
}
const { step, symbol } = Astro.props;
---

<div class="mt-16 mb-1 flex items-center gap-4">
  <span class="text-primary tracking-[0.25em] uppercase opacity-70">Step {step}</span>
  <span class="bg-border h-px flex-1 opacity-50"></span>
  <span
    class="text-accent bg-card border-border items-center justify-center rounded-full border px-4 py-2 text-2xl"
    set:html={symbol}
  />
</div>
