<div class="border-border bg-card my-10 overflow-hidden rounded-lg border">
  <div class="border-border flex items-center justify-between border-b px-5 py-3">
    <span class="text-muted-foreground font-mono text-[10px] tracking-[0.2em] uppercase"
      >Linear vs Logarithmic Growth</span
    >
    <span class="bg-primary h-1.5 w-1.5 rounded-full opacity-60"></span>
  </div>
  <div class="bg-background flex w-full justify-center p-6">
    <svg viewBox="0 0 440 230" class="h-auto w-full max-w-lg">
      {/* Axes */}
      <line x1="40" y1="195" x2="410" y2="195" stroke="var(--border)" stroke-width="1.5"></line>
      <line x1="40" y1="15" x2="40" y2="195" stroke="var(--border)" stroke-width="1.5"></line>
      {/* Axis labels */}
      <text x="400" y="212" font-size="10" font-family="monospace" fill="var(--muted-foreground)"
        >x</text
      >
      <text x="20" y="20" font-size="10" font-family="monospace" fill="var(--muted-foreground)"
        >y</text
      >
      {/* Subtle grid */}
      <line
        x1="40"
        y1="105"
        x2="410"
        y2="105"
        stroke="var(--border)"
        stroke-width="0.5"
        stroke-dasharray="3 5"
        opacity="0.4"></line>
      <line
        x1="225"
        y1="15"
        x2="225"
        y2="195"
        stroke="var(--border)"
        stroke-width="0.5"
        stroke-dasharray="3 5"
        opacity="0.4"></line>
      {/* Linear */}
      <line
        x1="40"
        y1="195"
        x2="390"
        y2="15"
        stroke="var(--secondary)"
        stroke-width="2"
        stroke-dasharray="7 3"
        opacity="0.7"></line>
      <text
        x="330"
        y="30"
        font-size="9"
        fill="var(--secondary)"
        font-family="monospace"
        opacity="0.85">Linear</text
      >
      {/* Log curve */}
      <path
        d="M 40 195 C 75 135, 115 88, 175 65 S 310 42, 410 32"
        fill="none"
        stroke="var(--primary)"
        stroke-width="2.5"
        stroke-linecap="round"></path>
      <text
        x="250"
        y="60"
        font-size="10"
        fill="var(--primary)"
        font-weight="bold"
        font-family="monospace">log(x)</text
      >
      {/* Annotation */}
      <line
        x1="225"
        y1="195"
        x2="225"
        y2="105"
        stroke="var(--border)"
        stroke-width="1"
        stroke-dasharray="2 3"
        opacity="0.5"></line>
      <circle cx="225" cy="105" r="3" fill="var(--secondary)" opacity="0.7"></circle>
      <circle cx="225" cy="52" r="3" fill="var(--primary)"></circle>
    </svg>
  </div>
  <div class="border-border border-t px-5 py-3">
    <p class="text-muted-foreground font-mono text-[11px] opacity-70">
      The logarithmic curve flattens explosive growth into a progression the human eye can follow.
    </p>
  </div>
</div>
