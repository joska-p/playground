---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 640 280" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl">
    <style>
      .tg-bg {
        animation: fade-in 0.5s 0.1s ease-out both;
      }
      .tg-axis-draw {
        stroke-dasharray: 420;
        animation: draw-x 0.8s 0.2s ease-out both;
      }
      @keyframes draw-x {
        from {
          stroke-dashoffset: 420;
        }
        to {
          stroke-dashoffset: 0;
        }
      }
      .tg-curve {
        stroke-dasharray: 600;
        animation: draw-curve 1.1s 0.7s ease-out both;
      }
      @keyframes draw-curve {
        from {
          stroke-dashoffset: 600;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      .tg-qchip {
        animation: fade-up 0.5s 1.3s ease-out both;
      }
      .tg-gap {
        animation: fade-in 0.5s 1.7s ease-out both;
      }
      .tg-impossible {
        animation: fade-in 0.5s 2.1s ease-out both;
      }
      .tg-resolution {
        animation: fade-up 0.5s 2.6s ease-out both;
      }
    </style>

    <g class="tg-bg stroke-border" stroke-width="1.5">
      <line x1="320" y1="15" x2="320" y2="225"></line>
      <polygon points="316,15 324,15 320,8" class="fill-border"></polygon>
    </g>

    <line x1="60" y1="190" x2="580" y2="190" class="tg-axis-draw stroke-border" stroke-width="1.5"
    ></line>
    <polygon points="580,186 580,194 588,190" class="fill-border tg-bg"></polygon>

    <g class="stroke-border/35 tg-bg" stroke-width="0.8">
      <line x1="180" y1="183" x2="180" y2="197"></line>
      <line x1="250" y1="183" x2="250" y2="197"></line>
      <line x1="390" y1="183" x2="390" y2="197"></line>
      <line x1="460" y1="183" x2="460" y2="197"></line>
    </g>
    <g class="fill-muted-foreground text-anchor-middle tg-bg text-sm">
      <text x="180" y="212">−2</text>
      <text x="250" y="212">−1</text>
      <text x="320" y="212">0</text>
      <text x="390" y="212">1</text>
      <text x="460" y="212">2</text>
    </g>

    <line x1="300" y1="110" x2="340" y2="110" class="stroke-border/30 tg-bg" stroke-width="0.8"
    ></line>
    <text x="290" y="114" class="fill-muted-foreground text-anchor-end tg-bg text-sm">1</text>

    <path
      d="M120,20 C145,33 220,72 275,116 S305,138 320,143 S350,138 365,116 S430,50 520,20"
      fill="none"
      class="tg-curve stroke-primary"
      stroke-width="2.5"
      stroke-linecap="round"></path>

    <g class="tg-qchip">
      <rect
        x="230"
        y="24"
        width="180"
        height="38"
        rx="6"
        class="fill-card stroke-accent"
        stroke-width="2"></rect>
      <text x="320" y="50" text-anchor="middle" class="fill-accent text-xl italic">x² + 1 = 0</text>
    </g>

    <g class="tg-gap">
      <line
        x1="320"
        y1="143"
        x2="320"
        y2="190"
        class="stroke-accent"
        stroke-width="2"
        stroke-dasharray="5,4"></line>
      <polygon points="315,186 325,186 320,193" class="fill-accent/80"></polygon>
      <polygon points="315,147 325,147 320,140" class="fill-accent/80"></polygon>
      <text x="355" y="172" class="fill-accent/90 text-2xl font-bold">?</text>
      <text x="340" y="156" class="fill-accent text-sm">no real x</text>
    </g>

    <rect x="62" y="186" width="516" height="4" class="fill-accent/8 tg-impossible"></rect>

    <g class="tg-impossible">
      <text x="500" y="40" class="fill-primary text-base italic">y = x² + 1</text>
    </g>

    <g class="tg-resolution">
      <rect
        x="190"
        y="244"
        width="260"
        height="32"
        rx="6"
        class="fill-card stroke-primary"
        stroke-width="1.5"></rect>
      <text x="320" y="265" text-anchor="middle" class="fill-primary text-lg font-bold">
        postulate i &nbsp; i² = −1
      </text>
    </g>
  </svg>
</Figure>
