---
import Figure from "./figure.astro";
import "./common-animations.css";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 520 260" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg">
    <style>
      .tg-bg { animation: fade-in 0.5s 0.1s ease-out both; }
      .tg-axis-draw { stroke-dasharray: 420; animation: draw-x 0.8s 0.2s ease-out both; }
      @keyframes draw-x { from { stroke-dashoffset: 420; } to { stroke-dashoffset: 0; } }
      .tg-curve { stroke-dasharray: 600; animation: draw-curve 1.1s 0.7s ease-out both; }
      @keyframes draw-curve { from { stroke-dashoffset: 600; opacity: 0; } to { stroke-dashoffset: 0; opacity: 1; } }
      .tg-qchip { animation: fade-up 0.5s 1.3s ease-out both; }
      .tg-gap { animation: fade-in 0.5s 1.7s ease-out both; }
      .tg-impossible { animation: fade-in 0.5s 2.1s ease-out both; }
      .tg-resolution { animation: fade-up 0.5s 2.6s ease-out both; }
    </style>

    <!-- Axes -->
    <g class="tg-bg" stroke="var(--border)" stroke-width="1.5">
      <line x1="260" y1="15" x2="260" y2="215"></line>
      <polygon points="256,15 264,15 260,8" fill="var(--border)"></polygon>
    </g>

    <line x1="40" y1="180" x2="480" y2="180" stroke="var(--border)" stroke-width="1.5" class="tg-axis-draw"></line>
    <polygon points="480,176 480,184 488,180" fill="var(--border)" class="tg-bg"></polygon>

    <!-- Tick labels -->
    <g stroke="var(--border)" stroke-width="0.8" opacity="0.35" class="tg-bg">
      <line x1="140" y1="173" x2="140" y2="187"></line>
      <line x1="200" y1="173" x2="200" y2="187"></line>
      <line x1="320" y1="173" x2="320" y2="187"></line>
      <line x1="380" y1="173" x2="380" y2="187"></line>
    </g>
    <g font-family="Georgia,serif" font-size="10" text-anchor="middle" fill="var(--muted-foreground)" class="tg-bg">
      <text x="140" y="200">−2</text>
      <text x="200" y="200">−1</text>
      <text x="260" y="200">0</text>
      <text x="320" y="200">1</text>
      <text x="380" y="200">2</text>
    </g>

    <!-- y=1 reference line -->
    <line x1="240" y1="100" x2="280" y2="100" stroke="var(--border)" stroke-width="0.8" opacity="0.3" class="tg-bg"></line>
    <text x="230" y="104" font-family="Georgia,serif" font-size="10" fill="var(--muted-foreground)" text-anchor="end" class="tg-bg">1</text>

    <!-- The parabola: y = x² + 1 -->
    <path d="M100,20 C120,32 180,70 220,110 S245,130 260,135 S285,130 300,110 S360,46 420,20" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round" class="tg-curve"></path>

    <!-- Question chip: x² + 1 = 0 -->
    <g class="tg-qchip">
      <rect x="170" y="24" width="180" height="34" rx="6" fill="var(--card)" stroke="var(--accent)" stroke-width="2"></rect>
      <text x="260" y="47" text-anchor="middle" font-family="Georgia,serif" font-size="18" fill="var(--accent)" font-style="italic">x² + 1 = 0</text>
    </g>

    <!-- The impossible gap -->
    <g class="tg-gap">
      <!-- Vertical gap indicator -->
      <line x1="260" y1="135" x2="260" y2="180" stroke="var(--accent)" stroke-width="2" stroke-dasharray="5,4"></line>
      <!-- Arrow markers -->
      <polygon points="255,176 265,176 260,183" fill="var(--accent)" opacity="0.8"></polygon>
      <polygon points="255,139 265,139 260,132" fill="var(--accent)" opacity="0.8"></polygon>
      <!-- Question mark overlay on the gap -->
      <text x="290" y="160" font-family="Georgia,serif" font-size="24" font-weight="bold" fill="var(--accent)" opacity="0.9">?</text>
      <text x="280" y="148" font-family="Georgia,serif" font-size="11" fill="var(--accent)">no real x</text>
    </g>

    <!-- Red "impossible" band at y=0 -->
    <rect x="42" y="174" width="436" height="6" fill="var(--accent)" opacity="0.08" class="tg-impossible"></rect>

    <!-- Curve label -->
    <g class="tg-impossible">
      <text x="405" y="38" font-family="Georgia,serif" font-size="12" fill="var(--primary)" font-style="italic">y = x² + 1</text>
    </g>

    <!-- Resolution: i² = -1 -->
    <g class="tg-resolution">
      <rect x="140" y="226" width="240" height="30" rx="6" fill="var(--card)" stroke="var(--primary)" stroke-width="1.5"></rect>
      <text x="260" y="246" text-anchor="middle" font-family="Georgia,serif" font-size="15" fill="var(--primary)" font-weight="bold">
        postulate i &nbsp; i² = −1
      </text>
    </g>
  </svg>
</Figure>
