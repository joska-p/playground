<div class="border-border bg-card my-10 overflow-hidden rounded-lg border">
  <div class="border-border flex items-center justify-between border-b px-5 py-3">
    <span class="text-muted-foreground font-mono text-[10px] tracking-[0.2em] uppercase"
      >The rotation cycle of <em>i</em></span
    >
    <span
      class="text-accent bg-accent/10 border-accent/20 rounded border px-2 py-0.5 font-mono text-[10px]"
      >ℂ plane</span
    >
  </div>
  <div class="grid grid-cols-1 items-center gap-0 md:grid-cols-5">
    <div class="bg-background border-border flex justify-center p-6 md:col-span-3 md:border-r">
      <svg viewBox="0 0 300 300" class="h-auto w-full max-w-xs">
        {/* Unit circle */}
        <circle
          cx="150"
          cy="150"
          r="100"
          stroke="var(--border)"
          stroke-width="0.8"
          fill="none"
          stroke-dasharray="5 3"
          opacity="0.5"></circle>
        {/* Axes */}
        <line x1="20" y1="150" x2="280" y2="150" stroke="var(--border)" stroke-width="1.5"></line>
        <line x1="150" y1="20" x2="150" y2="280" stroke="var(--border)" stroke-width="1.5"></line>
        {/* Axis labels */}
        <text x="260" y="144" font-size="9" font-family="monospace" fill="var(--muted-foreground)"
          >Real</text
        >
        <text x="155" y="26" font-size="9" font-family="monospace" fill="var(--muted-foreground)"
          >Imaginary</text
        >
        {/* Arc 1→i */}
        <path
          d="M 245 150 A 95 95 0 0 0 150 55"
          fill="none"
          stroke="var(--accent)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-dasharray="3 2"
          opacity="0.85"></path>
        <polygon points="150,52 157,63 143,63" fill="var(--accent)" opacity="0.9"></polygon>
        <text x="218" y="88" font-size="8" font-family="monospace" fill="var(--accent)">× i</text>
        {/* Arc i→-1 */}
        <path
          d="M 150 55 A 95 95 0 0 0 55 150"
          fill="none"
          stroke="var(--accent)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-dasharray="3 2"
          opacity="0.5"></path>
        <text x="68" y="88" font-size="8" font-family="monospace" fill="var(--accent)" opacity="0.7"
          >× i</text
        >
        {/* Arc -1→-i */}
        <path
          d="M 55 150 A 95 95 0 0 0 150 245"
          fill="none"
          stroke="var(--accent)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-dasharray="3 2"
          opacity="0.3"></path>
        <text
          x="68"
          y="218"
          font-size="8"
          font-family="monospace"
          fill="var(--accent)"
          opacity="0.4">× i</text
        >
        {/* Four key points */}
        <circle cx="250" cy="150" r="5" fill="var(--secondary)"></circle>
        <text
          x="256"
          y="167"
          font-size="12"
          font-family="monospace"
          font-weight="bold"
          fill="var(--secondary)">1</text
        >
        <circle cx="150" cy="50" r="5" fill="var(--accent)"></circle>
        <text
          x="158"
          y="46"
          font-size="12"
          font-family="monospace"
          font-weight="bold"
          fill="var(--accent)">i</text
        >
        <circle cx="50" cy="150" r="5" fill="var(--destructive)" opacity="0.85"></circle>
        <text
          x="22"
          y="167"
          font-size="12"
          font-family="monospace"
          font-weight="bold"
          fill="var(--destructive)"
          opacity="0.85">−1</text
        >
        <circle cx="150" cy="250" r="5" fill="var(--muted-foreground)" opacity="0.6"></circle>
        <text
          x="158"
          y="267"
          font-size="12"
          font-family="monospace"
          fill="var(--muted-foreground)"
          opacity="0.6">−i</text
        >
        {/* Example Z vector */}
        <line
          x1="150"
          y1="150"
          x2="212"
          y2="78"
          stroke="var(--primary)"
          stroke-width="1.5"
          stroke-dasharray="4 2"
          opacity="0.8"></line>
        <circle cx="212" cy="78" r="4" fill="var(--primary)"></circle>
        <text
          x="218"
          y="72"
          font-size="10"
          font-family="monospace"
          font-weight="bold"
          fill="var(--primary)">Z = a + ib</text
        >
      </svg>
    </div>
    <div class="space-y-4 p-6 md:col-span-2">
      <p class="text-muted-foreground font-mono text-[10px] font-bold tracking-[0.2em] uppercase">
        The full cycle
      </p>
      <div class="space-y-2 font-mono text-[11px]">
        <div class="bg-background border-border flex items-center gap-2 rounded border px-3 py-2">
          <span class="text-secondary w-4 font-bold">1</span>
          <span class="text-border">×i</span>
          <span class="text-accent font-bold">i</span>
          <span class="text-muted-foreground ml-auto opacity-60">+90°</span>
        </div>
        <div class="bg-background border-border flex items-center gap-2 rounded border px-3 py-2">
          <span class="text-accent w-4 font-bold">i</span>
          <span class="text-border">×i</span>
          <span class="text-destructive font-bold">−1</span>
          <span class="text-muted-foreground ml-auto opacity-60">+90°</span>
        </div>
        <div class="bg-background border-border flex items-center gap-2 rounded border px-3 py-2">
          <span class="text-destructive w-4 font-bold">−1</span>
          <span class="text-border">×i</span>
          <span class="font-bold">−i</span>
          <span class="text-muted-foreground ml-auto opacity-60">+90°</span>
        </div>
        <div
          class="border-primary/30 bg-primary/5 flex items-center gap-2 rounded border px-3 py-2"
        >
          <span class="w-4 font-bold">−i</span>
          <span class="text-border">×i</span>
          <span class="text-secondary font-bold">1</span>
          <span class="text-primary ml-auto text-[10px] opacity-80">360° ↩</span>
        </div>
      </div>
    </div>
  </div>
</div>
