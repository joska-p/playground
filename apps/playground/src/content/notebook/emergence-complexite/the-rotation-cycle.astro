---

---

<div class="my-10 flex flex-wrap items-center justify-center gap-8">
  <canvas
    id="rotation-canvas"
    class="bg-card border-border block shrink-0 rounded-lg border"
    style="width:300px;height:300px"
    role="img"
    aria-label="Complex plane: multiplying by i rotates 90° — 1→i→−1→−i→1"></canvas>

  <div class="flex flex-col gap-2">
    {
      [
        {
          from: "1",
          to: "i",
          fromCls: "text-[color:var(--category-tutorial)]",
          toCls: "text-[color:var(--category-how-to)]",
        },
        {
          from: "i",
          to: "−1",
          fromCls: "text-[color:var(--category-how-to)]",
          toCls: "text-[color:var(--category-explanation)]",
        },
        {
          from: "−1",
          to: "−i",
          fromCls: "text-[color:var(--category-explanation)]",
          toCls: "text-[color:var(--category-data-viz)]",
        },
        {
          from: "−i",
          to: "1",
          fromCls: "text-[color:var(--category-data-viz)]",
          toCls: "text-[color:var(--category-tutorial)]",
        },
      ].map(({ from, to, fromCls, toCls }, i) => (
        <div
          class="rot-step border-border bg-card flex items-center gap-2 rounded-md border px-4 py-2.5 font-serif transition-colors duration-200"
          data-step={i}
        >
          <span class={`w-7 text-center text-lg font-bold ${fromCls}`}>{from}</span>
          <span class="text-muted-foreground font-mono text-[0.72rem]">×i</span>
          <span class={`w-7 text-center text-lg font-bold ${toCls}`}>{to}</span>
          <span class="text-primary ml-auto pl-3 font-mono text-[0.68rem]">+90°</span>
        </div>
      ))
    }
  </div>
</div>

<script>
  const canvas = document.getElementById("rotation-canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  function resize() {
    const size = Math.min(canvas.parentElement!.clientWidth, 300);
    canvas.width = size * devicePixelRatio;
    canvas.height = size * devicePixelRatio;
    canvas.style.width = size + "px";
    canvas.style.height = size + "px";
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
  }
  window.addEventListener("resize", resize);
  resize();

  const angles = [0, Math.PI / 2, Math.PI, (3 * Math.PI) / 2];
  const labels = ["1", "i", "−1", "−i"];
  const colorVars = [
    "--category-tutorial",
    "--category-how-to",
    "--category-explanation",
    "--category-data-viz",
  ];

  let phase = 0;

  function draw() {
    const style = getComputedStyle(document.documentElement);
    const border = style.getPropertyValue("--border").trim();
    const primary = style.getPropertyValue("--primary").trim();
    const fg = style.getPropertyValue("--foreground").trim();

    const size = canvas.offsetWidth;
    ctx.clearRect(0, 0, size, size);
    const cx = size / 2,
      cy = size / 2;
    const radius = size * 0.33;

    // Grid axes
    ctx.strokeStyle = `oklch(${border} / 0.45)`;
    ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.moveTo(cx, 0);
    ctx.lineTo(cx, size);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(0, cy);
    ctx.lineTo(size, cy);
    ctx.stroke();

    // Axis labels
    ctx.fillStyle = `oklch(${border})`;
    ctx.font = `${size * 0.028}px ui-monospace, monospace`;
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText("Re", cx + radius + 18, cy - 8);
    ctx.fillText("Im", cx + 8, cy - radius - 12);

    // Unit circle
    ctx.beginPath();
    ctx.arc(cx, cy, radius, 0, Math.PI * 2);
    ctx.strokeStyle = `oklch(${primary} / 0.3)`;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Sweep arm
    const arm = -phase;
    const sx = cx + Math.cos(arm) * radius;
    const sy = cy + Math.sin(arm) * radius;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(sx, sy);
    ctx.strokeStyle = `oklch(${primary} / 0.5)`;
    ctx.lineWidth = 1.5;
    ctx.setLineDash([4, 3]);
    ctx.stroke();
    ctx.setLineDash([]);

    // Four points
    for (let i = 0; i < 4; i++) {
      const col = style.getPropertyValue(colorVars[i]).trim();
      const a = -angles[i];
      const px = cx + Math.cos(a) * radius;
      const py = cy + Math.sin(a) * radius;

      ctx.beginPath();
      ctx.arc(px, py, 5, 0, Math.PI * 2);
      ctx.fillStyle = `oklch(${col})`;
      ctx.fill();

      const off = 20;
      ctx.font = `bold ${size * 0.047}px ui-serif, Georgia, serif`;
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.fillStyle = `oklch(${col})`;
      ctx.fillText(labels[i], cx + Math.cos(a) * (radius + off), cy + Math.sin(a) * (radius + off));
    }

    // Origin
    ctx.beginPath();
    ctx.arc(cx, cy, 2.5, 0, Math.PI * 2);
    ctx.fillStyle = `oklch(${border})`;
    ctx.fill();

    // Sync table
    const step = Math.floor((phase / (Math.PI / 2)) % 4);
    document.querySelectorAll(".rot-step").forEach((el, i) => {
      el.classList.toggle("!bg-muted", i === step);
      el.classList.toggle("!border-primary/40", i === step);
    });

    phase += 0.012;
    requestAnimationFrame(draw);
  }

  new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        draw();
      }
    },
    { threshold: 0.3 }
  ).observe(canvas);
</script>
