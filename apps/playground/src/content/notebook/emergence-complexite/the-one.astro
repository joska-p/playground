---
import Figure from "./figure.astro";
---

<Figure className="flex flex-col items-center gap-4">
  <svg viewBox="0 0 480 220" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg">
    <style>
      .one-halo {
        animation: halo-pulse 4s ease-in-out infinite;
        transform-origin: 240px 108px;
      }
      @keyframes halo-pulse {
        0%,
        100% {
          opacity: 0.06;
          transform: scale(1);
        }
        50% {
          opacity: 0.14;
          transform: scale(1.12);
        }
      }
      .one-brick {
        animation: brick-rise 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      }
      @keyframes brick-rise {
        from {
          opacity: 0;
          transform: translateY(18px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .one-ray {
        animation: ray-fade 4s ease-in-out infinite;
      }
      @keyframes ray-fade {
        0%,
        100% {
          opacity: 0.18;
        }
        50% {
          opacity: 0.45;
        }
      }
    </style>

    <!-- ambient halo -->
    <ellipse cx="240" cy="108" rx="88" ry="80" fill="var(--primary)" class="one-halo"></ellipse>

    <!-- rays (8 directions) -->
    <g stroke="var(--primary)" stroke-width="1.5" stroke-linecap="round" class="one-ray">
      <line x1="240" y1="42" x2="240" y2="22"></line>
      <line x1="240" y1="174" x2="240" y2="194"></line>
      <line x1="158" y1="108" x2="138" y2="108"></line>
      <line x1="322" y1="108" x2="342" y2="108"></line>
      <line x1="182" y1="60" x2="168" y2="46"></line>
      <line x1="298" y1="60" x2="312" y2="46"></line>
      <line x1="182" y1="156" x2="168" y2="170"></line>
      <line x1="298" y1="156" x2="312" y2="170"></line>
    </g>

    <!-- stone -->
    <rect
      x="176"
      y="56"
      width="128"
      height="104"
      rx="10"
      fill="var(--card)"
      stroke="var(--primary)"
      stroke-width="2"
      class="one-brick"></rect>
    <!-- inner border -->
    <rect
      x="184"
      y="64"
      width="112"
      height="88"
      rx="6"
      fill="none"
      stroke="var(--primary)"
      stroke-width="0.6"
      opacity="0.35"
      class="one-brick"></rect>

    <!-- numeral -->
    <text
      x="240"
      y="128"
      text-anchor="middle"
      font-family="Georgia, 'Times New Roman', serif"
      font-size="60"
      font-weight="bold"
      fill="var(--primary)"
      class="one-brick">1</text
    >

    <!-- label -->
    <text
      x="240"
      y="198"
      text-anchor="middle"
      font-family="Georgia, serif"
      font-size="11"
      fill="var(--muted-foreground)"
      letter-spacing="3">THE UNIT · THE ORIGIN · THE ONLY GIVEN</text
    >
  </svg>
</Figure>
