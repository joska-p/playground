<div class="group my-16 flex w-full justify-center">
  <svg
    class="h-auto w-full max-w-[280px] overflow-visible font-mono"
    viewBox="0 0 300 480"
    xmlns="http://www.w3.org/2000/svg"
  >
    <style>
      .layer {
        transition:
          transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
          opacity 0.4s ease;
        cursor: pointer;
      }
      /* Hovering the SVG separates the layers slightly */
      svg:hover .layer-c {
        transform: translateY(-20px);
      }
      svg:hover .layer-r {
        transform: translateY(-10px);
      }
      svg:hover .layer-z {
        transform: translateY(10px);
      }
      svg:hover .layer-n {
        transform: translateY(20px);
      }

      .axis-line {
        stroke-dasharray: 4 4;
        animation: march 20s linear infinite backwards;
      }
      @keyframes march {
        to {
          stroke-dashoffset: -100;
        }
      }
    </style>

    <line
      x1="150"
      y1="40"
      x2="150"
      y2="440"
      stroke="var(--border)"
      stroke-width="2"
      class="axis-line"
      opacity="0.4"></line>

    <g class="layer layer-c" transform="translate(150, 100)">
      <ellipse
        cx="0"
        cy="0"
        rx="140"
        ry="60"
        fill="var(--card)"
        fill-opacity="0.8"
        stroke="var(--primary)"
        stroke-width="2"></ellipse>
      <text x="-110" y="10" font-size="24" font-weight="bold" fill="var(--primary)">ℂ</text>
      <text x="80" y="5" font-size="10" fill="var(--muted-foreground)">x² = -1</text>
    </g>

    <g class="layer layer-r" transform="translate(150, 180)">
      <ellipse
        cx="0"
        cy="0"
        rx="110"
        ry="47"
        fill="var(--background)"
        fill-opacity="0.9"
        stroke="var(--foreground)"
        stroke-width="2"></ellipse>
      <text x="-80" y="10" font-size="22" font-weight="bold" fill="var(--foreground)">ℝ</text>
      <text x="50" y="5" font-size="10" fill="var(--muted-foreground)">Continuum</text>
    </g>

    <g class="layer layer-q" transform="translate(150, 260)">
      <ellipse
        cx="0"
        cy="0"
        rx="80"
        ry="34"
        fill="var(--card)"
        fill-opacity="0.95"
        stroke="var(--accent)"
        stroke-width="2"></ellipse>
      <text x="-50" y="10" font-size="20" font-weight="bold" fill="var(--accent)">ℚ</text>
      <text x="30" y="5" font-size="10" fill="var(--muted-foreground)">a ÷ b</text>
    </g>

    <g class="layer layer-z" transform="translate(150, 340)">
      <ellipse
        cx="0"
        cy="0"
        rx="55"
        ry="24"
        fill="var(--background)"
        fill-opacity="1"
        stroke="var(--secondary)"
        stroke-width="2"></ellipse>
      <text x="-30" y="10" font-size="18" font-weight="bold" fill="var(--secondary)">ℤ</text>
      <text x="15" y="5" font-size="10" fill="var(--muted-foreground)">0, -n</text>
    </g>

    <g class="layer layer-n" transform="translate(150, 420)">
      <ellipse
        cx="0"
        cy="0"
        rx="30"
        ry="13"
        fill="var(--primary)"
        fill-opacity="0.2"
        stroke="var(--primary)"
        stroke-width="2"></ellipse>
      <text x="-10" y="6" font-size="16" font-weight="bold" fill="var(--primary)">ℕ</text>
    </g>

    <circle cx="150" cy="420" r="3" fill="var(--foreground)" class="layer layer-n"></circle>
  </svg>
</div>
