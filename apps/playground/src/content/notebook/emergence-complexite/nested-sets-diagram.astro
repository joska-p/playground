---

<div class="my-10">
  <svg
    viewBox="0 0 600 340"
    xmlns="http://www.w3.org/2000/svg"
    class="block h-auto w-full"
    role="img"
    aria-label="Nested number sets: ℕ ⊂ ℤ ⊂ ℚ ⊂ ℝ ⊂ ℂ"
  >
    <!-- ℂ -->
    <ellipse
      cx="300"
      cy="170"
      rx="280"
      ry="148"
      class="fill-category-data-viz/5 stroke-category-data-viz/50"
      stroke-width="1.5"></ellipse>
    <text
      x="555"
      y="100"
      class="fill-(--color-category-data-viz)"
      font-family="ui-serif,Georgia,serif"
      font-size="18"
      font-weight="700"
      text-anchor="middle"
      dominant-baseline="middle">ℂ</text
    >
    <text
      x="530"
      y="118"
      font-family="ui-sans-serif,system-ui,sans-serif"
      font-size="8"
      class="fill-muted-foreground"
      text-anchor="middle"
      letter-spacing="1">COMPLEX</text
    >

    <!-- ℝ -->
    <ellipse
      cx="285"
      cy="170"
      rx="228"
      ry="116"
      class="fill-card/80 stroke-category-reference/60"
      stroke-width="1.5"></ellipse>
    <text
      x="480"
      y="126"
      class="fill-var(--color-category-reference)"
      font-family="ui-serif,Georgia,serif"
      font-size="17"
      font-weight="700"
      text-anchor="middle"
      dominant-baseline="middle">ℝ</text
    >
    <text
      x="455"
      y="143"
      font-family="ui-sans-serif,system-ui,sans-serif"
      font-size="8"
      class="fill-muted-foreground"
      text-anchor="middle"
      letter-spacing="1">REAL</text
    >

    <!-- ℚ -->
    <ellipse
      cx="272"
      cy="170"
      rx="178"
      ry="86"
      class="fill-card/90 stroke-var(--color-category-explanation)/65"
      stroke-width="1.5"></ellipse>
    <text
      x="418"
      y="149"
      class="fill-var(--color-category-explanation)"
      font-family="ui-serif,Georgia,serif"
      font-size="16"
      font-weight="700"
      text-anchor="middle"
      dominant-baseline="middle">ℚ</text
    >
    <text
      x="392"
      y="164"
      font-family="ui-sans-serif,system-ui,sans-serif"
      font-size="8"
      class="fill-muted-foreground"
      text-anchor="middle"
      letter-spacing="1">RATIONAL</text
    >

    <!-- ℤ -->
    <ellipse
      cx="260"
      cy="170"
      rx="130"
      ry="60"
      class="fill-card stroke-var(--color-category-how-to)/65"
      stroke-width="1.5"></ellipse>
    <text
      x="358"
      y="167"
      class="fill-var(--color-category-how-to)"
      font-family="ui-serif,Georgia,serif"
      font-size="16"
      font-weight="700"
      text-anchor="middle"
      dominant-baseline="middle">ℤ</text
    >
    <text
      x="330"
      y="181"
      font-family="ui-sans-serif,system-ui,sans-serif"
      font-size="8"
      class="fill-muted-foreground"
      text-anchor="middle"
      letter-spacing="1">INTEGER</text
    >

    <!-- ℕ -->
    <ellipse
      cx="248"
      cy="170"
      rx="82"
      ry="36"
      class="fill-card stroke-var(--color-category-tutorial)/75"
      stroke-width="1.5"></ellipse>
    <text
      x="248"
      y="173"
      class="fill-var(--color-category-tutorial)"
      font-family="ui-serif,Georgia,serif"
      font-size="16"
      font-weight="700"
      text-anchor="middle"
      dominant-baseline="middle">ℕ</text
    >

    <!-- Example numbers -->
    <text
      x="220"
      y="166"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/50"
      text-anchor="middle"
      dominant-baseline="middle">1</text
    >
    <text
      x="248"
      y="192"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/50"
      text-anchor="middle"
      dominant-baseline="middle">3</text
    >
    <text
      x="272"
      y="160"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/50"
      text-anchor="middle"
      dominant-baseline="middle">7</text
    >

    <text
      x="154"
      y="172"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/45"
      text-anchor="middle"
      dominant-baseline="middle">−5</text
    >
    <text
      x="295"
      y="185"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/45"
      text-anchor="middle"
      dominant-baseline="middle">0</text
    >
    <text
      x="330"
      y="160"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/45"
      text-anchor="middle"
      dominant-baseline="middle">−2</text
    >

    <text
      x="114"
      y="170"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/40"
      text-anchor="middle"
      dominant-baseline="middle">½</text
    >
    <text
      x="356"
      y="182"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/40"
      text-anchor="middle"
      dominant-baseline="middle">⅔</text
    >
    <text
      x="390"
      y="154"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/40"
      text-anchor="middle"
      dominant-baseline="middle">−¾</text
    >

    <text
      x="70"
      y="170"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/38"
      text-anchor="middle"
      dominant-baseline="middle">√2</text
    >
    <text
      x="432"
      y="175"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/38"
      text-anchor="middle"
      dominant-baseline="middle">π</text
    >
    <text
      x="452"
      y="157"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/38"
      text-anchor="middle"
      dominant-baseline="middle">e</text
    >

    <text
      x="28"
      y="162"
      font-family="ui-serif,Georgia,serif"
      font-size="10"
      class="fill-foreground/35"
      text-anchor="middle"
      dominant-baseline="middle">2+3i</text
    >
    <text
      x="482"
      y="186"
      font-family="ui-serif,Georgia,serif"
      font-size="11"
      class="fill-foreground/35"
      text-anchor="middle"
      dominant-baseline="middle">i</text
    >
  </svg>

  <p class="text-muted-foreground mt-3 text-center font-sans text-[0.8rem] italic">
    Each set is strictly contained in the next. Every expansion was forced by a question mathematics
    could not ignore.
  </p>
</div>
