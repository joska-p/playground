---
import Figure from "./figure.astro";
import "./common-animations.css";
import SvgNode from "./SvgNode.astro";
---

<Figure className="flex flex-col items-center">
  <svg viewBox="0 0 640 320" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl">
    <style>
      .iu-bg {
        animation: fade-in 0.5s 0.1s ease-out both;
      }
      .iu-circle {
        stroke-dasharray: 628;
        animation: iu-spin 1.2s 0.3s ease-out both;
      }
      @keyframes iu-spin {
        from {
          stroke-dashoffset: 628;
          opacity: 0;
        }
        to {
          stroke-dashoffset: 0;
          opacity: 1;
        }
      }
      .iu-n1 {
        animation: pop-in 0.4s 1.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 470px 160px;
      }
      .iu-n2 {
        animation: pop-in 0.4s 1.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 320px 50px;
      }
      .iu-n3 {
        animation: pop-in 0.4s 2.2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 170px 160px;
      }
      .iu-n4 {
        animation: pop-in 0.4s 2.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transform-origin: 320px 270px;
      }
      .iu-a1 {
        animation: fade-in 0.4s 1.6s ease-out both;
      }
      .iu-a2 {
        animation: fade-in 0.4s 2s ease-out both;
      }
      .iu-a3 {
        animation: fade-in 0.4s 2.4s ease-out both;
      }
      .iu-a4 {
        animation: fade-in 0.4s 2.8s ease-out both;
      }
      .iu-caption {
        animation: fade-in 0.4s 3s ease-out both;
      }
    </style>

    <defs>
      <marker id="iu-arr" markerWidth="7" markerHeight="7" refX="6" refY="3.5" orient="auto">
        <path d="M0,0 L0,7 L7,3.5 z" class="fill-primary/80"></path>
      </marker>
    </defs>

    <g class="iu-bg stroke-border/40" stroke-width="1">
      <line x1="90" y1="160" x2="550" y2="160"></line>
      <line x1="320" y1="30" x2="320" y2="290"></line>
    </g>
    <g class="iu-bg fill-muted-foreground/60 text-sm">
      <text x="555" y="164" class="text-anchor-start">Re</text>
      <text x="320" y="26" text-anchor="middle">Im</text>
    </g>

    <circle
      cx="320"
      cy="160"
      r="110"
      fill="none"
      class="stroke-primary/25 iu-circle"
      stroke-width="1.5"></circle>

    <path
      d="M430,126 A110,110 0 0,0 355,63"
      fill="none"
      class="stroke-primary iu-a1"
      stroke-width="2"
      marker-end="url(#iu-arr)"></path>
    <path
      d="M285,63 A110,110 0 0,0 210,126"
      fill="none"
      class="stroke-primary iu-a2"
      stroke-width="2"
      marker-end="url(#iu-arr)"></path>
    <path
      d="M210,194 A110,110 0 0,0 285,257"
      fill="none"
      class="stroke-primary iu-a3"
      stroke-width="2"
      marker-end="url(#iu-arr)"></path>
    <path
      d="M355,257 A110,110 0 0,0 430,194"
      fill="none"
      class="stroke-primary iu-a4"
      stroke-width="2"
      marker-end="url(#iu-arr)"></path>

    <g class="fill-primary/75 text-anchor-middle text-sm">
      <text x="420" y="78" class="iu-a1">×i</text>
      <text x="220" y="78" class="iu-a2">×i</text>
      <text x="220" y="250" class="iu-a3">×i</text>
      <text x="420" y="250" class="iu-a4">×i</text>
    </g>

    <g class="iu-n1"><SvgNode cx={470} cy={160} label="1" stroke="var(--secondary)" r={24} /></g>
    <g class="iu-n2"><SvgNode cx={320} cy={50} label="i" stroke="var(--primary)" r={24} /></g>
    <g class="iu-n3"><SvgNode cx={170} cy={160} label="−1" stroke="var(--accent)" r={24} /></g>
    <g class="iu-n4"><SvgNode cx={320} cy={270} label="−i" stroke="var(--primary)" r={24} /></g>

    <text
      x="320"
      y="312"
      text-anchor="middle"
      class="fill-muted-foreground iu-caption text-sm"
      letter-spacing="1"
    >
      multiplying by i = rotating 90° · four steps = full circle
    </text>
  </svg>
</Figure>
