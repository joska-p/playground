---
const layers = [
  {
    set: "ℂ",
    name: "COMPLEX",
    cls: "fill-primary/4 stroke-primary/30 text-primary",
    rx: 280,
    ry: 150,
    cx: 300,
    cy: 170,
    labelX: 550,
    labelY: 60,
  },
  {
    set: "ℝ",
    name: "REALS",
    cls: "fill-category-data-viz/4 stroke-category-data-viz/30 text-category-data-viz",
    rx: 225,
    ry: 124,
    cx: 245,
    cy: 172,
    labelX: 440,
    labelY: 82,
  },
  {
    set: "ℚ",
    name: "RATIONALS",
    cls: "fill-category-explanation/4 stroke-category-explanation/30 text-category-explanation",
    rx: 175,
    ry: 100,
    cx: 195,
    cy: 175,
    labelX: 345,
    labelY: 105,
  },
  {
    set: "ℤ",
    name: "INTEGERS",
    cls: "fill-category-how-to/4 stroke-category-how-to/30 text-category-how-to",
    rx: 125,
    ry: 76,
    cx: 145,
    cy: 178,
    labelX: 245,
    labelY: 128,
  },
  {
    set: "ℕ",
    name: "NATURALS",
    cls: "fill-category-tutorial/6 stroke-category-tutorial/40 text-category-tutorial",
    rx: 75,
    ry: 50,
    cx: 95,
    cy: 182,
    labelX: 145,
    labelY: 155,
  },
];
---

<div
  class="bg-card border-border/40 mx-auto my-12 w-full max-w-3xl rounded-xl border p-6 shadow-xs sm:p-8"
>
  <svg
    viewBox="0 0 600 340"
    xmlns="http://www.w3.org/2000/svg"
    class="h-auto w-full font-sans"
    role="img"
    aria-label="Nested sets: ℕ ⊂ ℤ ⊂ ℚ ⊂ ℝ ⊂ ℂ"
  >
    {
      layers.map((layer) => (
        <g class="group/layer transition-all duration-300">
          <ellipse
            cx={layer.cx}
            cy={layer.cy}
            rx={layer.rx}
            ry={layer.ry}
            class={`${layer.cls} transition-colors group-hover/layer:stroke-current`}
            stroke-width="1.5"
          />
          <g class={layer.cls} dominant-baseline="middle">
            <text
              x={layer.labelX}
              y={layer.labelY}
              class="fill-current font-serif text-xl font-black opacity-90"
              text-anchor="middle"
            >
              {layer.set}
            </text>
            <text
              x={layer.labelX}
              y={layer.labelY + 14}
              class="fill-current font-mono text-[0.55rem] font-bold tracking-widest opacity-60"
              text-anchor="middle"
            >
              {layer.name}
            </text>
          </g>
        </g>
      ))
    }

    <g
      class="fill-foreground/75 font-mono text-xs font-semibold"
      text-anchor="middle"
      dominant-baseline="middle"
    >
      <text x="65" y="182" class="fill-category-tutorial text-sm font-bold">1, 7, 42</text>
      <text x="185" y="180" class="fill-category-how-to">-5, -128</text>
      <text x="290" y="195" class="fill-category-explanation">¾, -0.25, 22/7</text>
      <text x="395" y="215" class="fill-category-data-viz">π, e, √2</text>
      <text x="440" y="275" class="fill-primary font-bold">2 + 3i, -i</text>
    </g>
  </svg>
</div>
