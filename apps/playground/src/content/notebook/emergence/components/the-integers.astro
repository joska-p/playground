---
import Figure from "./figure.astro";
import "../styles/styles.css";

const steps = [-5, -4, -3, -2, -1, 1, 2, 3, 4, 5];
const stepX = 45;
const centerX = 320;
---

<Figure className="flex flex-col items-center">
  <div class="bg-card border-border/40 w-full max-w-3xl rounded-xl border p-6 shadow-xs">
    <svg
      viewBox="0 0 640 190"
      xmlns="http://www.w3.org/2000/svg"
      class="h-auto w-full"
      role="img"
      aria-label="Integer number line ℤ = { …, -2, -1, 0, +1, +2, … }"
    >
      <defs>
        <marker id="int-arrow-left" markerWidth="6" markerHeight="6" refX="1" refY="3" orient="auto">
          <path d="M6,0 L6,6 L0,3 z" class="fill-accent" />
        </marker>
        <marker id="int-arrow-right" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
          <path d="M0,0 L0,6 L6,3 z" class="fill-secondary" />
        </marker>
      </defs>

      <line x1="30" y1="90" x2="610" y2="90" class="stroke-border" stroke-width="2"
            style="animation: draw 0.8s 0.1s cubic-bezier(0.16,1,0.3,1) both; --draw-offset: 580;" />

      <g class="anim-fade" style="--anim-delay: 1.4s;">
        <line x1="50" y1="90" x2="30" y2="90" class="stroke-accent" stroke-width="2"
              marker-end="url(#int-arrow-left)" />
        <line x1="590" y1="90" x2="610" y2="90" class="stroke-secondary" stroke-width="2"
              marker-end="url(#int-arrow-right)" />
      </g>

      {steps.map((val) => {
        const x = centerX + val * stepX;
        const distance = Math.abs(val);
        const delay = 0.5 + distance * 0.15;
        const isNeg = val < 0;
        const isOne = distance === 1;
        return (
          <g class="anim-slide" style={`--anim-delay: ${delay}s; --anim-duration: 0.5s;`}>
            <line x1={x} y1="83" x2={x} y2="97"
                  class={`stroke-current ${isNeg ? "text-accent" : "text-secondary"} ${distance > 1 ? "opacity-" + (100 - distance * 15) : "opacity-100"}`}
                  stroke-width={isOne ? "2" : "1.5"} />
            <text x={x} y="118" text-anchor="middle"
                  class={`fill-current font-mono text-xs font-bold ${isNeg ? "text-accent" : "text-secondary"} ${distance > 1 ? "opacity-" + (100 - distance * 15) : "opacity-100"}`}>
              {val > 0 ? `+${val}` : val.toString()}
            </text>
          </g>
        );
      })}

      <g class="anim-pop" style="--anim-delay: 0.4s; --anim-duration: 0.6s; transform-origin: 320px 90px;">
        <circle cx="320" cy="90" r="15" class="fill-card stroke-primary" stroke-width="2.5" />
        <text x="320" y="94" text-anchor="middle" class="fill-primary font-mono text-xs font-bold">0</text>
      </g>

      <g class="anim-fade" style="--anim-delay: 1.4s;">
        <path d="M 185,130 Q 320,145 455,130" class="stroke-border/30 fill-none" stroke-width="1.2" stroke-dasharray="4,4" />
        <text x="320" y="166" text-anchor="middle"
              class="fill-muted-foreground font-mono text-[0.7rem] tracking-wider uppercase opacity-85">
          ℤ = &#123; …, −2, −1, 0, +1, +2, … &#125; · Closed Under Subtraction
        </text>
      </g>
    </svg>
  </div>
</Figure>
