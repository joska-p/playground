---
import Figure from "./figure.astro";
import "../styles/styles.css";
import SvgNode from "./svg-node.astro";

const nodes = [
  { cx: 80, label: "1", cls: "opacity-100" },
  { cx: 176, label: "2", cls: "opacity-90" },
  { cx: 272, label: "3", cls: "opacity-80" },
  { cx: 368, label: "4", cls: "opacity-70" },
  { cx: 464, label: "5", cls: "opacity-60" },
  { cx: 560, label: "6", cls: "opacity-45" },
];
---

<Figure className="flex flex-col items-center">
  <svg
    viewBox="0 0 680 200"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full max-w-3xl"
    role="img"
    aria-label="Natural numbers ℕ = { 1, 2, 3, 4, 5, … }"
  >
    <line
      x1="30" y1="100" x2="660" y2="100"
      class="stroke-border" stroke-width="1.5"
      style="animation: draw 1s 0.1s ease-out both; --draw-offset: 630;"
    />

    {nodes.map((n, i) => (
      i === 0 ? (
        <SvgNode
          cx={n.cx} cy={100} label={n.label} r={24} subtitle="first"
          class="anim-pop"
          style={`--anim-delay: ${0.15 + i * 0.15}s; --anim-duration: 0.4s; transform-origin: ${n.cx}px 100px;`}
        />
      ) : (
        <g
          class="anim-pop"
          style={`--anim-delay: ${0.15 + i * 0.15}s; --anim-duration: 0.4s; transform-origin: ${n.cx}px 100px;`}
        >
          <circle
            cx={n.cx} cy={100} r="24"
            fill="var(--card)" class="stroke-primary"
            stroke-width="1.5" opacity={n.cls === "opacity-100" ? 1 : n.cls === "opacity-90" ? 0.9 : n.cls === "opacity-80" ? 0.8 : n.cls === "opacity-70" ? 0.7 : n.cls === "opacity-60" ? 0.6 : 0.45}
          />
          <text
            x={n.cx} y={100} dy=".35em" text-anchor="middle"
            class="fill-primary text-2xl font-bold"
            opacity={n.cls === "opacity-100" ? 1 : n.cls === "opacity-90" ? 0.9 : n.cls === "opacity-80" ? 0.8 : n.cls === "opacity-70" ? 0.7 : n.cls === "opacity-60" ? 0.6 : 0.45}
          >{n.label}</text>
        </g>
      )
    ))}

    <g class="anim-pop" style="--anim-delay: 1.05s; --anim-duration: 0.4s; transform-origin: 630px 100px;">
      <text x="628" y="108" class="fill-primary/35 text-3xl">…</text>
      <text x="628" y="144" text-anchor="middle" class="fill-muted-foreground/60 text-sm">∞</text>
    </g>

    <text
      x="345" y="180" text-anchor="middle"
      class="fill-muted-foreground text-base italic"
      letter-spacing="1"
      style="animation: fade-in 0.6s 1.2s ease-out both;"
    >ℕ = {"{ "}1, 2, 3, 4, 5, …{"}"}</text>
  </svg>
</Figure>
