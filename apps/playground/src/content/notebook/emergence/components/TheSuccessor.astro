---
import Figure from "./Figure.astro";
import "../styles/styles.css";
import SvgNode from "./SvgNode.astro";

const nodes = [
  { cx: 80, label: "1", delay: "0.1s" },
  { cx: 230, label: "2", delay: "0.5s" },
  { cx: 380, label: "3", delay: "0.9s" },
  { cx: 530, label: "4", delay: "1.3s" },
];
const arrows = [
  { x1: 118, x2: 186, label: "152", delay: "0.3s" },
  { x1: 268, x2: 336, label: "302", delay: "0.7s" },
  { x1: 418, x2: 486, label: "452", delay: "1.1s" },
  { x1: 568, x2: 624, label: "596", delay: "1.5s" },
];
---

<Figure className="flex flex-col items-center">
  <svg
    viewBox="0 0 700 200"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full max-w-3xl"
    role="img"
    aria-label="Successor rule: 1 → 2 → 3 → 4 → ..."
  >
    <defs>
      <marker id="succ-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" class="fill-muted-foreground" />
      </marker>
    </defs>

    {nodes.map((n) => (
      <SvgNode
        cx={n.cx} cy={100} label={n.label} r={36}
        class="anim-pop"
        style={`--anim-delay: ${n.delay}; --anim-duration: 0.5s; transform-origin: ${n.cx}px 100px;`}
      />
    ))}

    <g class="stroke-muted-foreground" stroke-width="1.5" fill="none" marker-end="url(#succ-arrow)">
      {arrows.map((a) => (
        <path
          d={`M ${a.x1},100 L ${a.x2},100`}
          class="anim-fade"
          style={`--anim-delay: ${a.delay}; --anim-duration: 0.35s;`}
        />
      ))}
    </g>

    <g class="fill-muted-foreground text-sm" text-anchor="middle">
      {arrows.map((a) => (
        <text
          x={parseInt(a.label)}
          y="88"
          class="anim-fade"
          style={`--anim-delay: ${a.delay}; --anim-duration: 0.35s;`}
        >+1</text>
      ))}
    </g>

    <g class="anim-pop" style="--anim-delay: 2s; --anim-duration: 0.5s; transform-origin: 660px 100px;">
      <text x="650" y="108" class="fill-muted-foreground/70 text-3xl">…</text>
    </g>

    <text
      x="350" y="170"
      text-anchor="middle"
      class="fill-muted-foreground/80 text-sm"
      letter-spacing="2"
      style="animation: fade-in 0.6s 2.2s ease-out both;"
    >ONE RULE · INFINITE CONSEQUENCE</text>
  </svg>
</Figure>
