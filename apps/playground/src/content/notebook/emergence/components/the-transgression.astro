---
import Figure from "./figure.astro";
import "../styles/styles.css";
---

<Figure className="flex flex-col items-center">
  <div class="bg-card border-border/40 w-full max-w-sm rounded-xl border p-5 shadow-xs">
    <svg
      viewBox="0 0 360 340"
      xmlns="http://www.w3.org/2000/svg"
      class="h-auto w-full"
      role="img"
      aria-label="Parabola x² + 1 has no intersection with the real axis"
    >
      <g stroke-width="1.5">
        <line x1="30" y1="240" x2="330" y2="240" class="stroke-border"
              style="animation: draw 0.8s 0.1s cubic-bezier(0.16,1,0.3,1) both; --draw-offset: 300;" />
        <line x1="180" y1="40" x2="180" y2="280" class="stroke-border/20 anim-fade"
              stroke-dasharray="4,4" style="--anim-delay: 0s;" />
      </g>

      <path d="M 50,70 C 110,210 130,165 180,165 C 230,165 250,210 310,70"
            fill="none" class="stroke-primary" stroke-width="3.5" stroke-linecap="round"
            style="animation: draw 1.2s 0.3s cubic-bezier(0.2,0.8,0.2,1) both; --draw-offset: 400;" />

      <g class="anim-slide" style="--anim-delay: 1.1s;">
        <rect x="90" y="30" width="180" height="36" rx="8"
              class="fill-card stroke-accent" stroke-width="1.5" />
        <text x="180" y="53" text-anchor="middle" class="fill-accent font-mono text-base font-bold">x² + 1 = 0</text>
      </g>

      <g class="anim-slide" style="--anim-delay: 1.5s;">
        <line x1="180" y1="172" x2="180" y2="233" class="stroke-accent" stroke-width="2" stroke-dasharray="5,3" />
        <polygon points="176,178 184,178 180,172" class="fill-accent" />
        <polygon points="176,227 184,227 180,234" class="fill-accent" />
        <text x="196" y="200" class="fill-accent font-mono text-sm font-black">?</text>
        <text x="196" y="214" class="fill-destructive font-mono text-[0.62rem] font-black tracking-wider uppercase">No Intersection</text>
      </g>

      <g class="anim-slide fill-muted-foreground font-mono text-[0.68rem] font-bold" text-anchor="middle" style="--anim-delay: 0.7s;">
        <text x="60" y="256">-2</text>
        <text x="180" y="256">0</text>
        <text x="300" y="256">+2</text>
        <text x="330" y="228" text-anchor="end" class="text-[0.55rem] tracking-widest uppercase opacity-50">Real Line (ℝ)</text>
      </g>
    </svg>
  </div>
</Figure>
