---
import Figure from "./Figure.astro";
import "../styles/styles.css";
---

<Figure className="flex flex-col items-center">
  <div class="bg-card border-border/40 w-full max-w-3xl rounded-xl border p-6 shadow-xs sm:p-8">
    <svg
      viewBox="0 0 640 250"
      xmlns="http://www.w3.org/2000/svg"
      class="h-auto w-full"
      role="img"
      aria-label="Rational density: between 1/3 and 1/2 there are infinitely many fractions"
    >
      <!-- Top number line -->
      <g class="anim-slide" style="--anim-delay: 0.1s;">
        <line x1="60" y1="50" x2="580" y2="50" class="stroke-border" stroke-width="2" />
        <g class="stroke-border" stroke-width="2">
          <line x1="120" y1="42" x2="120" y2="58" />
          <line x1="350" y1="42" x2="350" y2="58" class="stroke-category-explanation" stroke-width="2.5" />
          <line x1="520" y1="42" x2="520" y2="58" />
        </g>
        <g class="fill-foreground font-mono text-xs font-bold" text-anchor="middle">
          <text x="120" y="30">0</text>
          <text x="350" y="30" class="fill-category-explanation">1/2</text>
          <text x="520" y="30">1</text>
        </g>
      </g>

      <!-- Magnifying glass projectors -->
      <g class="stroke-category-explanation/20 fill-none"
         style="animation: draw 0.8s 0.5s cubic-bezier(0.16,1,0.3,1) both; --draw-offset: 300;"
         stroke-width="1.2" stroke-dasharray="4,4">
        <path d="M 280,50 L 60,140" />
        <path d="M 350,50 L 580,140" />
      </g>

      <!-- Expanded focus timeline -->
      <g class="anim-slide" style="--anim-delay: 1s;">
        <line x1="60" y1="140" x2="580" y2="140" class="stroke-category-exploration/50" stroke-width="2.5"
              style="animation: draw 0.8s 1.1s cubic-bezier(0.16,1,0.3,1) both; --draw-offset: 520;" />
        <g class="stroke-category-exploration" stroke-width="2">
          <line x1="120" y1="130" x2="120" y2="150" />
          <line x1="520" y1="130" x2="520" y2="150" />
        </g>
        <g class="fill-foreground font-mono text-sm font-black" text-anchor="middle">
          <text x="120" y="115" class="fill-category-exploration">1/3</text>
          <text x="520" y="115" class="fill-category-exploration">1/2</text>
        </g>
      </g>

      <!-- Level 2: 5/12 -->
      <g class="anim-slide" style="--anim-delay: 1.5s;">
        <line x1="320" y1="132" x2="320" y2="148" class="stroke-accent" stroke-width="2" />
        <rect x="295" y="158" width="50" height="24" rx="5"
              class="fill-card stroke-accent/40" stroke-width="1" />
        <text x="320" y="174" text-anchor="middle" class="fill-accent font-mono text-xs font-bold">5/12</text>
      </g>

      <!-- Level 3: 11/24 -->
      <g class="anim-slide" style="--anim-delay: 2s;">
        <line x1="420" y1="134" x2="420" y2="146" class="stroke-secondary" stroke-width="1.5" />
        <rect x="393" y="194" width="54" height="22" rx="5"
              class="fill-card stroke-secondary/30" stroke-width="1" />
        <text x="420" y="209" text-anchor="middle" class="fill-secondary font-mono text-[0.7rem] font-bold">11/24</text>
      </g>

      <!-- Micro dots -->
      <g class="anim-fade" style="--anim-delay: 2.4s;">
        <g class="fill-muted-foreground/40">
          <circle cx="220" cy="140" r="2" />
          <circle cx="228" cy="140" r="2" />
          <circle cx="236" cy="140" r="2" />
          <circle cx="464" cy="140" r="2" />
          <circle cx="472" cy="140" r="2" />
          <circle cx="480" cy="140" r="2" />
        </g>
      </g>

      <g class="anim-slide" style="--anim-delay: 2.5s;">
        <text x="320" y="242" text-anchor="middle"
              class="fill-muted-foreground font-mono text-[0.72rem] font-semibold tracking-widest uppercase">
          Any Two Fractions Contain Infinite More
        </text>
      </g>
    </svg>
  </div>
</Figure>
