---
import Figure from "./figure.astro";
import "../styles/styles.css";
---

<Figure className="flex flex-col items-center">
  <div class="bg-card border-border/40 w-full max-w-xl rounded-xl border p-5 shadow-xs sm:p-6">
    <svg
      viewBox="0 0 480 320"
      xmlns="http://www.w3.org/2000/svg"
      class="h-auto w-full"
      role="img"
      aria-label="Exponential curve showing explosive growth"
    >
      <g class="stroke-border/20" stroke-width="1" stroke-dasharray="4,4">
        <line x1="60" y1="260" x2="440" y2="260" class="stroke-border/60" stroke-width="1.5" stroke-dasharray="none" />
        <line x1="60" y1="40" x2="60" y2="260" class="stroke-border/60" stroke-width="1.5" stroke-dasharray="none" />
        <line x1="150" y1="40" x2="150" y2="260" />
        <line x1="240" y1="40" x2="240" y2="260" />
        <line x1="330" y1="40" x2="330" y2="260" />
        <line x1="420" y1="40" x2="420" y2="260" />
      </g>

      <path d="M 60,260 C 130,258 200,250 240,220 C 290,180 340,110 420,40"
            fill="none" class="stroke-category-explanation" stroke-width="3" stroke-linecap="round"
            style="animation: draw 1.4s 0.3s cubic-bezier(0.25,1,0.5,1) both; --draw-offset: 600;" />

      {[
        { x: 60, y: 260, val: "1", delay: "0.8s", cls: "text-category-explanation fill-category-explanation" },
        { x: 150, y: 257, val: "10", delay: "1.0s", cls: "text-category-explanation fill-category-explanation" },
        { x: 240, y: 220, val: "100", delay: "1.2s", cls: "text-category-explanation fill-category-explanation" },
        { x: 330, y: 135, val: "1k", delay: "1.4s", cls: "text-accent fill-accent font-bold" },
        { x: 420, y: 40, val: "10k", delay: "1.6s", cls: "text-accent fill-accent font-black" },
      ].map((node) => (
        <g class="anim-pop" style={`--anim-delay: ${node.delay}; --anim-duration: 0.5s; transform-origin: ${node.x}px ${node.y}px;`}>
          <circle cx={node.x} cy={node.y} r="5"
                  class={`fill-card stroke-current ${node.cls}`} stroke-width="2.5" />
          <text x={node.x + 8} y={node.y - 8} class={`font-mono text-[0.65rem] ${node.cls}`}>{node.val}</text>
        </g>
      ))}

      <text x="440" y="278" text-anchor="end"
            class="fill-muted-foreground font-mono text-[0.65rem] tracking-wider">Scale Input (n)</text>
    </svg>
  </div>
</Figure>
