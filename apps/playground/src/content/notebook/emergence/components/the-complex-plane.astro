---
import Figure from "./figure.astro";
import "../styles/styles.css";
---

<Figure className="flex flex-col items-center">
  <div class="bg-card border-border/40 w-full max-w-sm rounded-xl border p-5 shadow-xs">
    <svg
      viewBox="0 0 360 340"
      xmlns="http://www.w3.org/2000/svg"
      class="h-auto w-full"
      role="img"
      aria-label="Complex plane with vector 3 + 2i"
    >
      <g class="anim-fade stroke-border/15" stroke-width="1">
        <line x1="50" y1="110" x2="310" y2="110" stroke-dasharray="3,3" />
        <line x1="50" y1="180" x2="310" y2="180" stroke-dasharray="3,3" />
        <line x1="120" y1="50" x2="120" y2="290" stroke-dasharray="3,3" />
        <line x1="230" y1="50" x2="230" y2="290" stroke-dasharray="3,3" />
      </g>

      <g class="stroke-border" stroke-width="2">
        <line x1="30" y1="220" x2="330" y2="220" />
        <line x1="120" y1="30" x2="120" y2="310" class="stroke-primary/40" />
      </g>

      <g class="stroke-muted-foreground/40 anim-fade" stroke-width="1.2" stroke-dasharray="4,4" style="--anim-delay: 0.3s;">
        <line x1="230" y1="220" x2="230" y2="110" class="stroke-secondary" stroke-width="1.5" />
        <line x1="120" y1="110" x2="230" y2="110" class="stroke-accent" stroke-width="1.5" />
      </g>

      <line x1="120" y1="220" x2="230" y2="110"
            class="stroke-primary" stroke-width="3.5" stroke-linecap="round"
            style="animation: draw 1s 0.5s cubic-bezier(0.16,1,0.3,1) both; --draw-offset: 400;" />

      <g class="anim-pop" style="--anim-delay: 1.2s; --anim-duration: 0.5s; transform-origin: 230px 110px;">
        <circle cx="230" cy="110" r="14" class="fill-card stroke-primary" stroke-width="2" />
        <circle cx="230" cy="110" r="5" class="fill-primary" />
        <text x="248" y="102" class="fill-primary font-mono text-xs font-black">3 + 2i</text>
      </g>

      <g class="anim-fade font-mono text-[0.68rem] font-bold" style="--anim-delay: 0.7s;">
        <text x="330" y="236" text-anchor="end" class="fill-muted-foreground text-[0.55rem] tracking-wider uppercase">Real (Re)</text>
        <text x="132" y="42" class="fill-primary text-[0.55rem] tracking-wider uppercase">Imaginary (Im)</text>
        <text x="230" y="238" text-anchor="middle" class="fill-secondary font-black">a = 3</text>
        <text x="104" y="114" text-anchor="end" class="fill-accent font-black">b = 2i</text>
        <text x="105" y="236" text-anchor="end" class="fill-muted-foreground/40">0</text>
      </g>
    </svg>
  </div>
</Figure>
