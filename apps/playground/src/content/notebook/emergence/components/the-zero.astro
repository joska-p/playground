---
import Figure from "./figure.astro";
import "../styles/styles.css";
---

<Figure className="flex flex-col items-center">
  <div class="bg-card border-border/40 w-full max-w-3xl rounded-xl border p-6 shadow-xs">
    <svg
      viewBox="0 0 640 270"
      xmlns="http://www.w3.org/2000/svg"
      class="h-auto w-full"
      role="img"
      aria-label="Subtraction fracture: 3 - 3 creates zero, 3 - 5 creates negatives"
    >
      <!-- Top number line -->
      <g class="anim-slide" style="--anim-delay: 0.1s;">
        <line x1="80" y1="75" x2="560" y2="75" class="stroke-border/40" stroke-width="1" />
        <line x1="320" y1="75" x2="560" y2="75" class="stroke-border" stroke-width="2"
              style="animation: draw 0.8s 0.1s cubic-bezier(0.16,1,0.3,1) both; --draw-offset: 240;" />
        <g class="stroke-border/60" stroke-width="1.5">
          <line x1="320" y1="68" x2="320" y2="82" />
          <line x1="400" y1="68" x2="400" y2="82" />
          <line x1="480" y1="68" x2="480" y2="82" />
          <line x1="560" y1="68" x2="560" y2="82" />
        </g>
        <g class="fill-muted-foreground font-mono text-xs" text-anchor="middle">
          <text x="400" y="52" class="font-bold">1</text>
          <text x="480" y="52" class="font-bold">2</text>
          <text x="560" y="52" class="font-bold">3</text>
        </g>
      </g>

      <!-- The blindspot -->
      <g class="anim-slide" style="--anim-delay: 0.6s;">
        <rect x="295" y="32" width="50" height="28" rx="6"
              class="fill-card stroke-accent/80" stroke-width="1.5" />
        <text x="320" y="51" text-anchor="middle" class="fill-accent font-mono text-sm font-bold">?</text>
        <path d="M 320,75 L 312,95 L 328,115 L 315,135"
              class="stroke-accent/70 fill-none" stroke-width="2" stroke-linecap="round" />
        <g class="font-mono text-[0.65rem] font-medium" text-anchor="middle">
          <text x="230" y="98" class="fill-destructive">3 − 3 = ∅</text>
          <text x="230" y="116" class="fill-destructive/80">3 − 5 = ∅</text>
        </g>
      </g>

      <line x1="80" y1="145" x2="560" y2="145" class="stroke-border/20" stroke-width="1" stroke-dasharray="4,4"
            class="anim-fade" style="--anim-delay: 1s;" />

      <!-- New symmetric line -->
      <g class="anim-slide" style="--anim-delay: 1.2s;">
        <line x1="80" y1="205" x2="560" y2="205" class="stroke-border" stroke-width="2"
              style="animation: draw 0.8s 1.3s cubic-bezier(0.16,1,0.3,1) both; --draw-offset: 480;" />
        <g class="stroke-border/50" stroke-width="1.2">
          {[-3, -2, -1, 0, 1, 2, 3].map((v) => (
            <line x1={320 + v * 80} y1="198" x2={320 + v * 80} y2="212" />
          ))}
        </g>
        <g class="fill-muted-foreground/70 font-mono text-xs" text-anchor="middle">
          <text x="80">−3</text>
          <text x="160">−2</text>
          <text x="240">−1</text>
          <text x="400" class="fill-category-tutorial font-semibold">1</text>
          <text x="480" class="fill-category-tutorial font-semibold">2</text>
          <text x="560" class="fill-category-tutorial font-semibold">3</text>
        </g>
      </g>

      <!-- Zero node -->
      <g class="anim-pop" style="--anim-delay: 1.8s; --anim-duration: 0.6s; transform-origin: 320px 205px;">
        <circle cx="320" cy="205" r="16" class="fill-category-how-to stroke-card" stroke-width="3" />
        <text x="320" y="210" text-anchor="middle" class="fill-secondary-foreground font-mono text-xs font-bold">0</text>
      </g>

      <g class="anim-slide" style="--anim-delay: 2.2s;">
        <text x="320" y="256" text-anchor="middle"
              class="fill-muted-foreground font-mono text-[0.7rem] tracking-wider uppercase opacity-80">
          ZERO ANCHORS BALANCE · 3 − 3 = 0 · 3 − 5 = −2
        </text>
      </g>
    </svg>
  </div>
</Figure>
