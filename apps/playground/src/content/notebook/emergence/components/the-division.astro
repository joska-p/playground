---
import Figure from "./figure.astro";
import "../styles/styles.css";
---

<Figure className="flex flex-col items-center">
  <div class="bg-card border-border/40 w-full max-w-3xl rounded-xl border p-6 shadow-xs sm:p-8">
    <svg
      viewBox="0 0 640 280"
      xmlns="http://www.w3.org/2000/svg"
      class="h-auto w-full"
      role="img"
      aria-label="Division shatters the integer line: 1 ÷ 2 has no integer answer"
    >
      <!-- Integer line -->
      <g>
        <line x1="80" y1="65" x2="560" y2="65" class="stroke-border" stroke-width="2.5"
              style="animation: draw 0.8s 0.1s cubic-bezier(0.16,1,0.3,1) both; --draw-offset: 480;" />
        <g class="stroke-border/70" stroke-width="2">
          <line x1="140" y1="55" x2="140" y2="75" />
          <line x1="320" y1="55" x2="320" y2="75" />
          <line x1="500" y1="55" x2="500" y2="75" />
        </g>
        <g class="fill-foreground font-mono text-sm font-bold" text-anchor="middle">
          <text x="140" y="42">0</text>
          <text x="320" y="42">1</text>
          <text x="500" y="42">2</text>
        </g>
      </g>

      <!-- Fracture -->
      <g class="anim-slide" style="--anim-delay: 0.7s;">
        <path d="M 230,65 Q 230,95 230,105" class="stroke-accent fill-none" stroke-width="2" stroke-dasharray="4,3" />
        <g class="stroke-accent fill-none" stroke-width="2.5" stroke-linecap="round">
          <path d="M 230,100 L 235,112 L 227,124" />
          <path d="M 223,105 L 228,115 L 233,125" class="opacity-40" stroke-width="1.5" />
        </g>
        <rect x="135" y="102" width="64" height="26" rx="6"
              class="fill-card stroke-accent" stroke-width="1.5" />
        <text x="167" y="119" text-anchor="middle" class="fill-accent font-mono text-xs font-bold">1 ÷ 2</text>
        <text x="265" y="120" class="fill-destructive font-mono text-xs font-black tracking-wide">ERROR: ∅</text>
      </g>

      <line x1="80" y1="155" x2="560" y2="155" class="stroke-border/40" stroke-width="1.5" stroke-dasharray="6,4"
            class="anim-fade" style="--anim-delay: 1s;" />

      <!-- Two new rational spaces -->
      <g class="font-sans anim-slide" style="--anim-delay: 1.4s;">
        <g style="animation: slide-up 0.6s 1.4s cubic-bezier(0.16,1,0.3,1) both;">
          <rect x="100" y="180" width="190" height="56" rx="10"
                class="fill-category-explanation/10 stroke-category-explanation/40" stroke-width="2" />
          <text x="195" y="211" text-anchor="middle" class="fill-category-explanation font-serif text-2xl font-black">½</text>
          <text x="195" y="225" text-anchor="middle"
                class="fill-muted-foreground font-mono text-[0.6rem] font-semibold tracking-widest uppercase">
            Rational Space</text>
        </g>
        <g style="animation: slide-up 0.6s 1.4s cubic-bezier(0.16,1,0.3,1) both;">
          <rect x="350" y="180" width="190" height="56" rx="10"
                class="fill-category-explanation/10 stroke-category-explanation/40" stroke-width="2" />
          <text x="445" y="211" text-anchor="middle" class="fill-category-explanation font-serif text-2xl font-black">³⁄₂</text>
          <text x="445" y="225" text-anchor="middle"
                class="fill-muted-foreground font-mono text-[0.6rem] font-semibold tracking-widest uppercase">
            Dense Continuum</text>
        </g>
      </g>

      <g class="anim-slide" style="--anim-delay: 2s;">
        <text x="320" y="268" text-anchor="middle"
              class="fill-muted-foreground font-mono text-[0.72rem] font-semibold tracking-widest uppercase opacity-90">
          ℚ = &lbrace; a/b | a,b ∈ ℤ, b ≠ 0 &rbrace; · The Continuum Fills Up
        </text>
      </g>
    </svg>
  </div>
</Figure>
