{
  "extends": ["@repo/typescript-config/astro.json", "astro/tsconfigs/strict"],
  "include": ["src", ".astro/types.d.ts"],
  "exclude": ["dist"],
  "compilerOptions": {
    "outDir": "./dist",
    "paths": {
      "@components/*": ["./src/components/*"],
      "@pages/*": ["./src/pages/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@data/*": ["./src/data/*"],
      "@utils/*": ["./src/utils/*"]
    }
  }
}
